+// tmux emits OSC 52 clipboard writes with an EMPTY selection field (`\e]52;;<base64>`),
+// but the stock BrowserClipboardProvider only honors the explicit `c` (SYSTEM)
+// target, so it silently drops every tmux copy. Treat an empty selection the same
+// as the system clipboard so plain mouse-drag copies inside tmux reach the OS clipboard.
+class TmuxAwareClipboardProvider implements IClipboardProvider {
+    private isSystemSelection(selection: ClipboardSelectionType): boolean {
+        return (selection as string) === '' || selection === ClipboardSelectionType.SYSTEM;
+    }
+
+    public async readText(selection: ClipboardSelectionType): Promise<string> {
+        if (!this.isSystemSelection(selection)) return '';
+        return navigator.clipboard.readText();
+    }
+
+    public async writeText(selection: ClipboardSelectionType, data: string): Promise<void> {
+        if (!this.isSystemSelection(selection)) return;
+        return navigator.clipboard.writeText(data);
+    }
+}
