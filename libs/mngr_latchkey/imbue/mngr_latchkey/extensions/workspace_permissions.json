{
  "path_prefix": "/minds-api-proxy/api/v1/workspaces",
  "verbs": [
    {
      "permission": "minds-workspaces-read",
      "method": "GET",
      "path": { "kind": "tree" },
      "display_name": "List and read workspaces",
      "description": "List all workspaces and read their detail, version, and backups. Applies to all workspaces (listing is not per-workspace)."
    },
    {
      "permission": "minds-workspaces-create",
      "method": "POST",
      "path": { "kind": "collection" },
      "display_name": "Create workspaces",
      "description": "Create new workspaces."
    },
    {
      "permission": "minds-workspaces-destroy",
      "method": "POST",
      "path": { "kind": "targeted", "suffix": "/destroy$" },
      "display_name": "Destroy a workspace",
      "description": "Permanently destroy the selected workspace."
    },
    {
      "permission": "minds-workspaces-lifecycle",
      "method": "POST",
      "path": { "kind": "targeted", "suffix": "/(start|stop)$" },
      "display_name": "Start/stop a workspace",
      "description": "Start or stop the selected workspace's host."
    },
    {
      "permission": "minds-workspaces-backups-export",
      "method": "POST",
      "path": { "kind": "targeted", "suffix": "/backups/[^/]+/export$" },
      "display_name": "Export a workspace's backups",
      "description": "Export a backup snapshot of the selected workspace."
    },
    {
      "permission": "minds-workspaces-ssh",
      "method": "POST",
      "path": { "kind": "targeted", "suffix": "/ssh$" },
      "display_name": "Establish SSH access to a workspace",
      "description": "Establish SSH access into the selected workspace."
    },
    {
      "permission": "minds-workspaces-backups-manage",
      "method": "POST",
      "path": { "kind": "targeted", "suffix": "/backup-service/(update(/cancel)?|configure|disable|verification)$" },
      "display_name": "Manage a workspace's backups",
      "description": "Update the selected workspace's backup service, enable, disable, or repoint its backups, and toggle backup verification."
    },
    {
      "permission": "minds-workspaces-update",
      "method": "PATCH",
      "path": { "kind": "targeted", "suffix": "$" },
      "display_name": "Update a workspace",
      "description": "Update the selected workspace's settings (color, account association)."
    },
    {
      "permission": "minds-workspaces-recover",
      "method": ["GET", "POST"],
      "path": { "kind": "targeted", "suffix": "/(health|restart)$" },
      "display_name": "Recover a workspace",
      "description": "Check the selected workspace's health and restart its services or host."
    },
    {
      "permission": "minds-workspaces-resize",
      "method": "POST",
      "path": { "kind": "targeted", "suffix": "/resize$" },
      "display_name": "Resize a workspace's resources",
      "description": "Set the selected workspace's CPU and memory allotment. Set-only: values that cannot apply live take effect on the workspace's next restart, and restarting requires its own permission."
    },
    {
      "permission": "minds-workspaces-sharing",
      "method": ["GET", "PUT", "DELETE"],
      "path": { "kind": "targeted", "suffix": "/sharing/[^/]+(/readiness)?$" },
      "display_name": "Manage a workspace's sharing",
      "description": "View and change Cloudflare sharing for the selected workspace's services."
    }
  ]
}
