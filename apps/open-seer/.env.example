# open-seer configuration (DESIGN.md §9). Modal secrets in production; locally: cp .env.example .env

# Sentry org auth token with event:read, issue:read, event:write (assignment/merge/status).
SENTRY_AUTH_TOKEN=

# Sentry organization slug.
SENTRY_ORG=

# Only Sentry projects with this prefix are swept.
SENTRY_PROJECT_PREFIX=minds-

# The team issues are assigned to — assigned means an agent is on it.
SENTRY_TEAM=minds-agent

# GitHub PAT (v1; a GitHub App is the open question in DESIGN.md §12).
GITHUB_TOKEN=

# The minds mngr repo fixers open PRs against (owner/name).
TARGET_REPO=

# Mirror sync source — the tick pushes main + new/updated branches each run.
MIRROR_SOURCE_REPO=imbue-ai/mngr

# Mirror sync destination — branches/PRs here are never deleted.
MIRROR_REPO=imbue-ai/agentic-mngr

# Anthropic credential for the manager + fixer agents (strongest model). Set
# either an API key or a Claude Code OAuth token (`claude setup-token`); if both
# are set, Claude Code prefers the OAuth token. At least one is required.
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=

# Max fixer agents spawned per sweep; overflow issues stay unassigned for a later sweep.
OPEN_SEER_MAX_FIXERS=10

# Kill switch — the tick exits immediately unless truthy.
OPEN_SEER_ENABLED=1

# Sweeps print intended actions (assign/merge/spawn/PR) instead of executing writes.
OPEN_SEER_DRY_RUN=0

# mngr provider the tick spawns the sweep on (default modal; docker for local testing).
OPEN_SEER_SWEEP_PROVIDER=modal
