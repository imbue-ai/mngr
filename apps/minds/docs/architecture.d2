direction: right

classes: {
  container: {
    style: {
      border-radius: 8
      stroke-dash: 3
    }
  }
  grouping: {
    style: {
      stroke-dash: 5
      fill: transparent
      border-radius: 10
      font-size: 14
      bold: true
    }
  }
}

# -- User's Computer --

user-computer: User's Computer {
  style: {
    fill: "#f0f4ff"
    stroke: "#4a6fa5"
    stroke-width: 2
    border-radius: 12
    font-size: 18
    bold: true
  }

  minds-app: Minds Electron App {
    style: {
      fill: "#e8f0fe"
      stroke: "#3b82f6"
      stroke-width: 2
      border-radius: 10
      font-size: 16
      bold: true
    }

    desktop-server: Python Desktop Server {
      style: {
        fill: "#e0e7ff"
        stroke: "#4f46e5"
        stroke-width: 2
        border-radius: 8
        font-size: 14
        bold: true
      }

      observe: mngr observe {
        style: {
          fill: "#fef3c7"
          stroke: "#d97706"
          border-radius: 4
          font-size: 12
        }
      }

      events-1: "mngr events (host 1)" {
        style: {
          fill: "#d1fae5"
          stroke: "#059669"
          border-radius: 4
          font-size: 12
        }
      }

      events-2: "mngr events (host 2)" {
        style: {
          fill: "#d1fae5"
          stroke: "#059669"
          border-radius: 4
          font-size: 12
        }
      }

      observe -> events-1: {style.opacity: 0}
      observe -> events-2: {style.opacity: 0}
    }
  }

  latchkey-local: latchkey / detent {
    style: {
      fill: "#f3e8ff"
      stroke: "#9333ea"
      border-radius: 4
      font-size: 12
    }
  }
}

# -- Imbue Services (declared before Compute Provider so it appears to the left) --

imbue-services: Imbue Services {
  class: grouping
  style: {
    stroke: "#db2777"
  }

  connector: Remote Connector Service {
    style: {
      fill: "#fce7f3"
      stroke: "#ec4899"
      stroke-width: 2
      border-radius: 6
      font-size: 14
      bold: true
    }
  }

  supertokens: SuperTokens {
    style: {
      fill: "#fee2e2"
      stroke: "#ef4444"
      border-radius: 4
      font-size: 12
    }
  }

  litellm: LiteLLM {
    style: {
      fill: "#ffedd5"
      stroke: "#f97316"
      border-radius: 4
      font-size: 12
    }
  }

  connector -> supertokens: auth {
    style.stroke: "#ef4444"
  }
  connector -> litellm: virtual keys {
    style.stroke: "#f97316"
  }
}

# -- Compute Provider (dashed grouping containing both remote hosts) --

compute: Compute Provider {
  class: grouping
  style: {
    stroke: "#0284c7"
  }

  host-1: Remote Host 1 {
    style: {
      fill: "#fefce8"
      stroke: "#ca8a04"
      stroke-width: 2
      border-radius: 12
      font-size: 16
      bold: true
    }

    vps-1: VPS {
      style: {
        fill: "#fef9c3"
        stroke: "#eab308"
        border-radius: 8
        font-size: 14
      }

      latchkey-1: latchkey / detent {
        style: {
          fill: "#f3e8ff"
          stroke: "#9333ea"
          border-radius: 4
          font-size: 12
        }
      }

      docker-1: Docker Container {
        class: container
        style: {
          fill: "#ede9fe"
          stroke: "#7c3aed"
          border-radius: 6
          font-size: 13
        }

        agent-1: Agent (Claude Code) {
          style: {
            fill: "#c4b5fd"
            stroke: "#6d28d9"
            border-radius: 4
            font-size: 12
            bold: true
          }
        }
      }
    }
  }

  host-2: Remote Host 2 {
    style: {
      fill: "#fefce8"
      stroke: "#ca8a04"
      stroke-width: 2
      border-radius: 12
      font-size: 16
      bold: true
    }

    vps-2: VPS {
      style: {
        fill: "#fef9c3"
        stroke: "#eab308"
        border-radius: 8
        font-size: 14
      }

      latchkey-2: latchkey / detent {
        style: {
          fill: "#f3e8ff"
          stroke: "#9333ea"
          border-radius: 4
          font-size: 12
        }
      }

      docker-2: Docker Container {
        class: container
        style: {
          fill: "#ede9fe"
          stroke: "#7c3aed"
          border-radius: 6
          font-size: 13
        }

        agent-2: Agent (Claude Code) {
          style: {
            fill: "#c4b5fd"
            stroke: "#6d28d9"
            border-radius: 4
            font-size: 12
            bold: true
          }
        }
      }
    }
  }
}

# -- AI Providers (dashed grouping, no background) --

ai-providers: AI Providers {
  class: grouping
  style: {
    stroke: "#16a34a"
  }

  anthropic: Anthropic {
    style: {
      fill: "#dcfce7"
      stroke: "#22c55e"
      border-radius: 4
      font-size: 12
    }
  }

  openai: OpenAI {
    style: {
      fill: "#dcfce7"
      stroke: "#22c55e"
      border-radius: 4
      font-size: 12
    }
  }
}

# -- Connections --

# Desktop server to remote connector
user-computer.minds-app.desktop-server -> imbue-services.connector: API calls {
  style: {
    stroke: "#db2777"
    stroke-width: 2
  }
}

# Remote connector provisions VPSs via compute provider
imbue-services.connector -> compute: provisions VPSs {
  style: {
    stroke: "#0284c7"
  }
}

# Observe watches which hosts are online
user-computer.minds-app.desktop-server.observe -> compute.host-1: monitors {
  style: {
    stroke: "#d97706"
    stroke-dash: 5
  }
}
user-computer.minds-app.desktop-server.observe -> compute.host-2: monitors {
  style: {
    stroke: "#d97706"
    stroke-dash: 5
  }
}

# Events processes connected to agents
user-computer.minds-app.desktop-server.events-1 -> compute.host-1.vps-1.docker-1.agent-1: streams events {
  style: {
    stroke: "#059669"
    stroke-width: 2
  }
}
user-computer.minds-app.desktop-server.events-2 -> compute.host-2.vps-2.docker-2.agent-2: streams events {
  style: {
    stroke: "#059669"
    stroke-width: 2
  }
}

# Desktop server to local latchkey
user-computer.minds-app.desktop-server -> user-computer.latchkey-local {
  style: {
    stroke: "#9333ea"
    stroke-width: 2
  }
}

# Agents to their respective host latchkey processes
compute.host-1.vps-1.docker-1.agent-1 -> compute.host-1.vps-1.latchkey-1 {
  style: {
    stroke: "#9333ea"
    stroke-width: 2
  }
}
compute.host-2.vps-2.docker-2.agent-2 -> compute.host-2.vps-2.latchkey-2 {
  style: {
    stroke: "#9333ea"
    stroke-width: 2
  }
}

# Agents talk to LiteLLM (which acts as AI gateway)
compute.host-1.vps-1.docker-1.agent-1 -> imbue-services.litellm: inference requests {
  style: {
    stroke: "#f97316"
    stroke-width: 2
  }
}
compute.host-2.vps-2.docker-2.agent-2 -> imbue-services.litellm: inference requests {
  style: {
    stroke: "#f97316"
    stroke-width: 2
  }
}

# LiteLLM proxies to AI providers
imbue-services.litellm -> ai-providers.anthropic: proxied requests {
  style: {
    stroke: "#22c55e"
    stroke-width: 2
  }
}
imbue-services.litellm -> ai-providers.openai: proxied requests {
  style: {
    stroke: "#22c55e"
    stroke-width: 2
  }
}
