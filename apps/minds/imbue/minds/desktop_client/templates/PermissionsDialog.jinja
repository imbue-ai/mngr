{#def display_name, accent, extra_scripts="" #}
{#
  Modal chrome for the permission-request dialogs: backdrop, dialog card,
  close button, and the standard submit/deny/escape JS shared by every
  permission backend. The dialog body is the default content slot --
  subpages compose PermissionsHeader, PermissionsForm,
  PermissionsManualCredentials, and PermissionsError inside.

  ``extra_scripts`` is an optional Markup string appended after the
  standard JS, for backend-specific client wiring.

  The standard JS reads the request_id from the form's action URL (the
  PermissionsForm component supplies that), so this component does not
  need request_id itself.
#}
{% set _body_style = "--workspace-accent: " ~ accent ~ ";" %}
{% set _scripts %}
<script>
  window.closePermissionDialog = function () {
    if (window.minds && window.minds.closeModal) {
      window.minds.closeModal();
    } else {
      window.location.href = "/";
    }
  };
  window.onBackdropClick = function (event) {
    if (event.target && event.target.id === "permissions-backdrop") {
      window.closePermissionDialog();
    }
  };
  document.addEventListener("keydown", function (e) {
    if (e.key === "Escape") window.closePermissionDialog();
  });

  (function () {
    const form = document.getElementById("permissions-form");
    const approveBtn = document.getElementById("permissions-approve-btn");
    const errorBox = document.getElementById("permissions-error");
    const errorMsg = document.getElementById("permissions-error-message");

    // Backend-agnostic Approve enabling: Approve becomes available as
    // soon as any name="permissions" input is checked. Backends that
    // want different validation can override updateApproveState in the
    // extra_scripts arg.
    window.updateApproveState = function () {
      const anyChecked = form.querySelector('input[name="permissions"]:checked') !== null;
      approveBtn.disabled = !anyChecked;
    };
    form.querySelectorAll('input[name="permissions"]').forEach(function (cb) {
      cb.addEventListener("change", window.updateApproveState);
    });
    window.updateApproveState();

    form.addEventListener("submit", async function (e) {
      e.preventDefault();
      approveBtn.disabled = true;
      errorBox.classList.add("hidden");
      const manualBox = document.getElementById("permissions-manual-credentials");
      if (manualBox) manualBox.classList.add("hidden");
      const progress = document.getElementById("permissions-progress");
      if (progress) progress.classList.remove("hidden");

      const formData = new FormData(form);
      try {
        const response = await fetch(form.action, {
          method: "POST",
          body: formData,
          credentials: "same-origin",
        });
        if (!response.ok) {
          const text = await response.text();
          throw new Error(text || ("HTTP " + response.status));
        }
        const data = await response.json();
        if (data.outcome === "GRANTED") {
          window.closePermissionDialog();
          return;
        }
        if (progress) progress.classList.add("hidden");
        if (data.outcome === "NEEDS_MANUAL_CREDENTIALS") {
          const cmdEl = document.getElementById("permissions-manual-credentials-command");
          const msgEl = document.getElementById("permissions-manual-credentials-message");
          if (cmdEl) cmdEl.textContent = data.set_credentials_example || "";
          if (msgEl) msgEl.textContent = data.message || "";
          if (manualBox) manualBox.classList.remove("hidden");
          window.updateApproveState();
          return;
        }
        // FAILED: the approval did not complete (e.g. the browser sign-in
        // flow failed). The request stays pending server-side, so show the
        // reason and re-enable Approve so the user can retry -- this is a
        // failure, not a denial.
        if (data.outcome === "FAILED") {
          errorMsg.textContent = data.message || "Approval failed; please try again.";
          errorBox.classList.remove("hidden");
          approveBtn.disabled = false;
          return;
        }
        errorMsg.textContent = data.message || "Authorization failed.";
        errorBox.classList.remove("hidden");
        approveBtn.disabled = false;
      } catch (err) {
        if (progress) progress.classList.add("hidden");
        errorMsg.textContent = err && err.message ? err.message : String(err);
        errorBox.classList.remove("hidden");
        approveBtn.disabled = false;
      }
    });

    window.submitPermissionDeny = function () {
      approveBtn.disabled = true;
      // Fire-and-forget: don't make the user wait for the server to
      // notify the agent. keepalive: true lets the request outlive the
      // navigation in closePermissionDialog so the response event still
      // gets written and the agent still gets notified.
      const denyUrl = form.action.replace(/\/grant\b/, "/deny");
      fetch(denyUrl, {
        method: "POST",
        credentials: "same-origin",
        keepalive: true,
      }).catch(function () {});
      window.closePermissionDialog();
    };
  })();
</script>
{{ extra_scripts }}
{% endset %}
{# Transparent body so the dialog reads as a modal: the desktop client
   hosts this page in a transparent full-window overlay view stacked over
   the workspace, and the dim backdrop below reveals the workspace behind
   it. Opened directly in a browser (no modal host) it degrades to a
   dimmed, centered card on the default surface. #}
<Base title={{ "Permission request: " ~ display_name }}
      body_class="bg-transparent text-zinc-900 font-sans antialiased"
      body_style={{ _body_style }}
      scripts={{ _scripts }}>
  {# The backdrop only centers the dialog; it never scrolls. The dialog
     is capped at the viewport height and its inner wrapper scrolls, so
     an overflowing dialog (e.g. after "Adjust" reveals the editor)
     shows a scrollbar inside the card rather than down the full width
     of the app. #}
  <div id="permissions-backdrop"
       class="fixed inset-0 bg-black/40 flex items-center justify-center p-6"
       onclick="onBackdropClick(event)">
    <div id="permissions-dialog"
         class="relative w-full max-w-[640px] max-h-full flex flex-col bg-white border border-zinc-200 rounded-xl shadow-xl overflow-hidden">
      <DialogCloseButton id="permissions-close-btn" onclick="closePermissionDialog()" />
      <div class="overflow-y-auto min-h-0 p-6 sm:p-7">
        {{ content }}
      </div>
    </div>
  </div>
</Base>
