{#def extra="" #}
{#
  Card laid out as a left/right flex row (name + action). Usage:
    <CardRow>
      <span>name</span>
      <Button variant="primary">Action</Button>
    </CardRow>
#}
<div class="bg-white border border-zinc-200 rounded-xl shadow-sm p-4 flex items-center justify-between gap-3 {{ extra }}">
  {{ content }}
</div>
