{#def val, title, desc, editable=false, selected=false, preset="", placeholder="", rows=2 #}
{#
  Selectable radio-style onboarding option used by the creating-page question
  flow. ``val`` is the option's stable value (read by creating.js). Editable
  options reveal a textarea when selected (CSS in app.css); the textarea
  is prefilled with ``preset`` and its value is the answer. Visual state is
  driven by the ``opt-selected`` class, toggled by creating.js.
#}
<div class="opt{% if editable %} opt-editable{% endif %}{% if selected %} opt-selected{% endif %}"
     data-val="{{ val }}"{% if editable %} data-editable="1"{% endif %}>
  <span class="opt-radio"></span>
  <div class="opt-body">
    <span class="block text-sm font-medium text-primary">{{ title }}</span>
    <span class="opt-desc block text-[12.5px] text-secondary leading-snug mt-2">{{ desc }}</span>
    {% if editable %}
      <div class="opt-edit mt-8">
        <textarea class="opt-text w-full px-12 py-8 text-[13px] rounded-md border border-default bg-surface-primary text-primary outline-none transition focus:border-accent focus:ring-2 focus:ring-accent/40 leading-snug"
                  rows="{{ rows }}" placeholder="{{ placeholder }}">{{ preset }}</textarea>
      </div>
    {% endif %}
  </div>
</div>
