{#def title="Minds", theme="dark", workspace_bg="#0B292B", body_class="font-sans antialiased bg-token-workspace text-token-primary", body_style="", body_attrs="", head="", scripts="" #}
{#
  Base layout. Every page wraps its content in this component.

  Pulls in the Tailwind Play CDN JS (downloaded once into /_static/tailwind.js
  and served locally, so this is offline-safe after the first fetch) plus
  the hand-written tokens.css. Tailwind generates layout utilities at
  runtime; colors / type / surfaces come from tokens.css via the
  token-utility classes (text-token-*, bg-token-*, border-token-*).

  Args:
    title         <title> contents. Defaults to "Minds".
    theme         "dark" | "light" -- written to <html data-theme="...">.
                  Inferred server-side from the picked workspace color's
                  luminance (see design_tokens.theme_for); foreground
                  tokens auto-flip via the [data-theme=*] CSS scopes.
    workspace_bg  Resolved CSS color (hex / oklch / rgb literal) for the
                  page surface; written to `<html style="--workspace-bg:
                  ..."> so .bg-token-workspace and any other token-bound
                  surface picks it up. Defaults to the `confusion`
                  preset's hex (#0B292B), which is the everywhere-default.
    body_class    classes on body. Default consumes the workspace bg
                  + token-primary text. Override only when you need a
                  non-standard surface.
    body_style    inline style on body. Pages may stack additional
                  custom-property bindings (e.g. --ws-row for per-row
                  identity dots).
    body_attrs    extra attributes on body, as a raw HTML fragment.
    head          extra head content (page-specific link/meta tags).
    scripts       script tags emitted just before /body. Prefer
                  src=/_static/foo.js over inline JS.
#}
<!DOCTYPE html>
<html lang="en" data-theme="{{ theme }}" style="--workspace-bg: {{ workspace_bg }};">
<head>
  <meta charset="UTF-8">
  <title>{{ title }}</title>
  <script src="/_static/tailwind.js"></script>
  <link rel="stylesheet" href="/_static/tokens.css">
  {{ head }}
</head>
<body class="{{ body_class }}" style="{{ body_style }}" {{ body_attrs }}>
  {{ content }}
  {{ scripts }}
</body>
</html>
