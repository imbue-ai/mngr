{#def title="Minds", body_class="bg-white text-zinc-900 font-sans antialiased", body_style="", body_attrs="", head="", scripts="" #}
{#
  Base layout. Every page wraps its content in this component.
  Pulls in the compiled, minified Tailwind v4 stylesheet (/_static/app.min.css)
  -- a single tree-shaken sheet built from static/app.css by `just minds-css`
  (no runtime JIT, fully offline). app.css holds both the Tailwind directives
  and the hand-written tokens/component CSS that used to live in tokens.css.
  Because the sheet is compiled, a new/changed Tailwind class only takes effect
  after a rebuild; `just minds-start` runs the compiler in --watch mode for dev.

  Args:
    title       contents. Defaults to "Minds".
    body_class  classes on body. Default is the light page surface.
    body_style  free-form inline style on body. The chrome page uses
                this to set ``background-color: var(--titlebar-bg, ...)``
                so the body color bleeds through the content iframe's
                rounded top corners; other pages can use it for any
                document-root CSS variable they need to scope to a
                single page (e.g. a per-workspace ``--workspace-accent``
                feeding accent-spine / accent-swatch consumers).
    body_attrs  extra attributes on body, as a raw HTML fragment (e.g.
                'data-is-mac="true" data-mngr-forward-origin="..."').
    head        extra head content (page-specific link/meta tags). HTML.
    scripts     script tags emitted just before /body. HTML. Prefer
                src=/_static/foo.js over inline JS.
#}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>{{ title }}</title>
  <script>
    // Apply the persisted theme before first paint (no flash). The styleguide
    // dev toggle writes localStorage['minds-theme'] = 'dark' | 'light'; the
    // formal light/dark UX lands in a later stage. Absent flag => light.
    try { if (localStorage.getItem('minds-theme') === 'dark') document.documentElement.classList.add('dark'); } catch (e) {}
  </script>
  <link rel="stylesheet" href="/_static/app.min.css">
  {{ head }}
</head>
<body class="{{ body_class }}" style="{{ body_style }}" {{ body_attrs }}>
  {{ content }}
  {{ scripts }}
</body>
</html>
