{#def #}
{#
  Hidden error notice. Rendered hidden by default; the inbox shell JS
  unhides it and populates the message when the server returns a
  failure outcome (HTTP error or non-GRANTED non-NEEDS_MANUAL outcome).
#}
<div id="permissions-error" class="hidden mt-4">
  <Notice variant="error">
    <p class="font-semibold">Authorization failed</p>
    <p id="permissions-error-message"></p>
  </Notice>
</div>
