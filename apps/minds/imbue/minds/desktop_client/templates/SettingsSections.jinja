{#def report_unexpected_errors=false, include_error_logs=false, has_saved_backup_password=false, dark_mode=false, region_options=[], region_selected="", app_version="" #}
{#
  The app-level ("Minds") settings sections, shared verbatim between the
  centered settings modal (pages.SettingsModal, the Electron overlay surface)
  and the full-page browser-mode fallback (pages.Settings). All sections are
  per-machine device settings, not account-scoped. Interactivity lives in
  /_static/app_settings.js, which binds by the element ids below -- so this
  component must appear at most once per page.

  ``region_options`` / ``region_selected`` feed the default-region select for
  Imbue Cloud workspaces (the same per-provider preference the create form
  reads and writes); when ``region_options`` is empty the section is omitted.
  ``app_version`` is the desktop app version (resolve_release_id()).
#}
<div class="flex flex-col gap-8">
  <section>
    <h2 class="type-heading text-primary mb-1">Appearance</h2>
    <label class="flex items-start justify-between gap-3 py-3 border-b border-subtle cursor-pointer">
      <span>
        <span class="type-body text-primary font-semibold">Dark mode</span>
        <span class="block type-helper text-tertiary">Switch between the light and dark window theme.</span>
      </span>
      <input type="checkbox" id="dark-mode-toggle" class="mt-1 shrink-0"
             {% if dark_mode %}checked{% endif %}>
    </label>
  </section>

  <section>
    <h2 class="type-heading text-primary mb-1">Error reporting</h2>
    <p class="type-helper text-tertiary mb-1">Applies to this device, regardless of which account is signed in.</p>
    <label class="flex items-start justify-between gap-3 py-3 border-b border-subtle cursor-pointer">
      <span>
        <span class="type-body text-primary font-semibold">Report unexpected errors</span>
        <span class="block type-helper text-tertiary">Send a report to Imbue when something goes wrong.</span>
      </span>
      <input type="checkbox" id="report-errors-toggle" class="mt-1 shrink-0"
             {% if report_unexpected_errors %}checked{% endif %}>
    </label>
    <label id="include-logs-row"
           class="flex items-start justify-between gap-3 py-3 border-b border-subtle cursor-pointer {% if not report_unexpected_errors %}hidden{% endif %}">
      <span>
        <span class="type-body text-primary font-semibold">Include logs</span>
        <span class="block type-helper text-tertiary">Attach recent log files to help diagnose the problem.</span>
      </span>
      <input type="checkbox" id="include-logs-toggle" class="mt-1 shrink-0"
             {% if include_error_logs %}checked{% endif %}>
    </label>
  </section>

  {% if region_options %}
  <section>
    <h2 class="type-heading text-primary mb-1">Account</h2>
    <div class="flex items-start justify-between gap-3 py-3 border-b border-subtle">
      <span>
        <span class="type-body text-primary font-semibold">Default region</span>
        <span class="block type-helper text-tertiary">Pre-selected when creating Imbue Cloud workspaces.</span>
      </span>
      <Select id="default-region-select" name="default_region" width="w-48">
        {% for region in region_options %}
          <option value="{{ region }}" {% if region == region_selected %}selected{% endif %}>{{ region }}</option>
        {% endfor %}
      </Select>
    </div>
    <p id="default-region-error" class="hidden type-helper text-important mt-1" role="alert"></p>
  </section>
  {% endif %}

  {# Backup master password change: the server rekeys every existing
     backed-up workspace's repository synchronously, then answers with
     per-workspace results. #}
  <section>
    <h2 class="type-heading text-primary mb-1">Backup password</h2>
    <p class="type-helper text-tertiary mb-3">
      The shared recovery password for all workspace backups (initially empty). Changing it
      rekeys the backup repository of every existing workspace; destroyed workspaces keep
      their old password.{% if has_saved_backup_password %} A copy is currently saved on this device.{% endif %}
    </p>
    <div class="flex flex-col gap-2 max-w-md">
      <input type="password" id="backup-new-password" autocomplete="new-password"
             placeholder="new master password (empty is allowed)"
             class="h-[34px] px-3 rounded-full type-body bg-surface-secondary text-primary">
      <input type="password" id="backup-new-password-confirm" autocomplete="new-password"
             placeholder="repeat the new master password"
             class="h-[34px] px-3 rounded-full type-body bg-surface-secondary text-primary">
      <label class="type-helper text-secondary flex items-center gap-2">
        <input type="checkbox" id="backup-change-save-password">
        Save this password so you don't have to retype it
      </label>
      <div class="flex items-center gap-2">
        <Button variant="secondary" id="backup-change-password-btn">Change master password</Button>
        <span id="backup-change-spinner" class="hidden type-section text-secondary">Rekeying workspaces...</span>
      </div>
      <p id="backup-change-error" class="hidden type-body text-important" role="alert"></p>
      <ul id="backup-change-results" class="hidden type-helper text-secondary list-disc pl-4" aria-live="polite"></ul>
    </div>
  </section>

  <section>
    <h2 class="type-heading text-primary mb-1">About</h2>
    <div class="flex items-center justify-between gap-3 py-3">
      <span class="type-body text-primary">Version</span>
      <span class="type-body text-primary font-semibold">{{ app_version or "dev" }}</span>
    </div>
  </section>
</div>
