{#def variant="neutral", size="sm", extra="", title="" #}
{#
  Compact pill-shaped status indicator. Five variants cover the colors
  that recur across the landing-page row badges, the destroying detail
  page, and the accounts page. ``size="xs"`` is for inline-with-text
  callouts (the accounts "Signed out" tag); ``size="sm"`` is for badges
  that sit in their own slot.

  ``extra`` is for one-off layout shims (``ml-8`` on inline tags,
  ``gap-8`` when the badge contains its own spinner). ``title`` adds a
  native browser tooltip on hover.
#}
{% set _variants = {
  "neutral": "bg-fill-subtle text-primary",
  "success": "bg-success/15 text-success",
  "error":   "bg-important/15 text-important",
  "warn":    "bg-warning/15 text-warning",
  "info":    "bg-info/15 text-info",
} %}
<span class="inline-flex items-center px-8 py-2 rounded-md text-{{ size }} font-medium {{ _variants[variant] }} {{ extra }}"
      {% if title %}title="{{ title }}"{% endif %}>{{ content }}</span>
