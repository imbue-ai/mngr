{#def variant="neutral", size="sm", extra="", title="" #}
{#
  Compact pill-shaped status indicator. Five variants cover the colors
  that recur across the landing-page row badges, the destroying detail
  page, and the accounts page. ``size="xs"`` is for inline-with-text
  callouts (the accounts "Signed out" tag); ``size="sm"`` is for badges
  that sit in their own slot.

  ``extra`` is for one-off layout shims (``ml-2`` on inline tags,
  ``gap-2`` when the badge contains its own spinner). ``title`` adds a
  native browser tooltip on hover.
#}
{% set _variants = {
  "neutral": "bg-zinc-100 text-primary",
  "success": "bg-emerald-100 text-emerald-800",
  "error":   "bg-red-100 text-red-800",
  "warn":    "bg-amber-100 text-amber-800",
  "info":    "bg-blue-100 text-blue-800",
} %}
<span class="inline-flex items-center px-2 py-0.5 rounded-md text-{{ size }} font-medium {{ _variants[variant] }} {{ extra }}"
      {% if title %}title="{{ title }}"{% endif %}>{{ content }}</span>
