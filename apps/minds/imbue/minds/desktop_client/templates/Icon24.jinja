{#def name, size="md", extra="" #}
{#
  24x24 stroke-based lucide-style icon. ``name`` picks from the
  ``ICONS_24`` catalog global in templates.py. Sizes are sm (w-3.5),
  md (w-4, default), or lg (w-5). The icon inherits color from the
  parent via ``currentColor``; set the parent's ``text-*`` class to
  recolor.

  Usage:
    <Icon24 name="home" />
    <Icon24 name="settings" size="sm" />
    <Icon24 name="external" extra="text-blue-600" />

  Brand marks (Google / GitHub) and 20x20 filled icons (the dialog
  close X, the Latchkey check) live in their own components or stay
  inline because they don't share the stroke shell.
#}
{%- set _size_cls = {"sm": "w-3.5 h-3.5", "md": "w-4 h-4", "lg": "w-5 h-5"}[size] -%}
<svg class="{{ _size_cls }} {{ extra }}" viewBox="0 0 24 24"
     fill="none" stroke="currentColor" stroke-width="2"
     stroke-linecap="round" stroke-linejoin="round"
     aria-hidden="true">{{ ICONS_24[name] | safe }}</svg>
