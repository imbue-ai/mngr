{#def title="Minds", is_mac=None, is_authenticated=False, mngr_forward_origin=None, is_agent_content_surface=False, accent="", body_class="", body_style="", head="", scripts="" #}
{#
  Shared trusted app shell: the fixed breadcrumb titlebar + browser-mode floating
  workspace switcher + accent / chrome.js wiring, wrapping a page body passed in
  the content slot.

  This is the trusted app chrome. Two modes:

  - Local page (default, ``is_agent_content_surface=False``): a trusted
    local/native page (Landing, Create, Settings, ...) renders its own body in
    the slot. The body is pushed below the fixed titlebar (``pt-[38px]``) and
    scrolls normally; the surface is the neutral page background.
  - Agent content surface (``is_agent_content_surface=True``): pages.Chrome
    fills the slot with the content iframe (the browser-mode agent surface). The
    document is locked to the viewport (``overflow: hidden``) and the body
    background tracks ``--titlebar-bg`` so an active workspace accent bleeds
    through the content surface's rounded corners.

  ``accent`` is an optional ``#rrggbb`` workspace accent rendered SERVER-SIDE
  (the ``--titlebar-bg`` variable plus the ``titlebar-surface`` self-theming
  scope) so a workspace-scoped page's first paint already carries the right
  titlebar color -- no neutral-then-accent pop-in while chrome.js waits for the
  SSE color cache. chrome.js repaints live changes on top exactly as before.

  ``is_mac`` (traffic-light spacer + hidden window controls) and
  ``mngr_forward_origin`` (the body data attribute chrome.js reads to build
  ``/goto/<agent>/`` links) default to the live-request catalog globals so a
  trusted page need not thread them through its render function; pages.Chrome
  passes them explicitly. In Electron mode the browser-mode switcher block is
  hidden via JS; the content is a separate WebContentsView and window.minds
  exposes IPC adapters. ``head`` / ``scripts`` let a page append its own head
  tags / script tags after the shell's own (workspace_accent.js,
  backup_health.js, sidebar_workspace_row.js, chrome.js).
#}
{% set _is_mac = is_mac if is_mac is not none else chrome_is_mac() %}
{% set _mngr_forward_origin = mngr_forward_origin if mngr_forward_origin is not none else chrome_mngr_forward_origin() %}
{% if is_agent_content_surface %}
  {% set _body_class = body_class if body_class else "font-sans antialiased" %}
  {% set _body_style = body_style if body_style else "background-color: var(--titlebar-bg, var(--c-surface-primary));" %}
{% else %}
  {# Local pages: neutral page surface, and the body content sits below the
     fixed 38px titlebar (which is out of flow). pt-[38px] pairs with a page's
     own ``min-h-[calc(100dvh_-_38px)]`` centering so the centered content lands
     in the region below the titlebar rather than behind it. #}
  {% set _body_class = (body_class if body_class else "bg-surface-primary text-primary font-sans antialiased") ~ " pt-[38px]" %}
  {% set _body_style = body_style %}
{% endif %}
{% if accent %}
  {# Server-side accent: seed --titlebar-bg on the body so the titlebar's very
     first paint is workspace-tinted. chrome.js takes over live updates. #}
  {% set _body_style = _body_style ~ " --titlebar-bg: " ~ accent ~ ";" %}
{% endif %}
{# The agent content surface (pages.Chrome) is edge-to-edge, so it opts out of
   the global stable scrollbar gutter; scrolling local pages keep the gutter to
   avoid a sideways layout shift when a classic scrollbar appears. #}
{% set _html_class = "no-scrollbar-gutter" if is_agent_content_surface else "" %}
{% set _head %}
<style>
  /* Things that can't easily be expressed as Tailwind utilities. */
{%- if is_agent_content_surface %}
  html, body { height: 100%; overflow: hidden; }
{%- endif %}
  #minds-titlebar { -webkit-app-region: drag; }
  #minds-titlebar button { -webkit-app-region: no-drag; }
  /* When the inbox modal (or any modal hosted in the main process's
     modalView) is open, drop the titlebar's app-region: drag. macOS
     unions drag regions across all views in a window, so without this
     the titlebar's drag swallows clicks intended for the modal's
     interior in the y=0..TITLEBAR strip. The main process sends
     `modal-state-changed` over IPC and chrome.js toggles the
     ``modal-open`` body class accordingly. */
  body.modal-open #minds-titlebar { -webkit-app-region: no-drag; }
</style>
{%- if head %}
{{ head }}
{%- endif %}
{% endset %}
{% set _body_attrs %}data-is-mac="{{ 'true' if _is_mac else 'false' }}" data-is-authenticated="{{ 'true' if is_authenticated else 'false' }}" data-mngr-forward-origin="{{ _mngr_forward_origin }}"{% endset %}
{% set _scripts %}
<script src="/_static/workspace_accent.js" defer></script>
<script src="/_static/backup_health.js" defer></script>
<script src="/_static/sidebar_workspace_row.js" defer></script>
<script src="/_static/chrome.js" defer></script>
{%- if scripts %}
{{ scripts }}
{%- endif %}
{% endset %}
<Base :title="title"
      :html_class="_html_class"
      :body_class="_body_class"
      :body_style="_body_style"
      head={{ _head }}
      body_attrs={{ _body_attrs }}
      scripts={{ _scripts }}>
  {# Two flex sections: a growing left cluster (breadcrumb + workspace
     icon-tabs) and a right cluster (requests inbox + bug report + non-mac
     window controls). There is no centered page title -- the breadcrumb
     names the context. macOS reserves the traffic-light strip with a fixed
     ``shrink-0`` spacer div. Non-mac draws its own min/max/close at the right.

     Left-cluster anatomy (chrome.js drives visibility per content URL):
       #back-btn      contextual back arrow, shown only on pages that opt in
                      (e.g. the create form) -- plain history back.
       #home-btn      "(icon) Minds"; navigates Home. Visible everywhere
                      except the welcome splash, where the user must pick an
                      account option before there is anywhere else to go.
       #ws-crumb      "/ workspace-name (chevron)" + the two icon-tabs
                      (Workspace, Workspace Settings), shown on
                      workspace-scoped screens. The name button
                      (#workspace-switcher-btn) opens the workspace switcher
                      menu anchored beneath itself.
       #requests-toggle  right-cluster inbox button (always visible) with a
                      pending-request count badge; opens the inbox popup.
       #page-crumb    "/ page-name" for non-workspace full pages (create,
                      browser-mode settings/accounts/auth fallbacks). #}
  <div id="minds-titlebar"
       style="background-color: var(--titlebar-bg, var(--c-surface-primary));"
       class="{% if accent %}titlebar-surface {% endif %}fixed top-0 left-0 right-0 h-[38px] flex items-center select-none z-[100] px-1">
    <div class="flex-1 flex items-center gap-0.5 min-w-0">
      {% if _is_mac %}<div class="w-[72px] shrink-0" aria-hidden="true"></div>{% endif %}
      {# Visibility below is driven through the native ``hidden`` attribute
         (display:none !important), never a ``hidden`` class: these elements
         carry ``flex`` / ``inline-flex`` display classes that would beat a
         ``.hidden`` utility in the cascade (see Badge.jinja's note). #}
      <TitlebarButton id="back-btn" aria-label="Back" data-tooltip="Back" hidden><Icon16 name="chevron-left" /></TitlebarButton>
      <TitlebarButton id="home-btn" aria-label="Home" data-tooltip="Home" extra="gap-1.5 pr-2">
        <Icon16 name="home" />
        <span class="type-label">Minds</span>
      </TitlebarButton>
      <div id="ws-crumb" class="flex items-center gap-0.5 min-w-0" hidden>
        <span class="type-label text-tertiary px-0.5" aria-hidden="true">/</span>
        <TitlebarButton id="workspace-switcher-btn" aria-label="Switch workspace" data-tooltip="Switch workspace" extra="gap-1 min-w-0">
          <span id="workspace-switcher-name" class="type-label truncate max-w-[180px]"></span>
          <Icon16 name="chevron-down-small" extra="shrink-0" />
        </TitlebarButton>
        <span class="type-label text-tertiary px-0.5" aria-hidden="true">/</span>
        <TitlebarButton id="ws-tab-workspace" aria-label="Workspace" data-tooltip="Workspace"><Icon16 name="panels-top-left" /></TitlebarButton>
        <TitlebarButton id="ws-tab-settings" aria-label="Workspace Settings" data-tooltip="Workspace Settings"><Icon16 name="settings" /></TitlebarButton>
      </div>
      <div id="page-crumb" class="flex items-center gap-0.5 min-w-0" hidden>
        <span class="type-label text-tertiary px-0.5" aria-hidden="true">/</span>
        <span id="page-crumb-name" class="type-label text-primary truncate max-w-[240px] px-1"></span>
      </div>
    </div>
    <div class="flex items-center justify-end shrink-0">
      <TitlebarButton id="requests-toggle" aria-label="Requests" data-tooltip="Requests" extra="gap-[3px]">
        <Icon16 name="inbox" />
        <Badge :count="0" id="requests-badge" hidden />
      </TitlebarButton>
      <TitlebarButton id="help-toggle" aria-label="Report a bug" data-tooltip="Report a bug"><Icon16 name="bug" /></TitlebarButton>
      <div class="flex {% if _is_mac %}hidden{% endif %}">
        <TitlebarButton variant="control" id="min-btn" aria-label="Minimize" data-tooltip="Minimize"><Icon12 name="minimize" /></TitlebarButton>
        <TitlebarButton variant="control" id="max-btn" aria-label="Maximize" data-tooltip="Maximize"><Icon12 name="maximize" /></TitlebarButton>
        <TitlebarButton variant="control" tone="danger" id="close-btn" aria-label="Close" data-tooltip="Close"><Icon12 name="close" /></TitlebarButton>
      </div>
    </div>
  </div>

  {# Browser-mode floating workspace-switcher menu: full-screen transparent
     backdrop (#sidebar-backdrop) with a floating dark menu (#sidebar-menu)
     positioned at toggle time by chrome.js using the workspace-switcher
     button's getBoundingClientRect + a caller-chosen offset. Clicks on
     the backdrop and Escape close the menu (handled by chrome.js). In
     Electron this whole block is hidden via JS; the switcher page
     (Sidebar.jinja) is loaded into the shared modal WebContentsView and
     uses the same #sidebar-backdrop / #sidebar-menu shape with the
     /_static/sidebar.js renderer. Both modes share the position model:
     menu.top-left = trigger.bottom-left + offset, with a uniform 4px panel
     pad (p-1) and 2px between entries (gap-0.5); each row adds its own
     px-2 for the hover highlight's inset. #}
  <div id="sidebar-backdrop" class="fixed inset-0 z-50 hidden">
    <div id="sidebar-menu"
         class="dark absolute w-[280px] flex flex-col gap-0.5 p-1 rounded-lg border border-subtle bg-surface-primary shadow-overlay overflow-hidden">
      <div id="sidebar-workspaces" class="flex flex-col gap-0.5"></div>
      <SidebarBottom />
    </div>
  </div>

  {{ content }}
</Base>
