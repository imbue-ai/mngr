{#def variant="nav", tone="default", extra="" #}
{#
  Title-bar window-control button. Distinct from the general-purpose
  Button primitive only in geometry (window-control sizing); its colors
  are plain design tokens (``text-secondary`` + ``hover:text-primary`` +
  ``hover:bg-fill-hover`` + ``active:bg-fill-active``).

  Those tokens are re-based per-workspace by the ``.titlebar-surface`` scope
  in app.css, which derives a black/white contrast from ``--titlebar-bg`` in
  pure CSS -- so the same button reads correctly on any workspace color and on
  the neutral chrome, with no per-element foreground variable.

  Props:
    variant
      "nav"     -- left-side icon hits (sidebar / home / back / forward /
                   requests). ``w-8 h-7`` with a slight rounded corner.
      "control" -- right-side native window controls (min / max / close)
                   on platforms where minds draws its own frame.
                   ``w-9 h-[38px]``, square corners (matches the OS).
    tone
      "default" -- accent-aware hover via ``.titlebar-btn``.
      "danger"  -- close-button-only red hover regardless of accent
                   (``.titlebar-btn-danger``); use on the close control
                   to mirror native Windows / Linux behavior.

  Any HTML attribute on the tag that is not declared above (id=, title=,
  aria-*, data-*) flows through via JinjaX's ``attrs`` passthrough.
#}
{%- set _variants = {
  "nav": "w-8 h-7 rounded-md",
  "control": "w-9 h-[38px] rounded-none",
} -%}
{%- set _tones = {
  "default": "",
  "danger": "titlebar-btn-danger",
} -%}
{%- set _btn_base = "inline-flex items-center justify-center cursor-pointer transition-colors text-secondary hover:text-primary hover:bg-fill-hover active:bg-fill-active" -%}
{%- set _cls = _btn_base ~ " " ~ _variants[variant] ~ " " ~ _tones[tone] ~ " " ~ extra -%}
<button {{ attrs.render(type="button", classes=_cls) }}>{{ content }}</button>
