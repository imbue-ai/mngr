{#def variant="info", extra="" #}
{#
  Info / warn / success / error notice box. Usage:
    <Notice variant="warn">Careful: something may need attention.</Notice>
#}
{% set _notice_variants = {
  "info":    "bg-blue-50 text-blue-900 border border-blue-100",
  "warn":    "bg-amber-50 text-amber-900 border border-amber-200",
  "success": "bg-emerald-50 text-emerald-700 border border-emerald-200",
  "error":   "bg-red-50 text-red-600 border border-red-200",
} %}
<div class="px-3 py-2.5 rounded-md text-sm my-2 {{ _notice_variants[variant] }} {{ extra }}">
  {{ content }}
</div>
