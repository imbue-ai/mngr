{#def variant="info" #}
{#
  Info / warn / success / error notice box. Usage:
    <Notice variant="warn">Careful: something may need attention.</Notice>

  Any HTML attribute on the tag that is not declared above (id=,
  class=, hidden, data-*) flows through via JinjaX's ``attrs``
  passthrough. ``class="..."`` is appended to the component's
  canonical class set; pass ``class="hidden"`` to start the notice
  collapsed (the auth pages toggle this via classList.add/remove).
#}
{% set _notice_variants = {
  "info":    "bg-info/12 text-info border border-info/30",
  "warn":    "bg-warning/12 text-warning border border-warning/30",
  "success": "bg-success/12 text-success border border-success/30",
  "error":   "bg-important/12 text-important border border-important/30",
} %}
{% set _cls = "px-3 py-2 rounded-md type-body my-2" ~ _notice_variants[variant] %}
<div {{ attrs.render(classes=_cls) }}>
  {{ content }}
</div>
