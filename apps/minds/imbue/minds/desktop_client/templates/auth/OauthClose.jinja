{#def boot_state #}
{#
  Terminal page for the OAuth popup window (mithril OauthClose surface): shows
  the signed-in identity and instructs the user to close the tab. The opening
  tab continues the flow via its own status poll.
#}
{% set _scripts %}
<script>
  window.MindsUI.mountOauthClose(document.getElementById('oauth-close-root'));
</script>
{% endset %}
<PageNarrowContainer title="Signed in" :boot_state="boot_state" scripts={{ _scripts }}>
  <div id="oauth-close-root"></div>
</PageNarrowContainer>
