{#def boot_state #}
{#
  Forgot-password page. The body is the mithril ForgotPassword surface
  (frontend/src/views/AuthPages.ts): an email field that POSTs
  /auth/api/forgot-password and shows the server's generic success message
  inline (which never leaks whether the address exists).
#}
{% set _scripts %}
<script>
  window.MindsUI.mountForgotPassword(document.getElementById('forgot-password-root'));
</script>
{% endset %}
<PageNarrowContainer title="Forgot password" :boot_state="boot_state" scripts={{ _scripts }}>
  <div id="forgot-password-root"></div>
</PageNarrowContainer>
