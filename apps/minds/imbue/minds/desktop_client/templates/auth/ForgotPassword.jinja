{#def #}
{#
  Forgot-password page. Email field + POST to /auth/api/forgot-password.
  Shows success message inline (server returns a generic "if the address
  exists, a reset email has been sent" body to avoid leaking account
  existence).
#}
{% set _scripts %}
<script>
  document.getElementById('forgot-form').addEventListener('submit', async function (e) {
    e.preventDefault();
    var btn = document.getElementById('submit-btn');
    btn.disabled = true;
    document.getElementById('error-msg').classList.add('hidden');
    try {
      var res = await fetch('/auth/api/forgot-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: document.getElementById('email').value }),
      });
      var data = await res.json();
      var s = document.getElementById('success-msg');
      s.textContent = data.message;
      s.classList.remove('hidden');
    } catch (err) {
      var el = document.getElementById('error-msg');
      el.textContent = 'Network error';
      el.classList.remove('hidden');
    }
    btn.disabled = false;
  });
</script>
{% endset %}
<auth.AuthBase title="Forgot password" scripts={{ _scripts }}>
  <h1 class="text-2xl font-semibold text-zinc-900 mb-2">Reset password</h1>
  <p class="text-zinc-500 mb-6">Enter your email to receive a reset link</p>
  <Notice variant="error" id="error-msg" class="hidden"></Notice>
  <Notice variant="success" id="success-msg" class="hidden"></Notice>
  <form id="forgot-form">
    <div class="mb-4">
      <label for="email" class="block text-sm font-medium text-zinc-900 mb-1.5">Email</label>
      <TextInput type="email" name="email" id="email" required radius="lg" autocomplete="email" />
    </div>
    <ButtonSubmit variant="primary" size="lg" block id="submit-btn">Send reset link</ButtonSubmit>
  </form>
  <div class="text-center mt-5 text-sm text-zinc-500"><a href="/auth/login" class="text-blue-600 font-medium hover:underline">Back to sign in</a></div>
</auth.AuthBase>
