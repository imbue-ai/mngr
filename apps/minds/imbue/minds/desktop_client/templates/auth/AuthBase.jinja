{#def title, card_extra="max-w-[420px]", scripts="" #}
{#
  Auth-card layout variant of the Base component. Center-aligned card on a
  light page, fixed max width by default. Used by the auth subpages.
  Forwards the ``scripts`` arg through to Base so subpages can emit
  page-specific JS right before </body>.
#}
<Base title={{ title }}
      body_class="bg-zinc-50 text-zinc-900 font-sans antialiased flex items-center justify-center min-h-screen p-5"
      scripts={{ scripts }}>
  <div class="bg-white border border-zinc-200 rounded-xl shadow-sm p-10 {{ card_extra }} w-full">
    {{ content }}
  </div>
</Base>
