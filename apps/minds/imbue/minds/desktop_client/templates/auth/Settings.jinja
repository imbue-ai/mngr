{#def boot_state #}
{#
  Account settings page. The body is the mithril AccountSettings surface
  (frontend/src/views/AuthPages.ts), mounted from the ``account_settings``
  island: a read-only view of the signed-in identity plus Change password
  (email accounts) and Sign out. The per-machine error-reporting toggles live
  on the app-level /settings page, not here.
#}
{% set _scripts %}
<script>
  window.MindsUI.mountAccountSettings(document.getElementById('account-settings-root'));
</script>
{% endset %}
<PageNarrowContainer title="Account settings" max_width="max-w-[480px]" :boot_state="boot_state" scripts={{ _scripts }}>
  <div id="account-settings-root"></div>
</PageNarrowContainer>
