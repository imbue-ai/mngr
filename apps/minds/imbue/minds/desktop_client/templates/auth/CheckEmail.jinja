{#def boot_state #}
{#
  Verify-your-email page. The body is the mithril CheckEmail surface
  (frontend/src/views/AuthPages.ts), mounted from the ``check_email`` island:
  it polls /auth/api/email-verified, flips to the success state and redirects
  through /post-login on verification, and drives the resend button.
#}
{% set _scripts %}
<script>
  window.MindsUI.mountCheckEmail(document.getElementById('check-email-root'));
</script>
{% endset %}
<PageNarrowContainer title="Check your email" :boot_state="boot_state" scripts={{ _scripts }}>
  <div id="check-email-root"></div>
</PageNarrowContainer>
