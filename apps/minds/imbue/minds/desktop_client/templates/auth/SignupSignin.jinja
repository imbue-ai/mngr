{#def title, message, default_to_signup #}
{#
  Two-tab signup/signin page. ``default_to_signup`` picks which tab is
  visible on first paint; the inline links flip between them client-side
  without a navigation. OAuth (Google / GitHub) sits in a "or" divider
  below the form on each tab.
#}
{% set _scripts %}
<script src="/_static/auth.js" defer></script>
{% endset %}
<CardPage :title="title" scripts={{ _scripts }}>
  {% if message %}
    <Notice variant="info">{{ message }}</Notice>
  {% endif %}

  <div id="signup-tab" class="{% if not default_to_signup %}hidden{% endif %}">
    <h1 class="text-2xl font-semibold text-zinc-900 mb-2">Create account</h1>
    <p class="text-zinc-500 mb-6">Sign up to enable sharing</p>
    <Notice variant="error" id="signup-error" class="hidden"></Notice>
    <form id="signup-form">
      <div class="mb-4">
        <FormLabel target="signup-email">Email</FormLabel>
        <TextInput type="email" name="email" id="signup-email" required radius="lg" autocomplete="email" />
      </div>
      <div class="mb-4">
        <FormLabel target="signup-password">Password</FormLabel>
        <TextInput type="password" name="password" id="signup-password" required radius="lg" autocomplete="new-password" minlength={{ 8 }} />
      </div>
      <ButtonSubmit variant="primary" size="lg" block id="signup-btn">Create account</ButtonSubmit>
    </form>
    <div class="flex items-center my-5 text-zinc-400 text-xs">
      <span class="flex-1 border-b border-zinc-200"></span>
      <span class="px-3">or</span>
      <span class="flex-1 border-b border-zinc-200"></span>
    </div>
    <auth.OauthButton provider="google" extra="mb-2" />
    <auth.OauthButton provider="github" />
    <div class="text-center mt-5 text-sm text-zinc-500">
      Already have an account? <Link href="#" weight="medium" data-show-tab="signin">Sign in</Link>
    </div>
  </div>

  <div id="signin-tab" class="{% if default_to_signup %}hidden{% endif %}">
    <h1 class="text-2xl font-semibold text-zinc-900 mb-2">Sign in</h1>
    <p class="text-zinc-500 mb-6">Sign in to your Imbue account</p>
    <Notice variant="error" id="signin-error" class="hidden"></Notice>
    <form id="signin-form">
      <div class="mb-4">
        <FormLabel target="signin-email">Email</FormLabel>
        <TextInput type="email" name="email" id="signin-email" required radius="lg" autocomplete="email" />
      </div>
      <div class="mb-4">
        <FormLabel target="signin-password">Password</FormLabel>
        <TextInput type="password" name="password" id="signin-password" required radius="lg" autocomplete="current-password" />
      </div>
      <div class="text-right -mt-2 mb-4"><Link href="/auth/forgot-password" extra="text-xs">Forgot password?</Link></div>
      <ButtonSubmit variant="primary" size="lg" block id="signin-btn">Sign in</ButtonSubmit>
    </form>
    <div class="flex items-center my-5 text-zinc-400 text-xs">
      <span class="flex-1 border-b border-zinc-200"></span>
      <span class="px-3">or</span>
      <span class="flex-1 border-b border-zinc-200"></span>
    </div>
    <auth.OauthButton provider="google" extra="mb-2" />
    <auth.OauthButton provider="github" />
    <div class="text-center mt-5 text-sm text-zinc-500">
      Don't have an account? <Link href="#" weight="medium" data-show-tab="signup">Create one</Link>
    </div>
  </div>
</CardPage>
