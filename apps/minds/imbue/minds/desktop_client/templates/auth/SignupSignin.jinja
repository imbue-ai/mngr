{#def title, boot_state #}
{#
  Standalone sign-up / sign-in page. The whole body is the mithril AuthForm
  surface (frontend/src/views/AuthPages.ts), mounted from the ``auth`` island
  slice: the two-tab email/password form, the OAuth (Google / GitHub) flow,
  the optional back link + info banner, and the post-auth navigation. The
  centered sign-in modal mounts the same AuthForm from its own island.
#}
{% set _scripts %}
<script>
  window.MindsUI.mountAuthPage(document.getElementById('auth-root'));
</script>
{% endset %}
<PageNarrowContainer :title="title" :boot_state="boot_state" scripts={{ _scripts }}>
  <div id="auth-root"></div>
</PageNarrowContainer>
