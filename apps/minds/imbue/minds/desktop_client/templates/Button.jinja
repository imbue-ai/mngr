{#def variant="secondary", extra="", id="", onclick="", block=false #}
{#
  Plain <button type="button">. Use for in-page actions (modal triggers,
  toggles, AJAX-style buttons). Usage:
    <Button variant="secondary" onclick="copyUrl()">Copy</Button>

  Pulls its base class string and variants map from the Catalog globals
  ``BTN_BASE`` / ``BTN_VARIANTS`` (defined in templates.py) so the three
  button components stay in lockstep without duplicating those values.
#}
<button type="button"
        class="{{ BTN_BASE }} {{ BTN_VARIANTS[variant] }} {% if block %}w-full{% endif %} {{ extra }}"
        {% if id %}id="{{ id }}"{% endif %}
        {% if onclick %}onclick="{{ onclick }}"{% endif %}>{{ content }}</button>
