{#def agent_id, ws_name #}
{#
  Full backup history page for one workspace, reached from the workspace
  settings page's "View all N backups" footer.

  The table is fed one page at a time from
  GET /api/v1/workspaces/<id>/backups/snapshots?offset=&limit= (newest-first,
  paginated server-side so a long history is never loaded all at once).
  workspace_backup_history.js owns the row markup, the empty / error states,
  and the Newer/Older pagination controls; only the shells live here.
#}
{% set _scripts %}
<script src="/_static/workspace_backup_history.js" defer></script>
{% endset %}
<Base title={{ "Backups: " ~ ws_name }}
      body_class="bg-surface-primary text-primary font-sans antialiased"
      scripts={{ _scripts }}>
  <PageContainer>
    <div id="backup-history-page" data-agent-id="{{ agent_id }}">
      <h1 class="type-heading text-primary">Backup history</h1>
      <p class="type-helper text-tertiary mb-6">
        Every backup of <span class="font-semibold">{{ ws_name }}</span>, newest first.
        <Link href={{ "/workspace/" ~ agent_id ~ "/settings" }}>Back to settings</Link>
      </p>

      <p id="history-status" class="type-body text-secondary mb-4">Loading backup history...</p>

      <div id="history-card" class="minds-card hidden overflow-hidden mb-4 p-0">
        <div id="history-rows"></div>
      </div>

      {# Pagination footer: JS fills the range text and drives the buttons;
         hidden entirely when everything fits on one page. #}
      <div id="history-pagination" class="hidden flex items-center justify-between">
        <span id="history-range" class="type-body text-secondary"></span>
        <div class="flex items-center gap-2">
          <Button variant="secondary" id="history-prev-btn">&larr; Newer</Button>
          <Button variant="secondary" id="history-next-btn">Older &rarr;</Button>
        </div>
      </div>
    </div>
  </PageContainer>
</Base>
