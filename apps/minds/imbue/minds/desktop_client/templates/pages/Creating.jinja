{#def boot_state #}
{#
  Progress page shown while an agent is being created. The whole body is the
  mithril CreatingPage component (frontend/src/views/CreatingPage.ts),
  mounted from the ``#minds-boot-state`` island this shell seeds (the
  ``creating`` slice: creation id, initial status caption, expected
  duration). The page is keyed by creation_id (a minds-internal in-flight
  handle) rather than the canonical agent_id, because the canonical id only
  comes into existence once the inner mngr create returns. The component
  polls the create operation for status (progress bar + failure view) and
  streams its logs over SSE; on completion it hands the /goto/<agent>/ URL
  to the host (content view in Electron, full-page navigation in browser).
#}
{% set _scripts %}
<script>
  window.MindsUI.mountCreating(document.getElementById('creating-root'));
</script>
{% endset %}
<ChromeShell title="Creating your workspace..."
      page_label="New workspace"
      body_class="bg-surface-primary text-primary font-sans antialiased flex items-center justify-center min-h-screen p-6"
      :boot_state="boot_state"
      scripts={{ _scripts }}>
  <main id="creating-root" class="w-full"></main>
</ChromeShell>
