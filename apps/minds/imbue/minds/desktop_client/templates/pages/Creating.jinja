{#def agent_id, status_text, expected_duration_seconds, palette, onboarding_services, is_remote #}
{#
  Progress page shown while an agent is being created. The page is keyed
  by creation_id (passed as agent_id here -- a minds-internal in-flight
  handle) rather than the canonical agent_id, because the canonical id
  only comes into existence once the inner mngr create returns.
  expected_duration_seconds drives the client-side time-based progress
  bar (eases toward ~80% over this duration).

  Layout: the screen is a nine-micro-step onboarding walkthrough (see
  onboarding.js), one short sentence per step, over a shared scene graphic
  that zooms out as the steps advance. The progress strip (bar + stage
  caption + collapsible logs) and any creation failure stay hidden until
  the user reaches the LAST step -- only there do the bar, the rotating
  tips, and the setting-up/Ready state surface. When creation finishes AND
  the user is on the last step, a Begin button replaces Next and enters
  the workspace (there is no automatic redirect). Clicking any scene icon
  jumps to the first step that explains it.

  palette is the server-side workspace color mapping (name -> #rrggbb) for
  the theme-demo step; the pick only restyles the in-page demo, it is not
  persisted to the workspace. onboarding_services is the carousel list
  (OnboardingService rows). is_remote picks the final-step copy: whether
  the workspace machine is a remote cloud host or this computer.
#}
{% set _scripts %}
<script src="/_static/creating.js" defer></script>
<script src="/_static/onboarding.js" defer></script>
{% endset %}
<Base title="Creating your workspace..."
      body_class="bg-surface-primary text-primary font-sans antialiased min-h-screen"
      scripts={{ _scripts }}>
  <main id="creating"
        class="w-full min-h-screen flex flex-col"
        data-agent-id="{{ agent_id }}"
        data-expected-duration-seconds="{{ expected_duration_seconds }}"
        data-is-remote="{{ 'true' if is_remote else 'false' }}">

    {# Loading screen. Holds the pinned top progress strip plus two mutually #}
    {# exclusive sub-views: the onboarding walkthrough (in-flight) and the #}
    {# failure view. The logs live in the top strip so they stay in one #}
    {# place regardless of which sub-view is showing. #}
    <section class="screen w-full flex-1 flex flex-col" data-screen="loading">

      {# Top strip: progress bar + stage caption + collapsible logs. #}
      {# Hidden until the user reaches the last walkthrough step -- #}
      {# onboarding.js reveals it there (see the page docstring). #}
      <div id="top-strip" class="w-full px-6 pt-4 hidden">
        <div class="h-1.5 bg-fill-subtle rounded-full overflow-hidden">
          <div id="bar-fill" class="h-full w-0 rounded-full bg-accent transition-[width] duration-300 ease-out"></div>
        </div>
        <div class="flex items-center justify-between mt-2 type-helper text-tertiary">
          <span id="stage">{{ status_text }}</span>
          <button type="button" id="details-toggle"
                  class="js-details inline-flex items-center gap-1 text-tertiary hover:text-primary cursor-pointer">
            Show details
          </button>
        </div>
        <div id="logs"
             class="dark hidden mt-3 p-3 bg-surface-primary text-secondary font-mono type-helper rounded-lg max-h-[200px] overflow-y-auto whitespace-pre-wrap border border-subtle"></div>
      </div>

      {# Onboarding walkthrough sub-view: shown while creation is in flight #}
      {# (and after it finishes, until the user clicks Begin). Hidden by #}
      {# creating.js if creation fails. Step visibility/transitions are #}
      {# driven by the step-1/2/3 class on #onboarding (see app.css). #}
      <div id="progress-view" class="flex-1 flex flex-col min-h-0">
        <div id="onboarding" class="onboarding step-1 flex-1 flex flex-col items-center justify-center w-full max-w-3xl mx-auto px-6 py-4 gap-6">

          {# Shared scene: the four graphic nodes. Steps reveal them #}
          {# progressively (laptop -> +key -> +tunnel+server) with a #}
          {# zoom-out feel via CSS scale/width transitions. #}
          <div id="scene" class="flex items-end justify-center gap-2 w-full select-none">
            <div id="scene-computer" class="scene-group flex flex-col items-center gap-2">
              <div class="scene-label type-helper text-tertiary">Your computer, your credentials</div>
              <div class="flex items-end gap-3 rounded-xl border border-subtle bg-fill-subtle px-4 py-4">
                <div id="scene-laptop" class="scene-node flex flex-col items-center gap-1 cursor-pointer" data-goto-step="1" title="What is minds?">
                  {# Imbue minds icon (simplified from electron/assets/icon.svg, grain filters dropped). #}
                  <svg viewBox="0 0 1024 1024" class="w-28 h-28 rounded-xl" aria-label="minds">
                    <rect width="1024" height="1024" rx="200" fill="#492222"/>
                    <path d="M239.393 346.233C213.333 388.701 181.957 578.826 170.21 692.964C168.726 707.387 179.615 719.956 194.083 720.906L243.5 724.15C254.832 724.894 264.36 732.926 267.01 743.968L287.114 827.735C289.477 837.581 297.325 845.189 307.312 846.857C387.978 860.334 533.31 868.318 620.93 820.192C992.068 616.341 865.659 254.427 642.258 194.566C418.857 134.706 303.377 241.962 239.393 346.233Z" fill="#E9ECD9"/>
                    <path d="M719.991 411.97C744.539 411.97 762.39 420.422 774.234 434.21C786.236 448.181 792.898 468.606 792.898 493.876C792.898 542.499 753.481 581.916 704.858 581.916C656.236 581.916 616.819 542.499 616.819 493.876C616.819 470.597 629.516 450.292 649.247 435.491C669.022 420.657 695.154 411.97 719.991 411.97Z" stroke="#492222" stroke-width="17.28" fill="none"/>
                    <path d="M583.295 282.074C621.147 282.074 649.061 294.27 667.574 314.33C686.184 334.495 696.216 363.607 696.216 399.073C696.216 467.817 636.155 524.583 560.738 524.583C485.322 524.583 425.26 467.817 425.26 399.073C425.26 365.723 444.83 336.66 475.056 315.555C505.279 294.451 545.21 282.074 583.295 282.074Z" stroke="#492222" stroke-width="17.28" fill="none"/>
                    <path d="M727.416 125.17C765.268 125.17 793.181 137.366 811.695 157.426C830.305 177.591 840.336 206.703 840.336 242.169C840.336 310.913 780.275 367.679 704.859 367.679C629.442 367.679 569.38 310.913 569.38 242.169C569.38 208.819 588.951 179.756 619.176 158.651C649.4 137.547 689.331 125.17 727.416 125.17Z" stroke="#E9ECD9" stroke-width="17.28" fill="none"/>
                  </svg>
                  <span class="type-helper text-tertiary">minds</span>
                </div>
                <div id="scene-key" class="scene-node flex flex-col items-center gap-1 cursor-pointer" data-goto-step="6" title="What is latchkey?">
                  {# Imbue latchkey logo, redrawn as SVG from the imbue.com #}
                  {# product-page mark (olive tile, pink vintage key + tag). #}
                  <svg viewBox="0 0 64 64" class="w-20 h-20 rounded-xl" aria-label="latchkey">
                    <rect width="64" height="64" rx="14" fill="#4b4c08"/>
                    <g fill="none" stroke="#e4999a" stroke-linecap="round">
                      {# bow (thick donut, right side) #}
                      <circle cx="40" cy="38" r="7.5" stroke-width="6.5"/>
                      {# stem pointing left, two teeth pointing down #}
                      <path d="M32 38 H 12 M15.5 38 v6.5 M22.5 38 v6" stroke-width="6"/>
                      {# tag ring + tag hanging up-right off the bow #}
                      <circle cx="46.5" cy="28" r="2.4" stroke-width="1.8"/>
                      <path d="M48.5 26 l3 -8 6.5 -1.5 3 5.5 -6 7 z" stroke-width="2.4" stroke-linejoin="round"/>
                    </g>
                  </svg>
                  <span class="type-helper text-tertiary">latchkey</span>
                </div>
              </div>
            </div>

            <div id="scene-tunnel" class="scene-node flex flex-col items-center gap-1 self-center mt-6 cursor-pointer" data-goto-step="8" title="What is the tunnel?">
              {# Tunnel: two gentle arcs with an encryption lock between them. #}
              <svg viewBox="0 0 120 48" class="w-40 h-16 text-tertiary" fill="none" stroke="currentColor" aria-label="encrypted tunnel">
                <path d="M4 14 C 40 5, 80 5, 116 14" stroke-width="3" stroke-linecap="round"/>
                <path d="M4 34 C 40 43, 80 43, 116 34" stroke-width="3" stroke-linecap="round"/>
                <rect x="51" y="21" width="18" height="14" rx="3" stroke-width="3"/>
                <path d="M55 21 v-3.5 a5 5 0 0 1 10 0 v3.5" stroke-width="3"/>
              </svg>
              <span class="type-helper text-tertiary">encrypted</span>
            </div>

            <div id="scene-workspace" class="scene-group flex flex-col items-center gap-2">
              <div class="scene-label type-helper text-tertiary text-center">
                {% if is_remote %}
                Workspace machine
                {% else %}
                Workspace
                <span class="block">(on this computer)</span>
                {% endif %}
              </div>
              <div class="rounded-xl border border-subtle bg-fill-subtle px-4 py-4">
                <div id="scene-server" class="scene-node flex flex-col items-center gap-1 cursor-pointer" data-goto-step="9" title="What is the workspace?">
                  {# Server with an AI sparkle, drawn as a brand-style tile #}
                  {# matching the minds / latchkey icons (palette colors: #}
                  {# confusion tile, peace glyph, comfort sparkle). The inner #}
                  {# fill rect scales with --create-progress so the machine #}
                  {# visually fills up in lockstep with the top progress bar. #}
                  <svg viewBox="0 0 64 64" class="w-20 h-20 rounded-xl" aria-label="workspace machine">
                    <defs>
                      <clipPath id="server-clip"><rect width="64" height="64" rx="14"/></clipPath>
                    </defs>
                    <rect width="64" height="64" rx="14" fill="#0b292b"/>
                    <g clip-path="url(#server-clip)">
                      <rect id="server-fill" width="64" height="64" fill="#9fbbd3" opacity="0.35" class="server-fill-rect"/>
                    </g>
                    <rect x="15" y="13" width="34" height="38" rx="5" fill="none" stroke="#9fbbd3" stroke-width="3.5"/>
                    <path d="M15 25.5 H 49 M 15 38 H 49" stroke="#9fbbd3" stroke-width="3"/>
                    <circle cx="21.5" cy="19" r="2" fill="#9fbbd3"/>
                    <circle cx="21.5" cy="31.75" r="2" fill="#9fbbd3"/>
                    <circle cx="21.5" cy="44.5" r="2" fill="#9fbbd3"/>
                    <path d="M47 5.5 l2.3 5.7 5.7 2.3 -5.7 2.3 -2.3 5.7 -2.3 -5.7 -5.7 -2.3 5.7 -2.3 z"
                          fill="#f5d6a0"/>
                  </svg>
                  <span id="server-caption" class="type-helper text-tertiary">setting up...</span>
                </div>
              </div>
            </div>
          </div>

          {# Micro-step text panels: one short sentence each (onboarding.js #}
          {# shows the one matching the current step). Steps 1-5 are the #}
          {# minds phase, 6-7 latchkey, 8-9 the full picture. #}
          <div class="onboarding-step text-center" data-step="1">
            <p class="type-body text-secondary max-w-xl">
              This is <b>minds</b>: your access terminal for an AI operating system.
            </p>
          </div>
          <div class="onboarding-step hidden text-center" data-step="2">
            <p class="type-body text-secondary max-w-xl">
              Your workspace runs in tabs. Chat with an agent in a Chat tab.
            </p>
          </div>
          <div class="onboarding-step hidden text-center" data-step="3">
            <p class="type-body text-secondary max-w-xl">
              Agents build and run apps for you. Those show up as tabs too.
            </p>
          </div>
          <div class="onboarding-step hidden text-center" data-step="4">
            <p class="type-body text-secondary max-w-xl">
              You can also browse the web, right alongside your agents.
            </p>
          </div>
          <div class="onboarding-step hidden text-center" data-step="5">
            <p class="type-body text-secondary max-w-xl">
              Pick a theme color for this workspace.
            </p>
          </div>
          <div class="onboarding-step hidden text-center" data-step="6">
            <p class="type-body text-secondary max-w-xl">
              This is <b>latchkey</b>: your credentials stay encrypted on your
              computer, never visible to agents.
            </p>
          </div>
          <div class="onboarding-step hidden text-center" data-step="7">
            <p class="type-body text-secondary max-w-xl">
              latchkey can connect your agents to the tools you already use.
            </p>
          </div>
          <div class="onboarding-step hidden text-center" data-step="8">
            <p class="type-body text-secondary max-w-xl">
              Your computer talks to your workspace over an encrypted tunnel.
            </p>
          </div>
          <div class="onboarding-step hidden text-center flex flex-col items-center gap-3" data-step="9">
            <p class="type-body text-secondary max-w-xl">
              Your workspace is where your agents run.
              {% if is_remote %}
              This one runs 24/7 in the cloud, even when your laptop is closed.
              {% else %}
              This one runs directly on your own computer.
              {% endif %}
            </p>
            {# Rotating tips while the user waits for the workspace to be #}
            {# ready (onboarding.js cycles them). #}
            <p id="tip" class="type-helper text-tertiary min-h-[18px] transition-opacity"></p>
          </div>

          {# Demo tab-space, shared by steps 2-5. NOT freely interactive: the #}
          {# Next button walks through the tabs (chat -> app -> web); only the #}
          {# theme swatches (step 5) take clicks. The accent follows the #}
          {# picked color (demo only; the real workspace color came from the #}
          {# create form). #}
          <div id="demo-wrap" class="hidden w-full flex flex-col items-center gap-3">
            <div id="theme-demo" class="w-full max-w-md rounded-xl overflow-hidden border border-subtle shadow-overlay text-left">
              <div id="demo-titlebar" class="flex items-center gap-1.5 px-3 pt-2" style="background-color: var(--demo-accent);">
                <div class="flex gap-1.5 pr-2 py-2">
                  <span class="demo-dot w-2.5 h-2.5 rounded-full"></span>
                  <span class="demo-dot w-2.5 h-2.5 rounded-full"></span>
                  <span class="demo-dot w-2.5 h-2.5 rounded-full"></span>
                </div>
                <span class="demo-tab demo-tab-active" data-tab="chat">Chat</span>
                <span class="demo-tab" data-tab="app">My app</span>
                <span class="demo-tab" data-tab="web">Web</span>
              </div>
              {# Fixed height so switching demo tabs never reflows the page. #}
              <div class="bg-surface-primary p-3 h-[120px] overflow-hidden">
                <div class="demo-pane" data-pane="chat">
                  <div class="demo-accent-bubble rounded-lg px-3 py-2 type-helper max-w-[85%] ml-auto mb-1.5" style="background-color: var(--demo-accent);">Build me a website for my bakery</div>
                  <div class="rounded-lg bg-surface-primary border border-subtle px-3 py-2 type-helper text-secondary max-w-[85%] mr-auto">On it! Starting with the menu page.</div>
                </div>
                <div class="demo-pane hidden" data-pane="app">
                  <div class="rounded-lg border border-subtle bg-surface-primary p-3">
                    <div class="h-2 rounded w-2/3 mb-2" style="background-color: var(--demo-accent);"></div>
                    <div class="h-2 rounded bg-fill-subtle w-full mb-1.5"></div>
                    <div class="h-2 rounded bg-fill-subtle w-5/6"></div>
                  </div>
                </div>
                <div class="demo-pane hidden" data-pane="web">
                  <div class="rounded-full border border-subtle bg-surface-primary px-3 py-1.5 type-helper text-tertiary">https://example.com</div>
                </div>
              </div>
            </div>
            {# Theme swatches: revealed on the pick-a-color step only. #}
            <div id="color-picker-wrap" class="hidden">
              <div id="onboarding-color-picker" role="radiogroup" aria-label="Theme color" class="flex items-center gap-2 flex-wrap justify-center">
                {% for name, hex_value in palette.items() %}
                  <ColorSwatch :hex="hex_value" :name="name" size="sm" :selected="loop.first" />
                {% endfor %}
              </div>
            </div>
          </div>

          {# Connectable-services carousel, shown on its own step. #}
          {% if onboarding_services %}
          <div id="carousel-wrap" class="hidden service-marquee w-full max-w-lg overflow-hidden" aria-label="Connectable services">
            <div class="service-marquee-track flex items-center gap-2 w-max">
              {% for _repeat in range(2) %}
                {% for service in onboarding_services %}
                  <span class="flex items-center gap-1.5 rounded-full border border-subtle bg-fill-subtle px-3 py-1.5 type-helper text-secondary whitespace-nowrap"
                        {% if _repeat == 1 %}aria-hidden="true"{% endif %}>
                    {% if service.icon_url %}
                      <img src="{{ service.icon_url }}" alt="" class="service-icon w-3.5 h-3.5">
                    {% else %}
                      <span class="w-4 h-4 rounded-full bg-fill-subtle text-tertiary inline-flex items-center justify-center type-helper font-semibold">{{ service.display_name[0] }}</span>
                    {% endif %}
                    {{ service.display_name }}
                  </span>
                {% endfor %}
              {% endfor %}
            </div>
          </div>
          {% endif %}

          {# Walkthrough nav: Previous / dots / Next, and Begin once both the #}
          {# workspace is ready and the user is on the last step. #}
          <nav class="flex items-center gap-4" aria-label="Walkthrough">
            <Button variant="secondary" size="lg" id="onboarding-prev" disabled>Previous</Button>
            <div class="flex items-center gap-1.5" id="onboarding-dots" aria-hidden="true">
              {% for _step in range(1, 10) %}
                <span class="onboarding-dot" data-dot="{{ _step }}"></span>
              {% endfor %}
            </div>
            {# Next/Begin visibility is inline display (not the ``hidden`` #}
            {# utility): the button base's inline-flex would win the CSS #}
            {# order against ``hidden``. onboarding.js toggles style.display. #}
            <Button variant="primary" size="lg" id="onboarding-next" extra="min-w-28">Next</Button>
            <Button variant="primary" size="lg" id="onboarding-begin" extra="min-w-28" style="display: none">Begin</Button>
          </nav>
        </div>
      </div>

      {# Failure sub-view: revealed by creating.js the moment creation fails. #}
      <div id="failure-view" class="hidden flex-1 w-full max-w-xl mx-auto px-6 flex flex-col justify-center pb-12">
        <div class="text-center pt-2 pb-1">
          <div class="type-heading mb-1.5 text-important">We couldn't set up your workspace</div>
          <p class="type-body text-secondary">Setup stopped before your workspace was ready.</p>
        </div>
        <Notice variant="error">
          <span id="error-message" class="font-mono type-helper break-words whitespace-pre-wrap"></span>
        </Notice>
        {# Private-repo guidance: revealed by creating.js only when the backend #}
        {# classifies the failure as GITHUB_AUTH_REQUIRED (the workspace source #}
        {# is a github.com URL none of this computer's git credentials can see). #}
        {# The copy is static template content gated on the error kind; the #}
        {# backend only classifies, it never generates prose. #}
        <div id="github-auth-help" class="hidden text-left type-body text-secondary mt-3">
          <p>
            This repository looks private, or it does not exist: GitHub asked for
            credentials, and none on this computer could open it. If you have access
            to the repository, sign in to GitHub on this computer and try again.
          </p>
          <p class="mt-2">
            The simplest way to sign in is the GitHub CLI: run
            <code class="font-mono">gh auth login</code> in a terminal and follow the
            prompts (see the
            <Link href="https://docs.github.com/en/github-cli/github-cli/quickstart"
                  target="_blank" rel="noopener">GitHub CLI quickstart</Link>).
            Git then uses those credentials automatically when cloning.
          </p>
          <p class="mt-2">
            Alternatively, clone or download the repository yourself to any folder on
            this computer, and enter that folder's path in the form instead of the URL.
          </p>
        </div>
        {# Generic (non-GitHub) git remote: same guidance as above but without #}
        {# the GitHub-CLI advice, which only fits github.com. Revealed by #}
        {# creating.js when the backend classifies the failure as GIT_AUTH_REQUIRED. #}
        <div id="git-auth-help" class="hidden text-left type-body text-secondary mt-3">
          <p>
            This repository looks private, or it does not exist: it asked for
            credentials, and none on this computer could open it. If you have access
            to it, make sure your git credentials for this host are set up on this
            computer, then try again.
          </p>
          <p class="mt-2">
            Alternatively, clone or download the repository yourself to any folder on
            this computer, and enter that folder's path in the form instead of the URL.
          </p>
        </div>
        <div class="flex items-center justify-center gap-2 mt-4">
          <ButtonLink href="/create" variant="primary">Back to setup</ButtonLink>
          <ButtonLink href="/" variant="ghost">Home</ButtonLink>
        </div>
      </div>

    </section>

  </main>
</Base>
