{#def boot_state #}
{#
  Centered sharing-editor modal page, hosted in the desktop client's shared
  modal WebContentsView (or the browser ModalHost iframe). Opened from
  Workspace Settings' "Manage sharing" buttons; the full /sharing page stays
  as the browser-mode fallback. The body is the mithril sharing surface's
  modal variant (frontend/src/views/SharingEditor.ts): backdrop + fixed
  card, a plain-links heading (nothing may navigate the overlay iframe),
  the editor or associate prompt, and dismissal through the host adapter
  (Cancel, the X, and backdrop clicks; Escape is handled by the Electron
  main process for any modal-view page).
#}
{% set _scripts %}
<script>
  window.MindsUI.mountSharingModal(document.getElementById('sharing-modal-root'));
</script>
{% endset %}
<OverlaySurface title="Sharing"
                body_style="-webkit-app-region: no-drag;"
                :boot_state="boot_state"
                scripts={{ _scripts }}>
  <div id="sharing-modal-root"></div>
</OverlaySurface>
