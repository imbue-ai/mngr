{#def title, agent_id, ws_name, boot_state #}
{#
  Full-page sharing editor: the browser-mode fallback for the centered
  sharing modal (pages.SharingModal), reached from Workspace Settings'
  "Manage sharing" buttons. The whole body -- heading, editor (or the
  associate prompt when the workspace has no account), submission flow --
  is the mithril sharing surface (frontend/src/views/SharingEditor.ts),
  mounted from the ``sharing`` island slice.
#}
{% set _scripts %}
<script>
  window.MindsUI.mountSharingPage(document.getElementById('sharing-root'));
</script>
{% endset %}
<ChromeShell :title="title"
      :crumb_workspace_name="ws_name"
      :crumb_agent_id="agent_id"
      :show_back="True"
      body_class="bg-surface-primary text-primary font-sans antialiased"
      :boot_state="boot_state"
      scripts={{ _scripts }}>
  <PageContainer>
    <div id="sharing-root"></div>
  </PageContainer>
</ChromeShell>
