{#def title, agent_id, service_name, mngr_forward_origin, initial_emails, has_account, accounts, redirect_url, ws_name, account_email #}
{#
  Sharing editor page used by the workspace-settings sharing flow.
  mngr_forward_origin is the bare origin of the mngr forward plugin;
  the workspace link in the page title points at
  {mngr_forward_origin}/goto/<agent>/.
#}
{% set _scripts %}
{% if has_account %}
<script src="/_static/sharing.js" defer></script>
{% endif %}
{% endset %}
<Base :title="title"
      body_class="bg-surface-primary text-primary font-sans antialiased"
      scripts={{ _scripts }}>
  <PageContainer>
    <h1 id="page-heading" class="text-2xl font-semibold text-primary leading-tight">
      Share <code class="code-pill">{{ service_name }}</code>
      in <Link href={{ mngr_forward_origin ~ "/goto/" ~ agent_id ~ "/" }}>{{ ws_name or agent_id }}</Link>
      {% if account_email %}(<Link href="/accounts">{{ account_email }}</Link>){% endif %}?
    </h1>

    {% if not has_account %}
      <Associate :agent_id="agent_id" :accounts="accounts" :redirect_url="redirect_url" />
    {% else %}

      <div id="sharing-editor">
        <p id="loading-state" class="text-secondary py-16">Loading...</p>
      </div>

      <div id="editor-content" class="hidden">
        <div id="url-section" class="hidden mb-16">
          <p class="font-medium mb-4">Shared URL</p>
          <div id="url-provisioning" class="hidden flex gap-8 items-center text-sm text-secondary my-8">
            <Spinner size="sm" />
            <span>Provisioning share&hellip;</span>
          </div>
          <div id="url-ready" class="hidden">
            <div class="flex gap-8 items-center bg-fill-subtle border border-default rounded-md px-12 py-8 my-8">
              <input type="text" id="share-url" readonly
                     class="flex-1 bg-transparent border-0 text-sm text-primary font-mono outline-none"
                     onclick="this.select()">
              <Button variant="secondary" id="copy-btn" onclick="copyUrl()">Copy</Button>
            </div>
            <p id="url-fallback-note" class="hidden text-xs text-tertiary mt-4">
              This link may take a moment to become reachable.
            </p>
          </div>
        </div>

        <h2 class="text-sm font-medium text-secondary mt-24 mb-12">Access List</h2>
        <div id="email-list"></div>
        <div class="flex gap-8 items-center mt-8">
          <TextInput type="email" name="new_email" id="new-email" placeholder="Add email address" extra="flex-1"
                     onkeydown="if (event.key === 'Enter') { event.preventDefault(); addEmail(); }" />
          <Button variant="secondary" onclick="addEmail()">Add</Button>
        </div>

        <div class="flex gap-8 mt-16 justify-between" id="action-buttons">
          <div class="flex gap-8">
            <ButtonLink href={{ "/workspace/" ~ agent_id ~ "/settings" }} variant="secondary">Cancel</ButtonLink>
            <Button variant="danger" id="disable-btn" onclick="submitDisable()" extra="hidden">Disable Sharing</Button>
          </div>
          <Button variant="success" id="action-btn" onclick="submitUpdate()">Update</Button>
        </div>
        <div id="submit-spinner" class="hidden py-16">
          <span class="text-secondary">Saving changes...</span>
        </div>
      </div>
    {% endif %}
  </PageContainer>

  {% if has_account %}
    {#
      Page-specific data goes in a JSON-serialized data island so sharing.js
      can pick it up without us having to template JS. Safe because we use
      Jinja's tojson filter -- the emitted payload is valid JSON and
      cannot break out into active code.
    #}
    <script id="sharing-config" type="application/json">
{
  "agentId": {{ agent_id | tojson }},
  "serviceName": {{ service_name | tojson }},
  "wsName": {{ (ws_name or agent_id) | tojson }},
  "accountEmail": {{ (account_email or '') | tojson }},
  "initialEmails": {{ initial_emails | tojson }}
}
    </script>
  {% endif %}
</Base>
