{#def boot_state #}
{#
  Manage accounts page (browser-mode fallback for the accounts modal). The
  body is the mithril accounts surface (frontend/src/views/AccountsPage.ts),
  mounted from the ``accounts`` island slice: per-account rows with
  workspace counts, default marker, signed-out indicator, and
  set-default / log-out / add-account actions.

  The per-machine error-reporting toggles live on the dedicated Settings
  page, not here -- they are global to the machine and independent of which
  accounts are signed in.
#}
{% set _scripts %}
<script src="/_static/sync_status_banner.js" defer></script>
<script>
  window.MindsUI.mountAccountsPage(document.getElementById('accounts-root'));
</script>
{% endset %}
<ChromeShell title="Manage Accounts" page_label="Accounts" :show_back="True" :boot_state="boot_state" scripts={{ _scripts }}>
  <PageContainer>
    <div id="accounts-root"></div>
  </PageContainer>
</ChromeShell>
