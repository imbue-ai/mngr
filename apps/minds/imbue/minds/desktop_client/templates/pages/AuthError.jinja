{#def boot_state #}
{#
  Authentication-failure page, shown when a one-time login code has been
  used or is malformed. The body is the mithril AuthErrorPage component
  (frontend/src/views/AuthTextPages.ts), mounted from the ``auth_error``
  island slice (the failure message).
#}
{% set _scripts %}
<script>
  window.MindsUI.mountAuthError(document.getElementById('auth-error-root'));
</script>
{% endset %}
<PageNarrowContainer title="Authentication Error" max_width="max-w-[460px]" scripts={{ _scripts }} :boot_state="boot_state">
  <div id="auth-error-root"></div>
</PageNarrowContainer>
