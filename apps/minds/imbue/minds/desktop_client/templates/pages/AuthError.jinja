{#def message #}
{#
  Authentication-failure page. Shown when a one-time login code has been
  used or is malformed.
#}
<auth.AuthBase title="Authentication Error" card_extra="max-w-[460px]">
  <h1 class="text-xl font-semibold text-zinc-900 leading-tight">Authentication Failed</h1>
  <p class="mt-2 text-zinc-700">{{ message }}</p>
  <p class="mt-2 text-zinc-700">
    Each login URL can only be used once. Please use the login URL printed in the terminal where
    the server is running, or restart the server to generate a new one.
  </p>
</auth.AuthBase>
