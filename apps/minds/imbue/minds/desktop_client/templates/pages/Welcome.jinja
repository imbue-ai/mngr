{#def boot_state #}
{#
  Welcome/splash page for first-time users. The whole body is the mithril
  WelcomePage component (frontend/src/views/WelcomePage.ts): Sign Up / Log In
  (which open the shared sign-in modal through the host adapter, falling back
  to the full-page /auth/* routes in a standalone document), the
  continue-without-an-account skip link, and the self-advance that watches
  the shared chrome event stream for has_accounts and lands on home once a
  sign-in completes elsewhere (e.g. an OAuth flow finished in the external
  browser). ``boot_state`` seeds an empty ``welcome`` slice -- the page needs
  no data, but every converted page carries an island so harnesses can wait
  on the mount marker uniformly.
#}
{% set _scripts %}
<script>
  window.MindsUI.mountWelcome(document.getElementById('welcome-root'));
</script>
{% endset %}
<ChromeShell title="Welcome to Minds" :boot_state="boot_state" scripts={{ _scripts }}>
  <div id="welcome-root"></div>
</ChromeShell>
