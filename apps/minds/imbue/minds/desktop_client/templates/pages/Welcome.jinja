{#def #}
{#
  Welcome/splash page for first-time users. Offers Sign Up / Log In and a
  "continue without an account" affordance that explains what's gated
  behind an account before proceeding.
#}
{% set _scripts %}
<script>
  (function() {
    var btn = document.getElementById('skip-account-btn');
    var dialog = document.getElementById('skip-dialog');
    var cancel = document.getElementById('skip-cancel-btn');
    btn.addEventListener('click', function() { dialog.classList.remove('hidden'); });
    cancel.addEventListener('click', function() { dialog.classList.add('hidden'); });
    dialog.addEventListener('click', function(e) {
      if (e.target === dialog) dialog.classList.add('hidden');
    });
  })();
</script>
{% endset %}
<Base title="Welcome to Minds" scripts={{ _scripts }}>
  <div class="min-h-screen flex items-center justify-center">
    <div class="max-w-sm w-full px-24 text-center">
      <h1 class="text-3xl font-bold text-primary mb-8">Welcome to Minds</h1>
      <p class="text-secondary text-sm mb-32">Run persistent, autonomous AI agents</p>

      <div class="flex flex-col gap-12 mb-24">
        <ButtonLink href="/auth/signup" variant="primary" block>Sign Up</ButtonLink>
        <ButtonLink href="/auth/login" variant="secondary" block>Log In</ButtonLink>
      </div>

      <Button variant="ghost" id="skip-account-btn"
              extra="!p-0 !bg-transparent !text-xs !font-normal !text-tertiary hover:!bg-transparent hover:!text-primary hover:underline">
        Continue without an account
      </Button>

      <Modal id="skip-dialog" card_extra="text-left">
        <h2 class="text-lg font-semibold text-primary mb-12">Continue without an account?</h2>
        <p class="text-sm text-primary mb-8">An Imbue account enables:</p>
        <ul class="text-sm text-primary list-disc pl-16 mb-16 space-y-4">
          <li>Project sharing</li>
          <li>Imbue-hosted cloud projects</li>
          <li>No need to bring your own API keys</li>
        </ul>
        <p class="text-xs text-tertiary mb-16">You can always create an account later by clicking "log in" in the upper right.</p>
        <div class="flex justify-end gap-12">
          <Button variant="secondary" id="skip-cancel-btn">Cancel</Button>
          <ButtonLink href="/create" variant="primary" id="skip-continue-btn">Continue</ButtonLink>
        </div>
      </Modal>
    </div>
  </div>
</Base>
