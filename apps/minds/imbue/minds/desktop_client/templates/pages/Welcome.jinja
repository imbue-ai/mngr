{#def #}
{#
  Welcome/splash page for first-time users. Offers Sign Up / Log In and a
  "continue without an account" link. The user must resolve one of the three
  before moving on: the titlebar home button is hidden here (chrome.js), and
  the home route bounces back to this splash until an account exists or the
  skip was chosen.

  Sign Up / Log In open the centered sign-in modal on the shared overlay
  surface (posted through the content relay's allowlisted
  ``minds:open-signin-modal`` channel; the content view has no window.minds
  bridge). ``mode`` picks which AuthForm tab leads; ``returnTo: '/'`` lands a
  successful sign-in on the home screen. In a plain browser the links fall
  back to the full-page /auth/* routes.

  The skip link goes through "/welcome/skip" (which records the choice, then
  redirects to "/") rather than straight to "/create": recording the choice
  stops the home route's bounce back to this splash, and the landing handler
  still shows the "Help improve Minds" error-reporting consent screen first
  (when unanswered), so reporting is offered to account-less users too, then
  lands on the create form. Reporting is therefore not gated behind having an
  account.
#}
{% set _scripts %}
<script>
  (function () {
    var isElectronShell = navigator.userAgent.indexOf('Electron') !== -1;
    if (isElectronShell) {
      var openModal = function (mode) {
        window.postMessage({ type: 'minds:open-signin-modal', returnTo: '/', mode: mode }, '*');
      };
      var signup = document.getElementById('welcome-signup-btn');
      var login = document.getElementById('welcome-login-btn');
      if (signup) signup.addEventListener('click', function (e) { e.preventDefault(); openModal('signup'); });
      if (login) login.addEventListener('click', function (e) { e.preventDefault(); openModal('signin'); });
    }

    // Self-advance the splash once an account exists: a sign-in can complete
    // without this page navigating (e.g. an OAuth flow finished in the
    // external browser after the sign-in modal was dismissed). Watch the
    // chrome SSE for has_accounts and land on home; the landing route no
    // longer bounces back once an account is present.
    var events;
    try { events = new EventSource('/_chrome/events'); } catch (e) { events = null; }
    if (events) {
      events.onmessage = function (ev) {
        var data;
        try { data = JSON.parse(ev.data); } catch (e) { return; }
        if (data && data.type === 'workspaces' && data.has_accounts) {
          events.close();
          window.location.href = '/';
        }
      };
    }
  })();
</script>
{% endset %}
<Base title="Welcome to Minds" scripts={{ _scripts }}>
  <div class="min-h-screen flex items-center justify-center">
    <div class="max-w-sm w-full px-6 text-center">
      <h1 class="type-heading-lg text-primary mb-2">Welcome to Minds</h1>
      <p class="text-secondary type-body mb-8">Run persistent, autonomous AI agents</p>

      <div class="flex flex-col gap-3 mb-6">
        <ButtonLink href="/auth/signup" variant="primary" block id="welcome-signup-btn">Sign Up</ButtonLink>
        <ButtonLink href="/auth/login" variant="secondary" block id="welcome-login-btn">Log In</ButtonLink>
      </div>

      <ButtonLink href="/welcome/skip" variant="ghost" id="skip-account-btn"
              extra="!p-0 !bg-transparent !type-helper !text-tertiary hover:!bg-transparent hover:!text-primary hover:underline">
        Continue without an account
      </ButtonLink>
    </div>
  </div>
</Base>
