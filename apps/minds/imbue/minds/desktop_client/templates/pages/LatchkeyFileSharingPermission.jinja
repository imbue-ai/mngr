{#def agent_id, request_id, ws_name, rationale, file_path, access, access_human_label, display_name, accent, mngr_forward_origin #}
{#
  Latchkey file-sharing permission request standalone page. Wraps the
  shared body component in the full PermissionsDialog chrome (Base
  plus backdrop plus submit/Escape JS) so the page can be loaded
  directly at /requests/{id}. The inbox modal embeds the body
  component directly.
#}
<PermissionsDialog :display_name="display_name" :accent="accent">
  <LatchkeyFileSharingPermissionBody
    :agent_id="agent_id"
    :request_id="request_id"
    :ws_name="ws_name"
    :rationale="rationale"
    :file_path="file_path"
    :access="access"
    :access_human_label="access_human_label"
    :display_name="display_name" />
</PermissionsDialog>
