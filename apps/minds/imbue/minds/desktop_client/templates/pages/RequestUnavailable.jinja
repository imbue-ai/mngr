{#def message #}
{#
  Shown when a permission-request page is opened but the request is no
  longer actionable (already granted/denied, or doesn't exist). Mirrors
  the permissions dialog's modal chrome (transparent body, dim backdrop,
  centered card) so it reads as the same dialog when hosted in the desktop
  client's overlay view, and degrades to a dimmed centered card in a
  browser.
#}
{% set _scripts %}
<script>
  window.closePermissionDialog = function () {
    if (window.minds && window.minds.closeModal) {
      window.minds.closeModal();
    } else {
      window.location.href = "/";
    }
  };
  window.onBackdropClick = function (event) {
    if (event.target && event.target.id === "permissions-backdrop") {
      window.closePermissionDialog();
    }
  };
  document.addEventListener("keydown", function (e) {
    if (e.key === "Escape") window.closePermissionDialog();
  });
</script>
{% endset %}
<Base title="Request unavailable"
      body_class="bg-transparent text-zinc-900 font-sans antialiased"
      scripts={{ _scripts }}>
  <div id="permissions-backdrop"
       class="fixed inset-0 bg-black/40 flex items-center justify-center p-6"
       onclick="onBackdropClick(event)">
    <div class="relative w-full max-w-[460px] bg-white border border-zinc-200 rounded-2xl shadow-xl overflow-hidden">
      <button type="button" aria-label="Close"
              onclick="closePermissionDialog()"
              class="absolute top-3 right-3 z-10 inline-flex items-center justify-center w-8 h-8 rounded-md text-zinc-400 hover:text-zinc-700 hover:bg-zinc-100 transition-colors cursor-pointer">
        <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="w-5 h-5">
          <path fill-rule="evenodd" clip-rule="evenodd"
                d="M4.22 4.22a.75.75 0 0 1 1.06 0L10 8.94l4.72-4.72a.75.75 0 1 1 1.06 1.06L11.06 10l4.72 4.72a.75.75 0 1 1-1.06 1.06L10 11.06l-4.72 4.72a.75.75 0 0 1-1.06-1.06L8.94 10 4.22 5.28a.75.75 0 0 1 0-1.06Z" />
        </svg>
      </button>
      <div class="p-6 sm:p-7">
        <h1 class="text-xl font-semibold text-zinc-900 leading-tight pr-8">This permission request is no longer available</h1>
        <p class="mt-2 text-zinc-600">{{ message }}</p>
        <div class="flex justify-end mt-6">
          <button type="button" onclick="closePermissionDialog()"
                  class="inline-flex items-center justify-center rounded-lg px-4 py-2 text-sm font-medium bg-zinc-900 text-white hover:bg-zinc-800 transition-colors cursor-pointer">
            Close
          </button>
        </div>
      </div>
    </div>
  </div>
</Base>
