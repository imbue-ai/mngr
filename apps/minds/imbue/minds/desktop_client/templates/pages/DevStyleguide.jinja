{#def #}
{#
  Dev styleguide: hand-authored inventory of design tokens and UI patterns.
  Mounted at /_dev/styleguide. Always visible (no tier gate). Each swatch
  declares its token via data-token="--<name>"; the templates_test.py
  ratchet cross-checks this set against the :root declarations in
  static/tokens.css and fails if either side drifts.
#}
{% set _scripts %}
<script src="/_static/dev_styleguide.js" defer></script>
{% endset %}
<Base title="Minds Styleguide" scripts={{ _scripts }}>
  <div class="max-w-5xl mx-auto px-8 py-10">

    <header class="mb-10">
      <h1 class="text-2xl font-semibold text-zinc-900">Minds Styleguide</h1>
      <p class="text-sm text-zinc-500 mt-1">
        Tokens are in
        <code class="text-zinc-700">apps/minds/imbue/minds/desktop_client/static/tokens.css</code>.
      </p>
    </header>

    {# Tokens #}
    <section class="mb-12">
      <h2 class="text-lg font-semibold text-zinc-900 mb-1">Tokens</h2>
      <p class="text-xs text-zinc-500 mb-4">
        CSS custom properties declared on <code>:root</code> in
        <code>static/tokens.css</code>.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <div data-token="--shadow-seam"
             class="flex items-center gap-3 bg-white border border-zinc-200 rounded-lg p-3 shadow-sm">
          <div class="w-10 h-10 rounded-md bg-white shrink-0"
               style="box-shadow: var(--shadow-seam);"></div>
          <div class="min-w-0 flex-1">
            <div class="text-xs font-mono text-zinc-900 truncate">--shadow-seam</div>
            <div class="text-[11px] font-mono text-zinc-500 truncate">0 4px 10px -6px rgba(0, 0, 0, 0.35)</div>
          </div>
        </div>
      </div>
    </section>

    {# Workspace accent picker #}
    <section class="mb-12">
      <h2 class="text-lg font-semibold text-zinc-900 mb-1">Workspace accent</h2>
      <p class="text-xs text-zinc-500 mb-4">
        Per-workspace identity color. Drag the hue slider; everything below
        that uses <code>--workspace-accent</code> updates live.
      </p>
      <div class="bg-white border border-zinc-200 rounded-lg p-4 shadow-sm">
        <div class="flex items-center gap-4">
          <div class="accent-swatch w-12 h-12 rounded-md border border-zinc-300 shrink-0"></div>
          <div class="flex-1">
            <label for="styleguide-accent-hue" class="block text-xs text-zinc-500 mb-1">
              hue (0-360)
            </label>
            <input id="styleguide-accent-hue" type="range" min="0" max="360" value="230"
                   class="w-full">
          </div>
          <code id="styleguide-accent-value" class="text-xs text-zinc-700"></code>
        </div>
      </div>
    </section>

    {# Pattern catalog #}
    <section class="mb-12">
      <h2 class="text-lg font-semibold text-zinc-900 mb-1">Patterns</h2>
      <p class="text-xs text-zinc-500 mb-4">
        Common chrome and workspace UI patterns. Source files linked under
        each example.
      </p>

      {# Titlebar buttons #}
      <div class="mb-6">
        <div class="text-xs uppercase tracking-wide text-zinc-500 mb-2">Titlebar buttons</div>
        <div class="rounded-lg overflow-hidden border border-zinc-200 bg-zinc-900">
          <div class="h-[38px] flex items-center select-none border-b border-white/10 px-1">
            <div class="flex gap-0.5">
              <button title="Projects"
                      class="bg-transparent border-none text-zinc-400 cursor-pointer w-8 h-7 flex items-center justify-center rounded hover:text-zinc-200 hover:bg-white/5 active:bg-white/10">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="9" y1="3" x2="9" y2="21"/></svg>
              </button>
              <button title="Home"
                      class="bg-transparent border-none text-zinc-400 cursor-pointer w-8 h-7 flex items-center justify-center rounded hover:text-zinc-200 hover:bg-white/5 active:bg-white/10">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12L12 3l9 9"/><path d="M5 10v10a1 1 0 0 0 1 1h4v-6h4v6h4a1 1 0 0 0 1-1V10"/></svg>
              </button>
              <button title="Back"
                      class="bg-transparent border-none text-zinc-400 cursor-pointer w-8 h-7 flex items-center justify-center rounded hover:text-zinc-200 hover:bg-white/5 active:bg-white/10">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
              </button>
              <button title="Forward"
                      class="bg-transparent border-none text-zinc-400 cursor-pointer w-8 h-7 flex items-center justify-center rounded hover:text-zinc-200 hover:bg-white/5 active:bg-white/10">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"/></svg>
              </button>
            </div>
            <div class="flex-1 flex items-center justify-center gap-2 px-2 min-w-0">
              <span class="accent-swatch w-2.5 h-2.5 rounded-sm shrink-0"></span>
              <span class="text-zinc-200 text-xs whitespace-nowrap overflow-hidden text-ellipsis">my-workspace</span>
            </div>
            <button title="Requests"
                    class="relative bg-transparent border-none text-zinc-400 cursor-pointer w-8 h-7 flex items-center justify-center rounded hover:text-zinc-200 hover:bg-white/5">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            </button>
          </div>
        </div>
        <div class="mt-1 text-[11px] text-zinc-500 font-mono">templates/pages/Chrome.jinja</div>
      </div>

      {# Notification badge #}
      <div class="mb-6">
        <div class="text-xs uppercase tracking-wide text-zinc-500 mb-2">Notification badge</div>
        <div class="rounded-lg overflow-hidden border border-zinc-200 bg-zinc-900">
          <div class="h-[38px] flex items-center justify-end px-1">
            <button title="Requests"
                    class="relative bg-transparent border-none text-zinc-400 cursor-pointer w-8 h-7 flex items-center justify-center rounded hover:text-zinc-200 hover:bg-white/5">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              <span class="absolute top-0.5 right-0.5 w-2 h-2 rounded-full bg-red-500"></span>
            </button>
          </div>
        </div>
        <div class="mt-1 text-[11px] text-zinc-500 font-mono">templates/pages/Chrome.jinja :: #requests-badge</div>
      </div>

      {# Window controls (only rendered on non-mac in real chrome) #}
      <div class="mb-6">
        <div class="text-xs uppercase tracking-wide text-zinc-500 mb-2">Window controls</div>
        <div class="rounded-lg overflow-hidden border border-zinc-200 bg-zinc-900">
          <div class="h-[38px] flex items-center justify-end">
            <button title="Minimize"
                    class="bg-transparent border-none text-zinc-400 cursor-pointer w-9 h-[38px] flex items-center justify-center hover:bg-white/5 hover:text-zinc-200" style="border-radius: 0;">
              <svg viewBox="0 0 12 12" class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="2" y1="6" x2="10" y2="6"/></svg>
            </button>
            <button title="Maximize"
                    class="bg-transparent border-none text-zinc-400 cursor-pointer w-9 h-[38px] flex items-center justify-center hover:bg-white/5 hover:text-zinc-200" style="border-radius: 0;">
              <svg viewBox="0 0 12 12" class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="8" height="8" rx="0.5"/></svg>
            </button>
            <button title="Close"
                    class="bg-transparent border-none text-zinc-400 cursor-pointer w-9 h-[38px] flex items-center justify-center hover:bg-red-600 hover:text-white" style="border-radius: 0;">
              <svg viewBox="0 0 12 12" class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="2" y1="2" x2="10" y2="10"/><line x1="10" y1="2" x2="2" y2="10"/></svg>
            </button>
          </div>
        </div>
        <p class="mt-1 text-[11px] text-zinc-500">
          Only rendered on non-mac platforms in real chrome (macOS has native traffic lights).
        </p>
        <div class="mt-0.5 text-[11px] text-zinc-500 font-mono">templates/pages/Chrome.jinja :: #min-btn / #max-btn / #close-btn</div>
      </div>

      {# Sidebar items #}
      <div class="mb-6">
        <div class="text-xs uppercase tracking-wide text-zinc-500 mb-2">Sidebar items</div>
        <div class="w-[260px] rounded-lg overflow-hidden border border-zinc-200 bg-zinc-900">
          <div class="py-2">
            <div class="sidebar-item is-current cursor-pointer text-sm font-medium text-zinc-200 rounded-md mx-1.5 my-0.5 py-2.5 pl-4 pr-3 transition-colors bg-white/5">
              current-workspace
            </div>
            <div class="sidebar-item cursor-pointer text-sm font-medium text-zinc-200 rounded-md mx-1.5 my-0.5 py-2.5 pl-4 pr-3 transition-colors hover:bg-white/5">
              another-workspace
            </div>
            <div class="sidebar-item cursor-pointer text-sm font-medium text-zinc-200 rounded-md mx-1.5 my-0.5 py-2.5 pl-4 pr-3 transition-colors hover:bg-white/5">
              third-one
            </div>
          </div>
        </div>
        <div class="mt-1 text-[11px] text-zinc-500 font-mono">static/sidebar.js + static/chrome.js (rendered dynamically) :: .sidebar-item from tokens.css</div>
      </div>

      {# Accent spine #}
      <div class="mb-6">
        <div class="text-xs uppercase tracking-wide text-zinc-500 mb-2">Accent spine</div>
        <div class="accent-spine relative flex items-center gap-3 bg-white border border-zinc-200 rounded-xl px-4 py-3.5 overflow-hidden">
          <div class="text-sm text-zinc-700">Card with workspace accent stripe on the left edge.</div>
        </div>
        <div class="mt-1 text-[11px] text-zinc-500 font-mono">templates/pages/Landing.jinja, templates/pages/Destroying.jinja :: .accent-spine from tokens.css</div>
      </div>

      {# Focus ring #}
      <div class="mb-6">
        <div class="text-xs uppercase tracking-wide text-zinc-500 mb-2">Focus ring</div>
        <div class="bg-white border border-zinc-200 rounded-lg p-4">
          <TextInput name="styleguide-focus-ring-input" placeholder="Click to focus" />
        </div>
        <div class="mt-1 text-[11px] text-zinc-500 font-mono">TextInput.jinja (focus:border-blue-600 focus:ring-2 focus:ring-blue-600/15)</div>
      </div>

      {# Shadow seam #}
      <div class="mb-6">
        <div class="text-xs uppercase tracking-wide text-zinc-500 mb-2">Shadow seam</div>
        <div class="bg-zinc-50 p-6 rounded-lg">
          <div class="bg-white rounded-md p-4 text-sm text-zinc-700"
               style="box-shadow: var(--shadow-seam);">
            Below the titlebar, separating chrome from workspace content.
          </div>
        </div>
        <div class="mt-1 text-[11px] text-zinc-500 font-mono">tokens.css :: --shadow-seam</div>
      </div>

      {# Spinner #}
      <div class="mb-6">
        <div class="text-xs uppercase tracking-wide text-zinc-500 mb-2">Spinner</div>
        <div class="bg-white border border-zinc-200 rounded-lg p-4 flex items-center gap-4">
          <Spinner size="sm" />
          <Spinner size="md" />
          <Spinner size="lg" />
        </div>
        <div class="mt-1 text-[11px] text-zinc-500 font-mono">tokens.css :: .spinner + Spinner.jinja</div>
      </div>

      {# Buttons #}
      <div class="mb-6">
        <div class="text-xs uppercase tracking-wide text-zinc-500 mb-2">Buttons</div>
        <div class="bg-white border border-zinc-200 rounded-lg p-4 flex flex-wrap items-center gap-2">
          <Button variant="primary">Primary</Button>
          <Button variant="secondary">Secondary</Button>
          <Button variant="danger">Danger</Button>
          <Button variant="success">Success</Button>
          <Button variant="ghost">Ghost</Button>
        </div>
        <div class="mt-1 text-[11px] text-zinc-500 font-mono">Button.jinja</div>
      </div>

      {# Notices #}
      <div class="mb-6">
        <div class="text-xs uppercase tracking-wide text-zinc-500 mb-2">Notices</div>
        <div class="bg-white border border-zinc-200 rounded-lg p-4">
          <Notice variant="info">Heads up: informational message.</Notice>
          <Notice variant="warn">Careful: something may need attention.</Notice>
          <Notice variant="success">All set: action completed.</Notice>
          <Notice variant="error">Failed: something went wrong.</Notice>
        </div>
        <div class="mt-1 text-[11px] text-zinc-500 font-mono">Notice.jinja</div>
      </div>

      {# Cards #}
      <div class="mb-6">
        <div class="text-xs uppercase tracking-wide text-zinc-500 mb-2">Cards</div>
        <div class="flex flex-col gap-2">
          <Card>
            <span class="text-sm text-zinc-700">Default block card -- caller arranges children.</span>
          </Card>
          <Card layout="row-spread">
            <span class="font-medium text-zinc-700">my-service</span>
            <Button variant="secondary">Manage</Button>
          </Card>
          <Card layout="row" padding="tight">
            <span class="font-medium text-zinc-700">provider</span>
            <span class="text-xs text-zinc-500">backend</span>
            <span class="flex-1"></span>
            <Button variant="secondary">Disable</Button>
          </Card>
          <Card tag="a" href="#" layout="row" interactive>
            <span class="flex-1 font-medium text-zinc-900">Interactive card (tag=&quot;a&quot;)</span>
            <span class="text-xs text-zinc-500">click anywhere</span>
          </Card>
        </div>
        <div class="mt-1 text-[11px] text-zinc-500 font-mono">Card.jinja :: .minds-card from tokens.css</div>
      </div>

      {# Page container #}
      <div class="mb-6">
        <div class="text-xs uppercase tracking-wide text-zinc-500 mb-2">Page container</div>
        <div class="bg-zinc-100 border border-zinc-200 rounded-lg">
          <PageContainer>
            <div class="bg-white border border-zinc-200 rounded-md p-3 text-sm text-zinc-700">
              Centered, max-width body wrapper used by most page templates.
            </div>
          </PageContainer>
        </div>
        <div class="mt-1 text-[11px] text-zinc-500 font-mono">PageContainer.jinja</div>
      </div>

      {# Opt (onboarding option card) #}
      <div class="mb-6">
        <div class="text-xs uppercase tracking-wide text-zinc-500 mb-2">Opt (onboarding option)</div>
        <div class="bg-white border border-zinc-200 rounded-lg p-4 flex flex-col gap-2.5">
          <Opt val="example-a" title="Example option" desc="Non-editable selectable card." />
          <Opt val="example-b" title="Selected" desc="Marker for the chosen option." selected />
          <Opt val="example-c" title="Editable" desc="Expands a textarea when selected." editable preset="prefilled text" placeholder="placeholder text" />
        </div>
        <div class="mt-1 text-[11px] text-zinc-500 font-mono">Opt.jinja (.opt / .opt-selected from tokens.css)</div>
      </div>

      {# OAuth icons #}
      <div class="mb-6">
        <div class="text-xs uppercase tracking-wide text-zinc-500 mb-2">OAuth icons</div>
        <div class="bg-white border border-zinc-200 rounded-lg p-4 flex items-center gap-6">
          <span class="inline-flex items-center gap-2 text-sm text-zinc-700">
            <auth.OauthIcon provider="google" /> Google
          </span>
          <span class="inline-flex items-center gap-2 text-sm text-zinc-700">
            <auth.OauthIcon provider="github" /> GitHub
          </span>
        </div>
        <div class="mt-1 text-[11px] text-zinc-500 font-mono">auth/OauthIcon.jinja</div>
      </div>

      {# Status badges #}
      <div class="mb-6">
        <div class="text-xs uppercase tracking-wide text-zinc-500 mb-2">Status badges</div>
        <div class="bg-white border border-zinc-200 rounded-lg p-4 flex flex-wrap items-center gap-3">
          <StatusBadge>Neutral</StatusBadge>
          <StatusBadge variant="success">Done</StatusBadge>
          <StatusBadge variant="error">Failed</StatusBadge>
          <StatusBadge variant="warn">Warning</StatusBadge>
          <StatusBadge variant="info">Info</StatusBadge>
          <StatusBadge variant="warn" size="xs">Tiny</StatusBadge>
        </div>
        <div class="mt-1 text-[11px] text-zinc-500 font-mono">StatusBadge.jinja</div>
      </div>

      {# Section header #}
      <div class="mb-6">
        <div class="text-xs uppercase tracking-wide text-zinc-500 mb-2">Section header</div>
        <div class="bg-white border border-zinc-200 rounded-lg p-4">
          <SectionHeader>Plain</SectionHeader>
          <p class="text-sm text-zinc-600 mb-2">Content under the plain header.</p>
          <SectionHeader divider>With divider</SectionHeader>
          <p class="text-sm text-zinc-600">Content under the divider header.</p>
        </div>
        <div class="mt-1 text-[11px] text-zinc-500 font-mono">SectionHeader.jinja</div>
      </div>

      {# Dialog close button #}
      <div class="mb-6">
        <div class="text-xs uppercase tracking-wide text-zinc-500 mb-2">Dialog close button</div>
        <div class="bg-white border border-zinc-200 rounded-lg p-4 relative h-16">
          <DialogCloseButton onclick="void(0)" />
          <p class="text-sm text-zinc-500">Top-right X used by overlay dialogs.</p>
        </div>
        <div class="mt-1 text-[11px] text-zinc-500 font-mono">DialogCloseButton.jinja</div>
      </div>

      {# Modal -- styleguide only shows the *inside* of the modal because
         the real wrapper occupies the whole viewport. #}
      <div class="mb-6">
        <div class="text-xs uppercase tracking-wide text-zinc-500 mb-2">Modal (inner card preview)</div>
        <div class="bg-zinc-100 border border-zinc-200 rounded-lg p-6 flex items-center justify-center">
          <div class="bg-white rounded-xl shadow-lg border border-zinc-200 max-w-sm w-full p-6">
            <h2 class="text-lg font-semibold text-zinc-900 mb-3">Confirm action?</h2>
            <p class="text-sm text-zinc-600 mb-4">This is what the inner card of a Modal looks like.</p>
            <div class="flex justify-end gap-3">
              <Button variant="secondary">Cancel</Button>
              <Button variant="danger">Confirm</Button>
            </div>
          </div>
        </div>
        <div class="mt-1 text-[11px] text-zinc-500 font-mono">Modal.jinja (full overlay wraps a hidden flex container; preview shows the card only)</div>
      </div>

    </section>

  </div>
</Base>
