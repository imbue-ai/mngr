{#def #}
{#
  Dev styleguide: hand-authored inventory of design tokens and UI patterns.
  Mounted at /_dev/styleguide. Always visible (no tier gate). Each swatch
  declares its token via data-token="--<name>"; the templates_test.py
  ratchet cross-checks this set against the :root declarations in
  static/app.css and fails if either side drifts.
#}
{% set _scripts %}
<script src="/_static/workspace_accent.js" defer></script>
<script src="/_static/sidebar_workspace_row.js" defer></script>
<script src="/_static/dev_styleguide.js" defer></script>
{% endset %}
<Base title="Minds Styleguide" scripts={{ _scripts }}>
  <div class="max-w-5xl mx-auto px-8 py-10">

    <header class="mb-10 flex items-start justify-between gap-4">
      <div>
        <h1 class="text-2xl font-semibold text-zinc-900">Minds Styleguide</h1>
        <p class="text-sm text-zinc-500 mt-1">
          Tokens are in
          <code class="text-zinc-700">apps/minds/imbue/minds/desktop_client/static/app.css</code>.
        </p>
      </div>
      {# Dev-only light/dark toggle. Flips `.dark` on <html> + persists to
         localStorage (wired in dev_styleguide.js); every minds page honors it
         via Base.jinja's pre-paint script. #}
      <button id="styleguide-theme-toggle" type="button"
              class="shrink-0 px-3 py-2 rounded-md text-sm font-medium border border-zinc-300 bg-white text-zinc-900 hover:bg-zinc-100 cursor-pointer">
        Switch to dark
      </button>
    </header>

    {# Tokens #}
    <section class="mb-12">
      <h2 class="text-lg font-semibold text-zinc-900 mb-1">Tokens</h2>
      <p class="text-xs text-zinc-500 mb-4">
        CSS custom properties declared on <code>:root</code> in
        <code>static/app.css</code>.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <div data-token="--shadow-seam"
             class="flex items-center gap-3 bg-white border border-zinc-200 rounded-lg p-3 shadow-sm">
          <div class="w-10 h-10 rounded-md bg-white shrink-0"
               style="box-shadow: var(--shadow-seam);"></div>
          <div class="min-w-0 flex-1">
            <div class="text-xs font-mono text-zinc-900 truncate">--shadow-seam</div>
            <div class="text-[11px] font-mono text-zinc-500 truncate">0 4px 10px -6px rgba(0, 0, 0, 0.35)</div>
          </div>
        </div>
      </div>
    </section>

    {# Type ramp + text-color tokens. These are conventions enforced by
       sweep rather than CSS tokens; documenting them here is the source
       of truth for new templates. #}
    <section class="mb-12">
      <h2 class="text-lg font-semibold text-zinc-900 mb-1">Type ramp</h2>
      <p class="text-xs text-zinc-500 mb-4">
        Heading hierarchy and body text. Every heading is
        ``font-semibold text-zinc-900``; the only axis is size. Body and
        captions use ``text-sm`` / ``text-xs``.
      </p>
      <div class="bg-white border border-zinc-200 rounded-lg p-4 flex flex-col gap-3">
        <div>
          <p class="text-3xl font-bold text-zinc-900">Splash heading</p>
          <p class="text-[11px] text-zinc-500 font-mono mt-0.5">text-3xl font-bold -- one-off, Welcome only</p>
        </div>
        <div>
          <p class="text-2xl font-semibold text-zinc-900">Big page heading (h1)</p>
          <p class="text-[11px] text-zinc-500 font-mono mt-0.5">text-2xl font-semibold -- auth pages, Sharing, DevStyleguide, PermissionsHeader</p>
        </div>
        <div>
          <p class="text-xl font-semibold text-zinc-900">Standard page heading (h1)</p>
          <p class="text-[11px] text-zinc-500 font-mono mt-0.5">text-xl font-semibold -- Landing, Login, AuthError, Destroying, InboxUnavailable, WorkspaceSettings, Accounts</p>
        </div>
        <div>
          <p class="text-lg font-semibold text-zinc-900">Section / modal heading (h2)</p>
          <p class="text-[11px] text-zinc-500 font-mono mt-0.5">text-lg font-semibold -- Creating step questions, modal dialogs, DevStyleguide section headers</p>
        </div>
        <div>
          <p class="text-sm text-zinc-700">Default body text. Readable paragraph on a card.</p>
          <p class="text-[11px] text-zinc-500 font-mono mt-0.5">text-sm -- default body</p>
        </div>
        <div>
          <p class="text-xs text-zinc-500">Caption / secondary text. Goes under headings and beside controls.</p>
          <p class="text-[11px] text-zinc-500 font-mono mt-0.5">text-xs -- secondary / caption</p>
        </div>
      </div>
    </section>

    {# Text color tokens (Stage 1). The semantic, themeable text ramp that
       replaces the raw zinc text utilities documented in the legacy section
       below. Pure black/white at three alpha steps; regular text contrasts
       the surface, inverse contrasts an inverted surface; both swap
       black<->white between modes. Shown in both modes side by side (the
       right card is scoped `.dark`); use the header toggle to flip the whole
       app. data-token marks each --color-* token for the templates_test.py
       drift guard. #}
    <section class="mb-12">
      <h2 class="text-lg font-semibold text-zinc-900 mb-1">Text color tokens</h2>
      <p class="text-xs text-zinc-500 mb-4">
        Semantic, themeable text colors (<code>app.css</code>).
        <code>text-primary</code> / <code>-secondary</code> / <code>-tertiary</code>
        for text on the current surface; <code>text-inverse-*</code> for text on
        an inverted surface. Pure black / white with alpha; values flip
        light&harr;dark.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

        {# Light (scoped via `.light` so it stays light even when the whole
           app is toggled to dark) #}
        <div>
          <div class="text-[11px] uppercase tracking-wide text-zinc-500 mb-2">Light</div>
          <div class="light rounded-lg border border-zinc-200 bg-white p-4 flex flex-col gap-4">
            <div class="flex flex-col gap-2">
              <div data-token="--color-primary" class="flex items-baseline justify-between gap-3">
                <span class="text-primary text-sm font-medium">Primary</span>
                <code class="text-secondary text-[11px] font-mono">text-primary</code>
              </div>
              <div data-token="--color-secondary" class="flex items-baseline justify-between gap-3">
                <span class="text-secondary text-sm font-medium">Secondary</span>
                <code class="text-secondary text-[11px] font-mono">text-secondary</code>
              </div>
              <div data-token="--color-tertiary" class="flex items-baseline justify-between gap-3">
                <span class="text-tertiary text-sm font-medium">Tertiary</span>
                <code class="text-secondary text-[11px] font-mono">text-tertiary</code>
              </div>
            </div>
            <div class="rounded-md bg-zinc-900 p-3 flex flex-col gap-2">
              <div data-token="--color-inverse-primary" class="flex items-baseline justify-between gap-3">
                <span class="text-inverse-primary text-sm font-medium">Inverse primary</span>
                <code class="text-inverse-secondary text-[11px] font-mono">text-inverse-primary</code>
              </div>
              <div data-token="--color-inverse-secondary" class="flex items-baseline justify-between gap-3">
                <span class="text-inverse-secondary text-sm font-medium">Inverse secondary</span>
                <code class="text-inverse-secondary text-[11px] font-mono">text-inverse-secondary</code>
              </div>
              <div data-token="--color-inverse-tertiary" class="flex items-baseline justify-between gap-3">
                <span class="text-inverse-tertiary text-sm font-medium">Inverse tertiary</span>
                <code class="text-inverse-secondary text-[11px] font-mono">text-inverse-tertiary</code>
              </div>
            </div>
          </div>
        </div>

        {# Dark (scoped via `.dark` on the card; bg hardcoded until surface
           tokens exist) #}
        <div>
          <div class="text-[11px] uppercase tracking-wide text-zinc-500 mb-2">Dark</div>
          <div class="dark rounded-lg border border-white/10 p-4 flex flex-col gap-4" style="background-color: #18181b;">
            <div class="flex flex-col gap-2">
              <div class="flex items-baseline justify-between gap-3">
                <span class="text-primary text-sm font-medium">Primary</span>
                <code class="text-secondary text-[11px] font-mono">text-primary</code>
              </div>
              <div class="flex items-baseline justify-between gap-3">
                <span class="text-secondary text-sm font-medium">Secondary</span>
                <code class="text-secondary text-[11px] font-mono">text-secondary</code>
              </div>
              <div class="flex items-baseline justify-between gap-3">
                <span class="text-tertiary text-sm font-medium">Tertiary</span>
                <code class="text-secondary text-[11px] font-mono">text-tertiary</code>
              </div>
            </div>
            <div class="rounded-md bg-white p-3 flex flex-col gap-2">
              <div class="flex items-baseline justify-between gap-3">
                <span class="text-inverse-primary text-sm font-medium">Inverse primary</span>
                <code class="text-inverse-secondary text-[11px] font-mono">text-inverse-primary</code>
              </div>
              <div class="flex items-baseline justify-between gap-3">
                <span class="text-inverse-secondary text-sm font-medium">Inverse secondary</span>
                <code class="text-inverse-secondary text-[11px] font-mono">text-inverse-secondary</code>
              </div>
              <div class="flex items-baseline justify-between gap-3">
                <span class="text-inverse-tertiary text-sm font-medium">Inverse tertiary</span>
                <code class="text-inverse-secondary text-[11px] font-mono">text-inverse-tertiary</code>
              </div>
            </div>
          </div>
        </div>

      </div>
      <div class="mt-2 text-[11px] text-zinc-500 font-mono">app.css :: --color-primary / -secondary / -tertiary (+ -inverse-*)</div>
    </section>

    {# Border tokens. Themeable borders: subtle / default / strong (Figma
       10/16/25% alpha), pure black in light and pure white in dark, same
       alphas both modes. Shown in both modes (right card scoped `.dark`);
       data-token marks each --color-* token for the drift guard. #}
    <section class="mb-12">
      <h2 class="text-lg font-semibold text-zinc-900 mb-1">Border tokens</h2>
      <p class="text-xs text-zinc-500 mb-4">
        Themeable borders (<code>app.css</code>): <code>border-subtle</code>
        (faint dividers), <code>border-default</code> (standard card / input
        border), <code>border-strong</code> (emphasis). Black in light, white in
        dark, same alpha steps.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

        {# Light #}
        <div>
          <div class="text-[11px] uppercase tracking-wide text-zinc-500 mb-2">Light</div>
          <div class="light rounded-lg border border-zinc-200 bg-white p-4 grid grid-cols-3 gap-3">
            <div data-token="--color-subtle" class="flex flex-col items-center gap-2">
              <div class="w-full h-12 rounded-md border border-subtle"></div>
              <code class="text-[11px] font-mono text-secondary">border-subtle</code>
            </div>
            <div data-token="--color-default" class="flex flex-col items-center gap-2">
              <div class="w-full h-12 rounded-md border border-default"></div>
              <code class="text-[11px] font-mono text-secondary">border-default</code>
            </div>
            <div data-token="--color-strong" class="flex flex-col items-center gap-2">
              <div class="w-full h-12 rounded-md border border-strong"></div>
              <code class="text-[11px] font-mono text-secondary">border-strong</code>
            </div>
          </div>
        </div>

        {# Dark (scoped via `.dark`; bg hardcoded until surface tokens exist) #}
        <div>
          <div class="text-[11px] uppercase tracking-wide text-zinc-500 mb-2">Dark</div>
          <div class="dark rounded-lg border border-white/10 p-4 grid grid-cols-3 gap-3" style="background-color: #18181b;">
            <div class="flex flex-col items-center gap-2">
              <div class="w-full h-12 rounded-md border border-subtle"></div>
              <code class="text-[11px] font-mono text-secondary">border-subtle</code>
            </div>
            <div class="flex flex-col items-center gap-2">
              <div class="w-full h-12 rounded-md border border-default"></div>
              <code class="text-[11px] font-mono text-secondary">border-default</code>
            </div>
            <div class="flex flex-col items-center gap-2">
              <div class="w-full h-12 rounded-md border border-strong"></div>
              <code class="text-[11px] font-mono text-secondary">border-strong</code>
            </div>
          </div>
        </div>

      </div>
      <div class="mt-2 text-[11px] text-zinc-500 font-mono">app.css :: --color-subtle / -default / -strong (border-*)</div>
    </section>

    {# Surface & fill tokens. Surfaces are solid backgrounds (primary/inverse
       are exact mirrors; overlay = inverse @ 20%); fills are translucent
       resting/state tints over a surface (selected dropped). Both modes; the
       panels themselves use bg-surface-primary + border-default. data-token
       marks each --color-* token for the drift guard. #}
    <section class="mb-12">
      <h2 class="text-lg font-semibold text-zinc-900 mb-1">Surface &amp; fill tokens</h2>
      <p class="text-xs text-zinc-500 mb-4">
        Surfaces (<code>bg-surface-primary</code> / <code>-inverse</code> /
        <code>-overlay</code>) are solid backgrounds; primary &amp; inverse
        mirror (white&harr;black), overlay is the inverse color at 20%. Fills
        (<code>bg-fill-subtle</code> / <code>-hover</code> / <code>-active</code>)
        are translucent tints over a surface.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

        {# Light #}
        <div>
          <div class="text-[11px] uppercase tracking-wide text-zinc-500 mb-2">Light</div>
          <div class="light bg-surface-primary border border-default rounded-lg p-4">
            <div class="text-[10px] uppercase tracking-wide text-tertiary mb-1.5">Surfaces</div>
            <div class="grid grid-cols-3 gap-3 mb-4">
              <div data-token="--color-surface-primary" class="flex flex-col items-center gap-1.5">
                <div class="w-full h-12 rounded-md bg-surface-primary border border-default"></div>
                <code class="text-[11px] font-mono text-secondary">primary</code>
              </div>
              <div data-token="--color-surface-inverse" class="flex flex-col items-center gap-1.5">
                <div class="w-full h-12 rounded-md bg-surface-inverse"></div>
                <code class="text-[11px] font-mono text-secondary">inverse</code>
              </div>
              <div data-token="--color-surface-overlay" class="flex flex-col items-center gap-1.5">
                <div class="w-full h-12 rounded-md bg-surface-overlay"></div>
                <code class="text-[11px] font-mono text-secondary">overlay</code>
              </div>
            </div>
            <div class="text-[10px] uppercase tracking-wide text-tertiary mb-1.5">Fills</div>
            <div class="grid grid-cols-3 gap-3">
              <div data-token="--color-fill-subtle" class="flex flex-col items-center gap-1.5">
                <div class="w-full h-12 rounded-md bg-fill-subtle border border-subtle"></div>
                <code class="text-[11px] font-mono text-secondary">subtle</code>
              </div>
              <div data-token="--color-fill-hover" class="flex flex-col items-center gap-1.5">
                <div class="w-full h-12 rounded-md bg-fill-hover border border-subtle"></div>
                <code class="text-[11px] font-mono text-secondary">hover</code>
              </div>
              <div data-token="--color-fill-active" class="flex flex-col items-center gap-1.5">
                <div class="w-full h-12 rounded-md bg-fill-active border border-subtle"></div>
                <code class="text-[11px] font-mono text-secondary">active</code>
              </div>
            </div>
          </div>
        </div>

        {# Dark (scoped via `.dark`) #}
        <div>
          <div class="text-[11px] uppercase tracking-wide text-zinc-500 mb-2">Dark</div>
          <div class="dark bg-surface-primary border border-default rounded-lg p-4">
            <div class="text-[10px] uppercase tracking-wide text-tertiary mb-1.5">Surfaces</div>
            <div class="grid grid-cols-3 gap-3 mb-4">
              <div class="flex flex-col items-center gap-1.5">
                <div class="w-full h-12 rounded-md bg-surface-primary border border-default"></div>
                <code class="text-[11px] font-mono text-secondary">primary</code>
              </div>
              <div class="flex flex-col items-center gap-1.5">
                <div class="w-full h-12 rounded-md bg-surface-inverse"></div>
                <code class="text-[11px] font-mono text-secondary">inverse</code>
              </div>
              <div class="flex flex-col items-center gap-1.5">
                <div class="w-full h-12 rounded-md bg-surface-overlay"></div>
                <code class="text-[11px] font-mono text-secondary">overlay</code>
              </div>
            </div>
            <div class="text-[10px] uppercase tracking-wide text-tertiary mb-1.5">Fills</div>
            <div class="grid grid-cols-3 gap-3">
              <div class="flex flex-col items-center gap-1.5">
                <div class="w-full h-12 rounded-md bg-fill-subtle border border-subtle"></div>
                <code class="text-[11px] font-mono text-secondary">subtle</code>
              </div>
              <div class="flex flex-col items-center gap-1.5">
                <div class="w-full h-12 rounded-md bg-fill-hover border border-subtle"></div>
                <code class="text-[11px] font-mono text-secondary">hover</code>
              </div>
              <div class="flex flex-col items-center gap-1.5">
                <div class="w-full h-12 rounded-md bg-fill-active border border-subtle"></div>
                <code class="text-[11px] font-mono text-secondary">active</code>
              </div>
            </div>
          </div>
        </div>

      </div>
      <div class="mt-2 text-[11px] text-zinc-500 font-mono">app.css :: --color-surface-* (bg-surface-*) + --color-fill-* (bg-fill-*)</div>
    </section>

    {# Status / feedback tokens. One solid hue per semantic (Figma),
       mode-independent; notice / badge backgrounds are derived with an
       opacity modifier (bg-success/12 etc.). focus-ring is the focus
       indicator color. data-token marks each --color-* for the drift guard. #}
    <section class="mb-12">
      <h2 class="text-lg font-semibold text-zinc-900 mb-1">Status / feedback tokens</h2>
      <p class="text-xs text-zinc-500 mb-4">
        One solid hue per semantic (<code>important</code> / <code>success</code>
        / <code>warning</code> / <code>info</code>) plus <code>focus-ring</code>.
        Same in both modes; notice / badge tints are derived via an opacity
        modifier (e.g. <code>bg-success/12 border-success/30 text-success</code>).
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

        {# Light #}
        <div>
          <div class="text-[11px] uppercase tracking-wide text-zinc-500 mb-2">Light</div>
          <div class="light bg-surface-primary border border-default rounded-lg p-4">
            <div class="grid grid-cols-5 gap-2 mb-4">
              <div data-token="--color-important" class="flex flex-col items-center gap-1.5"><div class="w-full h-10 rounded-md bg-important"></div><code class="text-[10px] font-mono text-secondary">important</code></div>
              <div data-token="--color-success" class="flex flex-col items-center gap-1.5"><div class="w-full h-10 rounded-md bg-success"></div><code class="text-[10px] font-mono text-secondary">success</code></div>
              <div data-token="--color-warning" class="flex flex-col items-center gap-1.5"><div class="w-full h-10 rounded-md bg-warning"></div><code class="text-[10px] font-mono text-secondary">warning</code></div>
              <div data-token="--color-info" class="flex flex-col items-center gap-1.5"><div class="w-full h-10 rounded-md bg-info"></div><code class="text-[10px] font-mono text-secondary">info</code></div>
              <div data-token="--color-focus-ring" class="flex flex-col items-center gap-1.5"><div class="w-full h-10 rounded-md bg-focus-ring"></div><code class="text-[10px] font-mono text-secondary">focus</code></div>
            </div>
            <div class="flex flex-col gap-2">
              <div class="rounded-md border border-success/30 bg-success/12 text-success px-3 py-2 text-sm">Success notice (hue + opacity)</div>
              <div class="rounded-md border border-important/30 bg-important/12 text-important px-3 py-2 text-sm">Error notice (important)</div>
            </div>
          </div>
        </div>

        {# Dark #}
        <div>
          <div class="text-[11px] uppercase tracking-wide text-zinc-500 mb-2">Dark</div>
          <div class="dark bg-surface-primary border border-default rounded-lg p-4">
            <div class="grid grid-cols-5 gap-2 mb-4">
              <div class="flex flex-col items-center gap-1.5"><div class="w-full h-10 rounded-md bg-important"></div><code class="text-[10px] font-mono text-secondary">important</code></div>
              <div class="flex flex-col items-center gap-1.5"><div class="w-full h-10 rounded-md bg-success"></div><code class="text-[10px] font-mono text-secondary">success</code></div>
              <div class="flex flex-col items-center gap-1.5"><div class="w-full h-10 rounded-md bg-warning"></div><code class="text-[10px] font-mono text-secondary">warning</code></div>
              <div class="flex flex-col items-center gap-1.5"><div class="w-full h-10 rounded-md bg-info"></div><code class="text-[10px] font-mono text-secondary">info</code></div>
              <div class="flex flex-col items-center gap-1.5"><div class="w-full h-10 rounded-md bg-focus-ring"></div><code class="text-[10px] font-mono text-secondary">focus</code></div>
            </div>
            <div class="flex flex-col gap-2">
              <div class="rounded-md border border-success/30 bg-success/12 text-success px-3 py-2 text-sm">Success notice (hue + opacity)</div>
              <div class="rounded-md border border-important/30 bg-important/12 text-important px-3 py-2 text-sm">Error notice (important)</div>
            </div>
          </div>
        </div>

      </div>
      <div class="mt-2 text-[11px] text-zinc-500 font-mono">app.css :: --color-important / -success / -warning / -info / -focus-ring</div>
    </section>

    {# Text-color ramp (LEGACY -- superseded by the token section above; kept
       until the call sites migrate off raw zinc). Five roles, five shades.
       Banished: text-zinc-600 (consolidated into 500 or 700 depending on
       role) and text-zinc-100 (folded into text-zinc-200 for on-dark text). #}
    <section class="mb-12">
      <h2 class="text-lg font-semibold text-zinc-900 mb-1">Text colors (legacy zinc)</h2>
      <p class="text-xs text-zinc-500 mb-4">
        Legacy raw-zinc ramp, being replaced by the Text color tokens above as
        call sites migrate. Five distinct zinc shades, one role each.
      </p>
      <div class="bg-white border border-zinc-200 rounded-lg p-4 flex flex-col gap-2.5">
        <div class="flex items-baseline gap-3">
          <span class="text-zinc-900 text-sm font-medium w-40 shrink-0">Primary text</span>
          <code class="text-[11px] font-mono text-zinc-500 shrink-0">text-zinc-900</code>
          <span class="text-zinc-500 text-xs">headings, emphasized body, labels for form fields</span>
        </div>
        <div class="flex items-baseline gap-3">
          <span class="text-zinc-700 text-sm font-medium w-40 shrink-0">Body</span>
          <code class="text-[11px] font-mono text-zinc-500 shrink-0">text-zinc-700</code>
          <span class="text-zinc-500 text-xs">readable paragraph text on a card; ghost button label</span>
        </div>
        <div class="flex items-baseline gap-3">
          <span class="text-zinc-500 text-sm font-medium w-40 shrink-0">Secondary / label</span>
          <code class="text-[11px] font-mono text-zinc-500 shrink-0">text-zinc-500</code>
          <span class="text-zinc-500 text-xs">captions, section labels, "loading..." spinners</span>
        </div>
        <div class="flex items-baseline gap-3">
          <span class="text-zinc-400 text-sm font-medium w-40 shrink-0">Muted / tertiary</span>
