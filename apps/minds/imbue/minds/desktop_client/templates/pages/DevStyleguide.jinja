{#def boot_state #}
{#
  Dev styleguide (/_dev/styleguide): a hand-authored inventory of design
  tokens + UI patterns. The whole catalog is the mithril StyleguidePage
  component (frontend/src/views/StyleguidePage.ts), which renders the static
  catalog (a trusted HTML constant, styleguide_catalog.ts -- the source of
  the app.css token drift guard) and mounts the three live-component sections
  (smoke / Icon-Badge-Spinner primitives / the shared WorkspaceRow). The
  ``styleguide_smoke`` island seeds the smoke section's message. Wraps Base
  directly (full-width, no ChromeShell), so it carries the bundle tag itself
  like the overlay modal pages.
#}
{% set _scripts %}
<script src="/_static/workspace_accent.js" defer></script>
<script src="/_static/dev_styleguide.js" defer></script>
<script src="/_static/dist/chrome.bundle.js"></script>
<script type="application/json" id="minds-boot-state">{{ boot_state | tojson }}</script>
<script>
  window.MindsUI.mountStyleguidePage(document.getElementById('styleguide-root'));
</script>
{% endset %}
<Base title="Minds Styleguide" scripts={{ _scripts }}>
  <div id="styleguide-root"></div>
</Base>
