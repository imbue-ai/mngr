        <div class="flex flex-col items-center text-center">
          <div class="w-16 h-16 bg-zinc-200 border border-zinc-300 rounded-xl"></div>
          <code class="text-[11px] font-mono text-zinc-500 mt-1">rounded-xl (12px)</code>
          <span class="text-[11px] text-zinc-500">cards, modal / dialog chrome, chrome content tuck-under (Chrome.jinja)</span>
        </div>
        <div class="flex flex-col items-center text-center">
          <div class="w-16 h-16 bg-zinc-200 border border-zinc-300 rounded-2xl"></div>
          <code class="text-[11px] font-mono text-zinc-500 mt-1">rounded-2xl (16px)</code>
          <span class="text-[11px] text-zinc-500">unused (reserved on ramp)</span>
        </div>
        <div class="flex flex-col items-center text-center">
          <div class="w-16 h-16 bg-zinc-200 border border-zinc-300 rounded-full"></div>
          <code class="text-[11px] font-mono text-zinc-500 mt-1">rounded-full</code>
          <span class="text-[11px] text-zinc-500">pills, dots, spinner outline</span>
        </div>
      </div>
    </section>

