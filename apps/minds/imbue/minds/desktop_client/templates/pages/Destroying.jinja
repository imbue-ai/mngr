{#def agent_id, agent_name, pid, status #}
{#
  Detail page for an in-flight or recently-completed destroy. Polls
  /api/destroying/<agent_id>/{status,log} to keep its log tail and status
  badge up to date; once status flips to "done" it redirects to /.
#}
{% set _scripts %}
<script src="/_static/destroying.js" defer></script>
{% endset %}
<Base title={{ "Destroying: " ~ agent_name }}
      body_class="bg-surface-primary text-primary font-sans antialiased"
      scripts={{ _scripts }}>
  <PageContainer>
    <div id="destroying-page" data-agent-id="{{ agent_id }}" data-pid="{{ pid }}" data-initial-status="{{ status }}">
      <h1 class="type-heading text-primary">Destroying {{ agent_name }}</h1>
      <p class="type-helper text-tertiary mb-4">{{ agent_id }} &middot; pid {{ pid }}</p>

      <div id="destroying-status" class="my-4 flex items-center gap-2">
        {% if status == 'running' %}
          <Spinner />
          <span id="status-text" class="text-primary">Running...</span>
        {% elif status == 'failed' %}
          <StatusBadge variant="error">Failed</StatusBadge>
        {% else %}
          <StatusBadge variant="success">Done</StatusBadge>
        {% endif %}
      </div>

      <h2 class="type-label text-secondary mt-6 mb-2">Log</h2>
      <div id="destroying-log"
           class="dark p-3 bg-surface-primary text-secondary font-mono type-helper rounded-lg max-h-[420px] overflow-y-auto whitespace-pre-wrap border border-subtle"></div>

      <div id="destroying-actions" class="mt-6 flex gap-3 hidden">
        <Button variant="primary" id="destroying-retry-btn">Retry</Button>
        <Button variant="secondary" id="destroying-dismiss-btn">Dismiss</Button>
      </div>

      <div class="mt-8">
        <Link href="/" extra="type-helper">&larr; Back to projects</Link>
      </div>
    </div>
  </PageContainer>
</Base>
