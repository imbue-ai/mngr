{#def boot_state, agent_name #}
{#
  Detail page for an in-flight or recently-completed destroy. The whole body
  is the mithril DestroyingPage component
  (frontend/src/views/DestroyingPage.ts), mounted from the
  ``#minds-boot-state`` island this shell seeds (the ``destroying`` slice:
  agent id, name, pid, initial status). The component polls
  /api/v1/workspaces/operations/destroy/<agent_id> for status, streams the
  log over SSE from .../operations/destroy/<agent_id>/logs, and redirects to
  / once the operation reports done.
#}
{% set _scripts %}
<script>
  window.MindsUI.mountDestroying(document.getElementById('destroying-root'));
</script>
{% endset %}
<ChromeShell title={{ "Destroying: " ~ agent_name }}
      body_class="bg-surface-primary text-primary font-sans antialiased"
      :boot_state="boot_state"
      scripts={{ _scripts }}>
  <PageContainer>
    <div id="destroying-root"></div>
  </PageContainer>
</ChromeShell>
