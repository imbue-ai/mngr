{#def workspace_agent_id="", assist_available=false, description="", is_agent_report=false, workspace_name="" #}
{#
  Get-help modal page. Loaded into the shared modal overlay view in Electron (and
  into the content frame as a fallback in browser mode), so the body is transparent
  and a dim backdrop reveals what's behind it -- matching the inbox modal.

  Two options are offered: "have an agent help" and "report a bug to Imbue". Agent
  help is available (and the default) only when opened from a loaded workspace --
  ``workspace_agent_id`` is set; submitting swaps the body to a loading spinner and
  POSTs the description to /help/assist, which blocks until the ``/assist`` chat is
  created and its first message sent, then auto-closes the modal (the new chat tab has
  already auto-opened in the workspace). Report mode POSTs the
  description plus the chosen diagnostics to /help/report, which collects state and
  sends a manually-tagged Sentry report; the response carries the Sentry ``event_id``
  (or null when Sentry is inactive), shown in the confirmation so the user can quote
  it. The report diagnostics are hidden in agent mode (the agent gathers its own
  context). Recent logs are always attached to a submitted report (there is no logs
  checkbox). ``workspace_agent_id`` scopes the optional workspace
  details to the workspace the help flow was opened from. ``description`` pre-fills the
  report textarea -- non-empty when an in-workspace ``/assist`` agent asked the app to
  open this modal with its diagnosis already written in.

  The diagnostics checkboxes are shown at the top level (not under a disclosure) and
  are "sticky": their checked state persists in localStorage across reports.
#}
{% set _scripts %}
<script>
  (function () {
    var WORKSPACE_AGENT_ID = {{ workspace_agent_id | tojson }};

    // Sticky checkbox state: persist each box's checked value across reports so a user
    // who files several reports does not have to re-tick the same diagnostics each time.
    // Keyed by element id; the description text is intentionally NOT persisted.
    var STICKY_PREFIX = "minds.help.";
    var STICKY_IDS = ["help-app-diagnostics", "help-workspace-details", "help-remote-access"];

    function restoreSticky(box) {
      var stored = window.localStorage.getItem(STICKY_PREFIX + box.id);
      if (stored !== null) box.checked = stored === "true";
    }
    function persistSticky(box) {
      try {
        window.localStorage.setItem(STICKY_PREFIX + box.id, box.checked ? "true" : "false");
      } catch (e) {
        /* ignore: a full/blocked localStorage just means the value isn't sticky */
      }
    }
    STICKY_IDS.forEach(function (id) {
      var box = document.getElementById(id);
      if (!box) return;  // not rendered (e.g. include-logs hidden, or no workspace)
      try { restoreSticky(box); } catch (e) { /* ignore unreadable localStorage */ }
      box.addEventListener("change", function () { persistSticky(box); });
    });

    function closeHelp() {
      if (window.minds && window.minds.closeModal) window.minds.closeModal();
      else window.history.back();
    }
    window.onHelpBackdropClick = function (event) {
      if (event.target && event.target.id === "help-backdrop") closeHelp();
    };
    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape") closeHelp();
    });
    document.getElementById("help-close-btn").addEventListener("click", closeHelp);

    var status = document.getElementById("help-status");
    var submit = document.getElementById("help-submit");

    // The two modes differ in what the submit button does and which options are
    // shown: agent help spawns an /assist chat (the agent gathers its own
    // context, so the report diagnostics are hidden), while report sends a bug
    // report with the chosen diagnostics.
    function selectedMode() {
      var checked = document.querySelector('input[name="help-mode"]:checked');
      return checked ? checked.value : "report";
    }
    function applyMode() {
      var isAgent = selectedMode() === "agent";
      var reportOptions = document.getElementById("help-report-options");
      if (reportOptions) reportOptions.classList.toggle("hidden", isAgent);
      submit.textContent = isAgent ? "Start agent" : "Send report";
    }
    Array.prototype.forEach.call(document.querySelectorAll('input[name="help-mode"]'), function (radio) {
      radio.addEventListener("change", applyMode);
    });
    applyMode();

    // Agent-help swaps the whole modal body to a loading state while the request
    // blocks (the /help/assist route waits for the chat to be created and its first
    // message sent, ~15s).
    function showAgentLoading() {
      document.getElementById("help-form").classList.add("hidden");
      document.getElementById("help-error").classList.add("hidden");
      document.getElementById("help-loading").classList.remove("hidden");
    }
    // A failed agent-help spawn (this workspace lacks the /assist skill, or it's unreachable, or
    // the create errored) swaps the body to an error state carrying the server's explanation plus
    // a "Back to report" button, instead of stranding the user on the spinner. Back returns to the
    // form in report mode so they can file a bug instead.
    function showAgentError(message) {
      document.getElementById("help-form").classList.add("hidden");
      document.getElementById("help-loading").classList.add("hidden");
      document.getElementById("help-error-body").textContent = message;
      document.getElementById("help-error").classList.remove("hidden");
    }
    function backToReportFromError() {
      document.getElementById("help-error").classList.add("hidden");
      document.getElementById("help-form").classList.remove("hidden");
      submit.disabled = false;
      // Select report mode by comparing each radio's value as a bare string (not a value
      // attribute selector): the mode-choice radios are absent in agent-report mode, and tests
      // assert the rendered markup contains no such selector outside the real radio inputs.
      Array.prototype.forEach.call(document.querySelectorAll('input[name="help-mode"]'), function (radio) {
        if (radio.value === "report") radio.checked = true;
      });
      applyMode();
    }
    document.getElementById("help-error-back-btn").addEventListener("click", backToReportFromError);

    function submitAgentHelp(description) {
      submit.disabled = true;
      showAgentLoading();
      fetch("/help/assist", {
        method: "POST",
        credentials: "same-origin",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ description: description, workspace_agent_id: WORKSPACE_AGENT_ID }),
      }).then(function (resp) {
        return resp.json().then(function (data) { return { ok: resp.ok, data: data }; });
      }).then(function (result) {
        if (result.ok) {
          // Creation + first message are done and the new chat tab has already
          // auto-opened in the workspace, so just dismiss the modal.
          closeHelp();
        } else {
          showAgentError((result.data && result.data.error) || "Could not start an agent.");
        }
      }).catch(function () {
        showAgentError("Network error starting the agent.");
      });
    }

    submit.addEventListener("click", function () {
      var description = document.getElementById("help-description").value.trim();
      if (!description) {
        status.textContent = "Please describe the problem first.";
        status.className = "type-helper text-danger mt-2";
        return;
      }
      if (selectedMode() === "agent") {
        submitAgentHelp(description);
        return;
      }
      var workspaceBox = document.getElementById("help-workspace-details");
      var payload = {
        description: description,
        include_app_diagnostics: document.getElementById("help-app-diagnostics").checked,
        include_workspace_details: workspaceBox ? workspaceBox.checked : false,
        remote_access: document.getElementById("help-remote-access").checked,
        workspace_agent_id: WORKSPACE_AGENT_ID,
      };
      submit.disabled = true;
      status.textContent = "Sending...";
      status.className = "type-helper text-tertiary mt-2";
      fetch("/help/report", {
        method: "POST",
        credentials: "same-origin",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      }).then(function (resp) {
        return resp.json().then(function (data) { return { ok: resp.ok, data: data }; });
      }).then(function (result) {
        if (result.ok) {
          showSent(result.data && result.data.event_id);
        } else {
          submit.disabled = false;
          status.textContent = (result.data && result.data.error) || "Could not send the report.";
          status.className = "type-helper text-danger mt-2";
        }
      }).catch(function () {
        submit.disabled = false;
        status.textContent = "Network error sending the report.";
        status.className = "type-helper text-danger mt-2";
      });
    });

    // Reveal the confirmation. When Sentry returned an event id, show it with a copy
    // button so the user can quote it when following up; otherwise hide that row (the
    // report was collected but Sentry was inactive, e.g. in dev).
    function showSent(eventId) {
      document.getElementById("help-form").classList.add("hidden");
      document.getElementById("help-sent").classList.remove("hidden");
      var idRow = document.getElementById("help-event-id-row");
      var idValue = document.getElementById("help-event-id");
      if (eventId) {
        idValue.textContent = eventId;
        idRow.classList.remove("hidden");
      } else {
        idRow.classList.add("hidden");
      }
    }

    var copyBtn = document.getElementById("help-copy-id-btn");
    copyBtn.addEventListener("click", function () {
      var id = document.getElementById("help-event-id").textContent;
      try {
        if (navigator.clipboard) navigator.clipboard.writeText(id);
        copyBtn.textContent = "Copied";
        setTimeout(function () { copyBtn.textContent = "Copy"; }, 1500);
      } catch (e) {
        /* ignore */
      }
    });

    document.getElementById("help-done-btn").addEventListener("click", closeHelp);
  })();
</script>
{% endset %}
<OverlaySurface title="Ran into a bug?" scripts={{ _scripts }}>
  <div id="help-backdrop"
       class="fixed inset-0 bg-surface-overlay flex items-center justify-center p-4"
       onclick="onHelpBackdropClick(event)">
    <div id="help-dialog"
         class="relative w-full max-w-md max-h-[90vh] overflow-y-auto bg-surface-primary rounded-lg border border-default shadow-overlay">
      <div class="flex items-center justify-between px-4 h-[44px] border-b border-default">
        <h1 class="type-section text-primary">Ran into a bug?</h1>
        <button type="button" aria-label="Close" id="help-close-btn" data-tooltip="Close"
                class="inline-flex items-center justify-center w-6 h-6 rounded-md text-tertiary hover:text-primary hover:bg-fill-hover cursor-pointer">
          <Icon16 name="close" />
        </button>
      </div>

      <div id="help-form" class="p-4">
        {% if is_agent_report %}
        {# Agent escalation: a report is already underway, so frame it as the agent's submission and
           drop the mode choice below. The workspace name is best-effort (falls back to generic copy). #}
        <p class="type-body text-primary mb-4">
          {% if workspace_name %}An agent in workspace <span class="font-semibold">{{ workspace_name }}</span> wants to submit this report:{% else %}An agent in this workspace wants to submit this report:{% endif %}
        </p>
        {% else %}
        <p class="type-body text-primary mb-4">Here's how we can help:</p>
        {% endif %}

        {# The have-an-agent-help / report-a-bug choice is hidden for an agent escalation (we are
           already reporting). With no radios rendered, the submit JS falls back to report mode. #}
        {% if not is_agent_report %}
        <div class="flex flex-col gap-2 mb-4">
          {% if assist_available %}
          {# Reachable/healthy workspace: agent help is available and is the default choice -- except
             when a description was pre-filled, which only happens when an in-workspace /assist
             agent escalated its diagnosis: that flow must land on the report form for a human to
             review and submit, so report (below) is the default in that case. #}
          <label class="flex items-start gap-3 cursor-pointer">
            <input type="radio" name="help-mode" value="agent" class="mt-1 shrink-0" {% if not description %}checked{% endif %}>
            <span>
              <span class="type-body text-primary font-semibold">Have an agent help fix the problem</span>
              <span class="block type-helper text-tertiary">Opens a new chat in this workspace that diagnoses the issue and fixes what it can.</span>
            </span>
          </label>
          {% else %}
          {# Disabled: either not in a workspace at all, or the workspace isn't reachable yet -- a
             loading/stuck workspace can't host a chat you could see or use. Reporting still works. #}
          <label class="flex items-start gap-3 cursor-not-allowed opacity-50">
            <input type="radio" name="help-mode" value="agent" class="mt-1 shrink-0" disabled>
            <span>
              <span class="type-body text-primary font-semibold">Have an agent help fix the problem</span>
              {% if workspace_agent_id %}
              <span class="block type-helper text-tertiary">Available once this workspace is responding.</span>
              {% else %}
              <span class="block type-helper text-tertiary">Open a workspace to use this.</span>
              {% endif %}
            </span>
          </label>
          {% endif %}
          <label class="flex items-start gap-3 cursor-pointer">
            <input type="radio" name="help-mode" value="report" class="mt-1 shrink-0" {% if not assist_available or description %}checked{% endif %}>
            <span>
              <span class="type-body text-primary font-semibold">Report a bug to Imbue</span>
              <span class="block type-helper text-tertiary">Send us a description and diagnostics so we can investigate.</span>
            </span>
          </label>
        </div>
        {% endif %}

        <label class="block type-label text-secondary mb-1" for="help-description">What happened?</label>
        <textarea id="help-description" rows="4"
                  class="w-full rounded-md border border-default bg-surface-primary p-2 type-body text-primary"
                  placeholder="Describe the problem you ran into...">{{ description }}</textarea>

        {# Report-only options. Hidden in agent-help mode, where the agent gathers its own context. #}
        <div id="help-report-options">
          <p class="type-label text-secondary mt-4 mb-2">Include with the report</p>
          <p class="type-helper text-tertiary mb-2">Recent logs are always included to help us diagnose the problem.</p>
          <div class="flex flex-col gap-2">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" id="help-app-diagnostics" class="shrink-0">
              <span class="type-body text-primary">App diagnostics (versions, accounts, workspaces, system)</span>
            </label>
            {% if workspace_agent_id %}
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" id="help-workspace-details" class="shrink-0">
              <span class="type-body text-primary">Details about the current workspace</span>
            </label>
            {% endif %}
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" id="help-remote-access" class="shrink-0">
              <span class="type-body text-primary">Allow Imbue to request remote access to help debug</span>
            </label>
          </div>
        </div>

        <Button variant="primary" block id="help-submit" extra="mt-4">Send report</Button>
        <p id="help-status" class="type-helper text-tertiary mt-2"></p>
      </div>

      <div id="help-loading" class="p-8 hidden text-center">
        <div class="flex justify-center mb-4"><Spinner size="lg" /></div>
        <p class="type-body text-primary">Starting an agent to help&hellip;</p>
        <p class="type-helper text-tertiary mt-1">Setting up a new chat in this workspace. This can take a few seconds.</p>
      </div>

      <div id="help-error" class="p-4 hidden text-center">
        <h2 class="type-heading text-primary mb-2">Couldn&rsquo;t start an agent</h2>
        <p id="help-error-body" class="type-body text-secondary mb-4"></p>
        <Button variant="primary" block id="help-error-back-btn">Back to report</Button>
      </div>

      <div id="help-sent" class="p-4 hidden text-center">
        <h2 id="help-sent-title" class="type-heading text-primary mb-2">Thanks!</h2>
        <p id="help-sent-body" class="type-body text-secondary mb-4">Your report was sent to Imbue.</p>
        <div id="help-event-id-row" class="hidden mb-4 text-left">
          <p class="type-label text-secondary mb-1">Report ID</p>
          <div class="flex items-center gap-2">
            <code id="help-event-id" class="flex-1 min-w-0 truncate rounded-md border border-default bg-fill-subtle px-2 py-1 type-label text-primary font-mono"></code>
            <Button variant="secondary" id="help-copy-id-btn">Copy</Button>
          </div>
          <p class="type-helper text-tertiary mt-1">Quote this ID when you follow up so we can find your report.</p>
        </div>
        <Button variant="primary" block id="help-done-btn">Done</Button>
      </div>
    </div>
  </div>
</OverlaySurface>
