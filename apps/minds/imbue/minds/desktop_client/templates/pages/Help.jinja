{#def include_logs_setting=false, workspace_agent_id="", description="", is_agent_report=false, workspace_name="", is_fragment=false #}
{#
  Get-help modal page. Loaded into the shared modal overlay view in Electron (and
  into the content frame as a fallback in browser mode), so the body is transparent
  and a dim backdrop reveals what's behind it -- matching the inbox modal.

  Two options are offered: "have an agent help" and "report a bug to Imbue". Agent
  help is available (and the default) only when opened from a loaded workspace --
  ``workspace_agent_id`` is set; submitting swaps the body to a loading spinner and
  POSTs the description to /help/assist, which blocks until the ``/assist`` chat is
  created and its first message sent, then auto-closes the modal (the new chat tab has
  already auto-opened in the workspace). Report mode POSTs the
  description plus the chosen diagnostics to /help/report, which collects state and
  sends a manually-tagged Sentry report; the response carries the Sentry ``event_id``
  (or null when Sentry is inactive), shown in the confirmation so the user can quote
  it. The report diagnostics are hidden in agent mode (the agent gathers its own
  context). ``include_logs_setting``
  is the persistent include-logs preference: when on, logs are always attached and the
  one-off checkbox is hidden. ``workspace_agent_id`` scopes the optional workspace
  details to the workspace the help flow was opened from. ``description`` pre-fills the
  report textarea -- non-empty when an in-workspace ``/assist`` agent asked the app to
  open this modal with its diagnosis already written in.

  The diagnostics checkboxes are shown at the top level (not under a disclosure) and
  are "sticky": their checked state persists in localStorage across reports.
#}
{% set _scripts %}
<script src="/_static/overlay_help.js" defer></script>
{% endset %}
<Base title="Get help"
      body_class="bg-transparent text-primary font-sans antialiased"
      scripts={{ _scripts }}
      :bare="is_fragment">
  {# overlay_help.js drives this modal in both contexts: injected as a fragment
     into the Electron overlay host, or auto-run on this standalone page. It reads
     workspace/include-logs from the #help-dialog data attributes, and (only when
     running standalone, with no overlay host) wires its own backdrop dismiss +
     Escape. #}
  <div id="help-backdrop"
       class="fixed inset-0 bg-surface-overlay flex items-center justify-center p-4">
    <div id="help-dialog"
         data-workspace-agent-id="{{ workspace_agent_id }}"
         data-include-logs="{{ 'true' if include_logs_setting else 'false' }}"
         class="relative w-full max-w-md max-h-[90vh] overflow-y-auto bg-surface-primary rounded-lg border border-default shadow-overlay">
      <div class="flex items-center justify-between px-4 h-[44px] border-b border-default">
        <h1 class="type-section text-primary">Get help</h1>
        <button type="button" aria-label="Close" id="help-close-btn" data-tooltip="Close"
                class="inline-flex items-center justify-center w-6 h-6 rounded-md text-tertiary hover:text-primary hover:bg-fill-hover cursor-pointer">
          <Icon16 name="close" />
        </button>
      </div>

      <div id="help-form" class="p-4">
        {% if is_agent_report %}
        {# Agent escalation: a report is already underway, so frame it as the agent's submission and
           drop the mode choice below. The workspace name is best-effort (falls back to generic copy). #}
        <p class="type-body text-primary mb-4">
          {% if workspace_name %}An agent in workspace <span class="font-semibold">{{ workspace_name }}</span> wants to submit this report:{% else %}An agent in this workspace wants to submit this report:{% endif %}
        </p>
        {% else %}
        <p class="type-body text-primary mb-4">Seems like you're running into a problem &mdash; we can help.</p>
        {% endif %}

        {# The have-an-agent-help / report-a-bug choice is hidden for an agent escalation (we are
           already reporting). With no radios rendered, the submit JS falls back to report mode. #}
        {% if not is_agent_report %}
        <div class="flex flex-col gap-2 mb-4">
          {% if workspace_agent_id %}
          {# In a loaded workspace, agent help is available and is the default choice -- except
             when a description was pre-filled, which only happens when an in-workspace /assist
             agent escalated its diagnosis: that flow must land on the report form for a human to
             review and submit, so report (below) is the default in that case. #}
          <label class="flex items-start gap-3 cursor-pointer">
            <input type="radio" name="help-mode" value="agent" class="mt-1 shrink-0" {% if not description %}checked{% endif %}>
            <span>
              <span class="type-body text-primary font-semibold">Have an agent help fix the problem</span>
              <span class="block type-helper text-tertiary">Opens a new chat in this workspace that diagnoses the issue and fixes what it can.</span>
            </span>
          </label>
          {% else %}
          {# Outside a workspace, agent help is not yet available (a future phase launches a new mind). #}
          <label class="flex items-start gap-3 cursor-not-allowed opacity-50">
            <input type="radio" name="help-mode" value="agent" class="mt-1 shrink-0" disabled>
            <span>
              <span class="type-body text-primary font-semibold">Have an agent help fix the problem</span>
              <span class="block type-helper text-tertiary">Open a workspace to use this.</span>
            </span>
          </label>
          {% endif %}
          <label class="flex items-start gap-3 cursor-pointer">
            <input type="radio" name="help-mode" value="report" class="mt-1 shrink-0" {% if not workspace_agent_id or description %}checked{% endif %}>
            <span>
              <span class="type-body text-primary font-semibold">Report a bug to Imbue</span>
              <span class="block type-helper text-tertiary">Send us a description and diagnostics so we can investigate.</span>
            </span>
          </label>
        </div>
        {% endif %}

        <label class="block type-label text-secondary mb-1" for="help-description">What happened?</label>
        <textarea id="help-description" rows="4"
                  class="w-full rounded-md border border-default bg-surface-primary p-2 type-body text-primary"
                  placeholder="Describe the problem you ran into...">{{ description }}</textarea>

        {# Report-only options. Hidden in agent-help mode, where the agent gathers its own context. #}
        <div id="help-report-options">
          <p class="type-label text-secondary mt-4 mb-2">Include with the report</p>
          <div class="flex flex-col gap-2">
            {% if not include_logs_setting %}
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" id="help-include-logs" class="shrink-0">
              <span class="type-body text-primary">Logs</span>
            </label>
            {% endif %}
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" id="help-app-diagnostics" class="shrink-0">
              <span class="type-body text-primary">App diagnostics (versions, accounts, workspaces, system)</span>
            </label>
            {% if workspace_agent_id %}
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" id="help-workspace-details" class="shrink-0">
              <span class="type-body text-primary">Details about the current workspace</span>
            </label>
            {% endif %}
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" id="help-remote-access" class="shrink-0">
              <span class="type-body text-primary">Allow Imbue to request remote access to help debug</span>
            </label>
          </div>
        </div>

        <Button variant="primary" block id="help-submit" extra="mt-4">Send report</Button>
        <p id="help-status" class="type-helper text-tertiary mt-2"></p>
      </div>

      <div id="help-loading" class="p-8 hidden text-center">
        <div class="flex justify-center mb-4"><Spinner size="lg" /></div>
        <p class="type-body text-primary">Starting an agent to help&hellip;</p>
        <p class="type-helper text-tertiary mt-1">Setting up a new chat in this workspace. This can take a few seconds.</p>
      </div>

      <div id="help-sent" class="p-4 hidden text-center">
        <h2 id="help-sent-title" class="type-heading text-primary mb-2">Thanks!</h2>
        <p id="help-sent-body" class="type-body text-secondary mb-4">Your report was sent to Imbue.</p>
        <div id="help-event-id-row" class="hidden mb-4 text-left">
          <p class="type-label text-secondary mb-1">Report ID</p>
          <div class="flex items-center gap-2">
            <code id="help-event-id" class="flex-1 min-w-0 truncate rounded-md border border-default bg-fill-subtle px-2 py-1 type-label text-primary font-mono"></code>
            <Button variant="secondary" id="help-copy-id-btn">Copy</Button>
          </div>
          <p class="type-helper text-tertiary mt-1">Quote this ID when you follow up so we can find your report.</p>
        </div>
        <Button variant="primary" block id="help-done-btn">Done</Button>
      </div>
    </div>
  </div>
</Base>
