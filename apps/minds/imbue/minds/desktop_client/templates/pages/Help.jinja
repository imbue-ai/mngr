{#def boot_state #}
{#
  Get-help modal page, loaded into the shared modal overlay view in Electron
  (and the browser ModalHost iframe). The whole body is the mithril HelpModal
  component (frontend/src/views/HelpModal.ts), mounted from the ``help``
  island slice: the agent-help / report-a-bug mode choice, the sticky
  diagnostics checkboxes (localStorage), the /help/assist loading + error
  states, the /help/report submission with the Sentry report-id
  confirmation, and dismissal (close button, backdrop, Escape) through the
  host adapter.
#}
{% set _scripts %}
<script>
  window.MindsUI.mountHelpModal(document.getElementById('help-root'));
</script>
{% endset %}
<OverlaySurface title="Ran into a bug?" :boot_state="boot_state" scripts={{ _scripts }}>
  <div id="help-root"></div>
</OverlaySurface>
