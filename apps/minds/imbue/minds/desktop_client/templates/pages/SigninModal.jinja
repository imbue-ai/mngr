{#def boot_state #}
{#
  Sign-in modal page, hosted in the desktop client's shared modal
  WebContentsView (or the browser ModalHost iframe). Opened from the create
  screen, the welcome splash, the home account launcher, and the Manage
  Accounts modal's "Add account". The body is the mithril AuthForm surface's
  modal variant (frontend/src/views/AuthPages.ts): a dim backdrop + centered
  card holding the two-tab form, with dismissal and post-auth navigation
  through the host adapter (a successful sign-in lands the content view on
  the island's return_to and dismisses the overlay).
#}
{% set _scripts %}
<script>
  window.MindsUI.mountSigninModal(document.getElementById('signin-modal-root'));
</script>
{% endset %}
<OverlaySurface title="Sign in"
                body_style="-webkit-app-region: no-drag;"
                :boot_state="boot_state"
                scripts={{ _scripts }}>
  <div id="signin-modal-root"></div>
</OverlaySurface>
