{#
  Error-reporting notice screen. Shown just after login (the user is authenticated)
  while MindsConfig.error_reporting_consent_given is False. Informational only: during
  the alpha, unexpected errors (including logs) are always reported to Imbue so we can
  find and fix problems faster -- there is no opt-out. "Continue" records that the notice
  was acknowledged (POST /consent) and flips the consent-given flag, then reloads the app,
  which now proceeds past this screen to the landing content.
#}
{% set _scripts %}
<script>
  (function() {
    var continueBtn = document.getElementById('consent-continue');

    continueBtn.addEventListener('click', function() {
      continueBtn.disabled = true;
      fetch('/consent', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({}),
      }).then(function() {
        window.location.href = '/';
      }).catch(function() {
        // Even if recording the acknowledgment failed, move on; the consent flag stays
        // unset so the notice will simply reappear on the next launch.
        window.location.href = '/';
      });
    });
  })();
</script>
{% endset %}
<Base title="Error reporting" scripts={{ _scripts }}>
  <div class="min-h-screen flex items-center justify-center">
    <div class="max-w-md w-full px-6">
      <h1 class="type-heading-lg text-primary mb-2">Help improve Minds</h1>
      <p class="text-secondary type-body mb-4">
        Minds is in its alpha phase. To help us find and fix problems quickly, unexpected errors are
        automatically reported to Imbue, along with recent logs to help diagnose what went wrong.
      </p>
      <p class="text-tertiary type-helper mb-8">
        Reports include diagnostic details about the error and your setup, which may identify you (for
        example, your signed-in account email).
      </p>

      <Button variant="primary" block id="consent-continue">Continue</Button>
    </div>
  </div>
</Base>
