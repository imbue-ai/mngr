{#def boot_state #}
{#
  Error-reporting consent screen, shown just after login while
  MindsConfig.error_reporting_consent_given is False. The whole body is the
  mithril ConsentPage component (frontend/src/views/ConsentPage.ts), mounted
  from the ``consent`` island slice (the two toggle states). The component
  reveals "Include logs" only while "Report unexpected errors" is on, POSTs
  /consent on Continue, and reloads the app.
#}
{% set _scripts %}
<script>
  window.MindsUI.mountConsent(document.getElementById('consent-root'));
</script>
{% endset %}
<ChromeShell title="Error reporting" :boot_state="boot_state" scripts={{ _scripts }}>
  <div id="consent-root"></div>
</ChromeShell>
