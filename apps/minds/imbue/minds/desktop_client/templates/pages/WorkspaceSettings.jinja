{#def boot_state, ws_name, agent_id, current_color #}
{#
  Workspace settings page. The whole body is the mithril
  WorkspaceSettingsPage component (frontend/src/views/WorkspaceSettingsPage.ts),
  mounted from the ``workspace_settings`` island slice: rename, the color
  picker (implicit save; optimistic titlebar preview through the host
  adapter), account association (fixed for Imbue-Cloud-leased hosts),
  sharing servers (centered modal via the host adapter, full-page hrefs as
  the standalone fallback), the backup section (status + verification +
  tracked update/configure operations), and the danger-zone destroy flow.

  The shell seeds the accent + crumb server-side (first paint); the shared
  hex normalization the picker uses comes from workspace_accent.js, which
  ChromeShell already loads as a shell script.
#}
{% set _scripts %}
<script>
  window.MindsUI.mountWorkspaceSettings(document.getElementById('workspace-settings-root'));
</script>
{% endset %}
<ChromeShell title={{ "Settings: " ~ ws_name }}
      :accent="current_color"
      :crumb_workspace_name="ws_name"
      :crumb_agent_id="agent_id"
      active_tab="settings"
      body_class="bg-surface-primary text-primary font-sans antialiased"
      :boot_state="boot_state"
      scripts={{ _scripts }}>
  <PageContainer>
    <div id="workspace-settings-root"></div>
  </PageContainer>
</ChromeShell>
