{#def agent_id, ws_name, current_account, accounts, servers, is_leased_imbue_cloud=False, current_color="#0b292b", is_stale=False, has_account=False, palette={} #}
{#
  Workspace settings page. Color picker, account section, sharing servers
  list, and the danger-zone destroy flow.

  is_leased_imbue_cloud is True for workspaces running on a host leased from
  Imbue Cloud. Such hosts are permanently bound to the leasing account to avoid
  confusing "account mixing", so the account section shows the bound account
  with a disabled Disassociate control and offers no association controls.

  current_color is the stored workspace color hex (#rrggbb); it pre-fills the
  hex input and pre-selects the matching palette swatch (if any).
  is_stale disables the picker controls when the workspace's provider's last
  discovery poll errored -- writes against an unreachable host would not be
  observable until provider recovery.
  palette is the {name: hex} map of pickable swatches (10 entries).
#}
{% set _scripts %}
<script src="/_static/workspace_accent.js" defer></script>
<script src="/_static/workspace_settings.js" defer></script>
<script src="/_static/workspace_backups.js" defer></script>
<script>
  (function() {
    var destroyBtn = document.getElementById('destroy-btn');
    var destroyDialog = document.getElementById('destroy-dialog');
    var destroyCancelBtn = document.getElementById('destroy-cancel-btn');
    var destroyConfirmBtn = document.getElementById('destroy-confirm-btn');
    var destroyErrorEl = document.getElementById('destroy-error');
    var agentId = document.getElementById('workspace-settings').dataset.agentId;

    // -- Rename ------------------------------------------------------------
    // Ultra-basic: a text input + Save that POSTs the new (arbitrary) name.
    // The server normalizes it to the host-name slug and updates both the
    // host name and the display label together. Reload on success so every
    // surface (title, sidebar) repaints with the new name.
    var renameInput = document.getElementById('workspace-name-input');
    var renameSaveBtn = document.getElementById('rename-save-btn');
    var renameErrorEl = document.getElementById('rename-error');
    var renameSavingBadge = document.getElementById('rename-saving-badge');
    if (renameInput && renameSaveBtn) {
      renameSaveBtn.addEventListener('click', function() {
        var newName = (renameInput.value || '').trim();
        renameErrorEl.classList.add('hidden');
        if (!newName) {
          renameErrorEl.textContent = 'A workspace name is required.';
          renameErrorEl.classList.remove('hidden');
          return;
        }
        renameSaveBtn.disabled = true;
        if (renameSavingBadge) renameSavingBadge.classList.remove('hidden');
        fetch('/api/v1/workspaces/' + encodeURIComponent(agentId) + '/rename', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name: newName })
        })
          .then(function(resp) {
            if (resp.ok) {
              window.location.reload();
              return null;
            }
            return resp.json().then(function(data) {
              renameSaveBtn.disabled = false;
              if (renameSavingBadge) renameSavingBadge.classList.add('hidden');
              var message = (data && (data.error || data.message || data.detail)) ||
                ('Rename failed (HTTP ' + resp.status + ')');
              renameErrorEl.textContent = message;
              renameErrorEl.classList.remove('hidden');
            });
          })
          .catch(function() {
            renameSaveBtn.disabled = false;
            if (renameSavingBadge) renameSavingBadge.classList.add('hidden');
            renameErrorEl.textContent = 'Rename failed (network error)';
            renameErrorEl.classList.remove('hidden');
          });
      });
    }

    destroyBtn.addEventListener('click', function() {
      destroyDialog.classList.remove('hidden');
    });
    destroyCancelBtn.addEventListener('click', function() {
      destroyDialog.classList.add('hidden');
    });
    destroyDialog.addEventListener('click', function(e) {
      if (e.target === destroyDialog) destroyDialog.classList.add('hidden');
    });

    destroyConfirmBtn.addEventListener('click', function() {
      destroyConfirmBtn.disabled = true;
      // Fire-and-redirect: the detached destroy subprocess survives a
      // settings-page navigation, and the landing page renders a
      // "Destroying..." marker on the row from on-disk state. No more
      // polling here.
      fetch('/api/v1/workspaces/' + encodeURIComponent(agentId) + '/destroy', { method: 'POST' })
        .then(function(resp) {
          if (resp.ok) {
            window.location.href = '/';
            return;
          }
          destroyConfirmBtn.disabled = false;
          destroyErrorEl.textContent = 'Could not start destroy (HTTP ' + resp.status + ')';
          destroyErrorEl.classList.remove('hidden');
          destroyDialog.classList.add('hidden');
        })
        .catch(function() {
          destroyConfirmBtn.disabled = false;
          destroyErrorEl.textContent = 'Could not start destroy (network error)';
          destroyErrorEl.classList.remove('hidden');
          destroyDialog.classList.add('hidden');
        });
    });
  })();
</script>
{% endset %}
<Base title={{ "Settings: " ~ ws_name }}
      body_class="bg-surface-primary text-primary font-sans antialiased"
      scripts={{ _scripts }}>
  <PageContainer>
    <div id="workspace-settings" data-agent-id="{{ agent_id }}" data-is-stale="{{ 'true' if is_stale else 'false' }}">
      <h1 class="type-heading text-primary">{{ ws_name }}</h1>
      <p class="type-helper text-tertiary mb-4">{{ agent_id }}</p>

      <SectionHeader>Workspace Name</SectionHeader>
      <div id="rename-section" class="mb-4">
        {% if is_stale %}
          <Notice variant="warn">
            This workspace is currently unreachable, so it can't be renamed right now.
            Try again once the workspace reconnects.
          </Notice>
        {% endif %}
        <div class="flex items-center gap-2">
          <input id="workspace-name-input"
                 type="text"
                 class="h-[34px] px-3 rounded-full type-body text-primary placeholder:text-tertiary disabled:opacity-40 bg-surface-secondary"
                 value="{{ ws_name }}"
                 maxlength="200"
                 spellcheck="false"
                 autocomplete="off"
                 aria-label="Workspace name"
                 {% if is_stale %}disabled{% endif %}>
          <Button variant="secondary" id="rename-save-btn" :disabled="is_stale">Save</Button>
          <span id="rename-saving-badge" class="hidden type-section text-secondary">Saving...</span>
        </div>
        <p id="rename-error" class="hidden type-body text-important mt-2" role="alert"></p>
      </div>

      {# ``extra`` turns the h2 into a flex row so the badge centers on
         the title's vertical axis; ``leading-none`` + fixed badge height
         keeps the line box from growing when the badge un-hides (which
         would push the swatches down a couple px). #}
      <SectionHeader extra="flex items-center gap-2">Workspace Color <span id="color-saving-badge" class="hidden type-section text-primary bg-surface-primary rounded-sm px-1.5 py-1">Saving</span></SectionHeader>
      <div id="color-section">
        {% if is_stale %}
          <Notice variant="warn">
            This workspace is currently unreachable, so its color can't be changed right now.
            Try again once the workspace reconnects.
          </Notice>
        {% endif %}
        <div role="radiogroup"
             aria-label="Workspace color palette"
             class="flex flex-wrap items-center gap-2 mb-3"
             id="color-swatches">
          {% for name, hex_value in palette.items() %}
            <ColorSwatch :hex="hex_value" :name="name" size="md"
                         :selected="hex_value == current_color" :disabled="is_stale" />
          {% endfor %}
          <input id="color-hex-input"
                 type="text"
                 class="color-hex-pill h-[34px] px-3 rounded-full type-body font-mono text-primary placeholder:text-tertiary disabled:opacity-40{{ ' is-selected' if current_color not in palette.values() else '' }}"
                 value="{{ current_color }}"
                 placeholder="#a1b2c3"
                 maxlength="9"
                 spellcheck="false"
                 autocomplete="off"
                 aria-label="Workspace color hex"
                 size="8"
                 {% if is_stale %}disabled{% endif %}>
        </div>
        <p id="color-error" class="hidden type-body text-important mt-2" role="alert"></p>
      </div>

      <SectionHeader divider>Account</SectionHeader>
      <div id="account-section">
      {% if is_leased_imbue_cloud %}
        {% if current_account %}
          <p>Associated with: <strong>{{ current_account.email }}</strong></p>
        {% endif %}
        <Notice variant="info">
          This workspace runs on a host leased from Imbue Cloud, so its account
          association is fixed and cannot be changed.
        </Notice>
        <Button variant="danger" id="disassociate-btn" disabled>Disassociate</Button>
      {% elif current_account %}
        <p>Associated with: <strong>{{ current_account.email }}</strong></p>
        <Notice variant="warn">
          Disassociating will remove all sharing (tunnels) for this workspace.
          You will need to set up sharing again after re-associating.
        </Notice>
        <Button variant="danger" id="disassociate-btn">Disassociate</Button>
        <span id="disassociate-spinner" class="hidden text-secondary ml-2">Disassociating...</span>
      {% else %}
        <Associate :agent_id="agent_id" :accounts="accounts" />
      {% endif %}
      </div>

      <SectionHeader divider>Sharing</SectionHeader>
      {% if servers %}
        <div class="flex flex-col gap-2">
        {% for server in servers %}
          <Card layout="row-spread">
            <span class="font-semibold">{{ server }}</span>
            <ButtonLink href={{ "/sharing/" ~ agent_id ~ "/" ~ server }} variant="secondary">Manage sharing</ButtonLink>
          </Card>
        {% endfor %}
        </div>
      {% else %}
        <p class="text-secondary">No servers discovered for this workspace.</p>
      {% endif %}

      <SectionHeader divider>Backups</SectionHeader>
      <div id="backup-section">
        {# Verification comes first: the service-status breakdown below only
           exists while verification is enabled. The conditional buttons are
           wrapped in plain spans because a `hidden` class loses to the Button
           component's own inline-flex (see templates/README.md). #}
        <div class="flex items-center gap-2 mb-2">
          <span class="type-body text-primary">Backup service verification</span>
          <span id="backup-verification-btn-wrap" class="hidden">
            <Button variant="secondary" id="backup-verification-btn">Disable</Button>
          </span>
          <span id="backup-verification-spinner" class="hidden type-section text-secondary"></span>
        </div>
        <p id="backup-status-line" class="type-body text-secondary mb-2">Loading backup status...</p>
        <div id="backup-versions" class="hidden type-helper text-tertiary mb-2"></div>
        <ul id="backup-problems" class="hidden type-body text-important mb-2 list-disc pl-4"></ul>
        <div class="flex items-center gap-2 mb-2">
          <span id="backup-update-btn-wrap" class="hidden">
            <Button variant="secondary" id="backup-update-btn">Update backup service</Button>
          </span>
          <span id="backup-stop-chats-btn-wrap" class="hidden">
            <Button variant="secondary" id="backup-stop-chats-btn">Stop all chats and retry</Button>
          </span>
          <span id="backup-cancel-btn-wrap" class="hidden">
            <Button variant="secondary" id="backup-cancel-btn">Cancel</Button>
          </span>
          <span id="backup-op-spinner" class="hidden type-section text-secondary">Working...</span>
        </div>
        <p id="backup-op-progress" class="hidden type-helper text-tertiary mb-2" aria-live="polite"></p>
        <p id="backup-error" class="hidden type-body text-important mb-2" role="alert"></p>

        <div id="backup-configure" class="mb-3">
          <Button variant="secondary" id="backup-configure-toggle-btn">Configure backups...</Button>
          <div id="backup-configure-form" class="hidden mt-3 flex flex-col gap-2">
            <div class="flex items-center gap-2">
              <FormLabel target="backup-provider-select">Provider</FormLabel>
              <select id="backup-provider-select" class="h-[34px] px-3 rounded-full type-body bg-surface-secondary text-primary">
                <option value="IMBUE_CLOUD" {% if not has_account %}disabled{% endif %}>Imbue Cloud{% if not has_account %} (requires an account){% endif %}</option>
                <option value="API_KEY" {% if not has_account %}selected{% endif %}>Bring my own (restic env)</option>
                <option value="NONE">None (disable backups)</option>
              </select>
            </div>
            <div id="backup-api-key-row" class="hidden">
              <FormLabel target="backup-api-key-env-input">Restic env (KEY=VALUE per line; no RESTIC_PASSWORD)</FormLabel>
              <textarea id="backup-api-key-env-input" rows="4" spellcheck="false"
                        class="w-full px-3 py-2 rounded-md type-body font-mono bg-surface-secondary text-primary"
                        placeholder="RESTIC_REPOSITORY=&#10;AWS_ACCESS_KEY_ID=&#10;AWS_SECRET_ACCESS_KEY="></textarea>
            </div>
            <div>
              <Button variant="secondary" id="backup-configure-submit-btn">Apply</Button>
            </div>
          </div>
        </div>
      </div>

      <SectionHeader divider>Danger zone</SectionHeader>
      <p class="type-body text-secondary mb-3">Permanently destroy this workspace and release any associated resources.</p>
      <Button variant="danger" id="destroy-btn">Destroy workspace</Button>
      <p id="destroy-error" class="hidden type-body text-important mt-2"></p>

      <Modal id="destroy-dialog">
        <h2 class="type-heading text-primary mb-3">Destroy workspace?</h2>
        <p class="type-body text-primary mb-4">This will permanently destroy <strong>{{ ws_name }}</strong> and all its data. This action cannot be undone.</p>
        <div class="flex justify-end gap-3">
          <Button variant="secondary" id="destroy-cancel-btn">Cancel</Button>
          <Button variant="danger" id="destroy-confirm-btn">Destroy</Button>
        </div>
      </Modal>

      <div class="mt-8">
        <Link href="/" extra="type-helper">&larr; Back to workspaces</Link>
      </div>
    </div>
  </PageContainer>
</Base>
