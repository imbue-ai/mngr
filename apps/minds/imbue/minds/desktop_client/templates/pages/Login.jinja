{#def #}
{#
  Login prompt page for unauthenticated users. Points the user at the
  one-time-code URL printed in the server's terminal.
#}
<CardPage title="Login - Projects">
  <h1 class="text-xl font-semibold text-zinc-900 leading-tight">Sign in to Minds</h1>
  <p class="text-xs text-zinc-400 mt-1.5 mb-5">Use the login URL printed in the terminal.</p>
  <p class="text-zinc-700 leading-relaxed">
    Each login URL can only be used once. If you've already used yours, restart the server to
    generate a new one.
  </p>
</CardPage>
