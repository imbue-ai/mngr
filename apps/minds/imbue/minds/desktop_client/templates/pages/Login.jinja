{#def boot_state #}
{#
  Login prompt page for unauthenticated users. The body is the mithril
  LoginPromptPage component (frontend/src/views/AuthTextPages.ts), which
  points the user at the one-time-code URL printed in the server's terminal.
  ``boot_state`` seeds an empty ``login`` slice (no data; see Welcome.jinja
  for why every converted page carries an island).
#}
{% set _scripts %}
<script>
  window.MindsUI.mountLoginPrompt(document.getElementById('login-root'));
</script>
{% endset %}
<PageNarrowContainer title="Login - Workspaces" scripts={{ _scripts }} :boot_state="boot_state">
  <div id="login-root"></div>
</PageNarrowContainer>
