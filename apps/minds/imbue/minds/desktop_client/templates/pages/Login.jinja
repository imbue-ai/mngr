{#def #}
{#
  Login prompt page for unauthenticated users. Points the user at the
  one-time-code URL printed in the server's terminal.
#}
<PageNarrowContainer title="Login - Projects">
  <h1 class="type-heading text-primary">Sign in to Minds</h1>
  <p class="type-helper text-tertiary mt-1.5 mb-4">Use the login URL printed in the terminal.</p>
  <p class="text-primary leading-relaxed">
    Each login URL can only be used once. If you've already used yours, restart the server to
    generate a new one.
  </p>
</PageNarrowContainer>
