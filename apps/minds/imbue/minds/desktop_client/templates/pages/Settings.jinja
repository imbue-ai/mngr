{#def report_unexpected_errors=false, include_error_logs=false, services_overview=[], file_sharing_grants=[], permissions_unavailable=false #}
{#
  App-level settings page, reachable from the floating sidebar's "Settings" entry.

  Two columns: a left nav that switches between subsections (Permissions,
  Error reporting) and a right content pane showing the active subsection.

  The Permissions subsection inspects and revokes the "predefined"
  (catalog-backed) latchkey grants held across all *active* workspaces. Grants
  are stored per host and every agent on a host shares them, so each card is one
  workspace (labelled by its primary agent). Revoking removes the rule only --
  stored credentials are left in place -- and there is intentionally no "change"
  affordance here: broadening or narrowing a grant happens through the ordinary
  agent-driven permission-request flow. Each service is shown as its own panel;
  the panel header's "Remove all authorizations" action revokes that one service
  from every workspace at once (it is per-service, not global).

  File-sharing grants (WebDAV access to specific paths) are shown in a separate
  panel below the services. Each workspace card lists its access level(s) --
  "read" and/or "read and write" -- and the actual shared paths appear in the
  chip's tooltip. Revoking a workspace's file sharing removes every shared-path
  grant for that workspace; the panel's "Remove all authorizations" does so for
  every workspace. Only the file-sharing rules are removed -- unrelated
  permissions on the shared internal scope are left intact.
  These settings live at the app level because the app, not any single
  workspace, owns permissions.

  The Error reporting subsection hosts the per-machine error-reporting toggles
  (the same settings the first-launch consent screen records). These are global
  to the machine, not account-scoped.
#}
{% set _scripts %}
<script>
  (function () {
    // -- Left-nav subsection switching -----------------------------------
    var navButtons = document.querySelectorAll('[data-settings-nav]');
    var panels = document.querySelectorAll('[data-settings-panel]');
    function selectSection(name) {
      navButtons.forEach(function (btn) {
        var isActive = btn.getAttribute('data-settings-nav') === name;
        btn.classList.toggle('bg-fill-hover', isActive);
        btn.classList.toggle('text-primary', isActive);
        btn.classList.toggle('text-secondary', !isActive);
      });
      panels.forEach(function (panel) {
        panel.classList.toggle('hidden', panel.getAttribute('data-settings-panel') !== name);
      });
    }
    navButtons.forEach(function (btn) {
      btn.addEventListener('click', function () {
        selectSection(btn.getAttribute('data-settings-nav'));
      });
    });

    // -- Error reporting toggles -----------------------------------------
    var reportToggle = document.getElementById('report-errors-toggle');
    var logsRow = document.getElementById('include-logs-row');
    var logsToggle = document.getElementById('include-logs-toggle');

    function syncLogsVisibility() {
      if (reportToggle.checked) {
        logsRow.classList.remove('hidden');
      } else {
        logsRow.classList.add('hidden');
      }
    }
    syncLogsVisibility();

    function saveErrorReporting(payload) {
      return fetch('/_chrome/error-reporting', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
    }

    reportToggle.addEventListener('change', function () {
      var enabled = reportToggle.checked;
      var payload = { report_unexpected_errors: enabled };
      if (!enabled) {
        logsToggle.checked = false;
        payload.include_logs = false;
      }
      syncLogsVisibility();
      saveErrorReporting(payload);
    });

    logsToggle.addEventListener('change', function () {
      saveErrorReporting({ include_logs: logsToggle.checked });
    });

    // -- Permission revocation -------------------------------------------
    var revokeDialog = document.getElementById('revoke-dialog');
    var revokeTitle = document.getElementById('revoke-dialog-title');
    var revokeBody = document.getElementById('revoke-dialog-body');
    var revokeCancelBtn = document.getElementById('revoke-cancel-btn');
    var revokeConfirmBtn = document.getElementById('revoke-confirm-btn');
    var revokeErrorEl = document.getElementById('revoke-error');
    var pendingRevoke = null;

    function openRevokeDialog(title, body, request) {
      pendingRevoke = request;
      revokeTitle.textContent = title;
      revokeBody.textContent = body;
      if (revokeErrorEl) revokeErrorEl.classList.add('hidden');
      revokeConfirmBtn.disabled = false;
      revokeDialog.classList.remove('hidden');
    }
    function closeRevokeDialog() {
      pendingRevoke = null;
      revokeDialog.classList.add('hidden');
    }
    if (revokeDialog) {
      revokeCancelBtn.addEventListener('click', closeRevokeDialog);
      revokeDialog.addEventListener('click', function (e) {
        if (e.target === revokeDialog) closeRevokeDialog();
      });
      revokeConfirmBtn.addEventListener('click', function () {
        if (!pendingRevoke) return;
        revokeConfirmBtn.disabled = true;
        fetch(pendingRevoke.url, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(pendingRevoke.body),
        })
          .then(function (resp) {
            if (resp.ok) {
              window.location.reload();
              return;
            }
            revokeConfirmBtn.disabled = false;
            if (revokeErrorEl) {
              revokeErrorEl.textContent = 'Could not revoke (HTTP ' + resp.status + ')';
              revokeErrorEl.classList.remove('hidden');
            }
          })
          .catch(function () {
            revokeConfirmBtn.disabled = false;
            if (revokeErrorEl) {
              revokeErrorEl.textContent = 'Could not revoke (network error)';
              revokeErrorEl.classList.remove('hidden');
            }
          });
      });
    }

    document.querySelectorAll('.revoke-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var serviceSection = btn.closest('[data-service-name]');
        var card = btn.closest('[data-workspace-agent-id]');
        var serviceLabel = serviceSection.getAttribute('data-service-label');
        var workspaceName = card.getAttribute('data-workspace-name');
        openRevokeDialog(
          'Revoke ' + serviceLabel + ' access?',
          'This removes ' + workspaceName + "'s " + serviceLabel + ' permissions. The agent can request them again later.',
          {
            url: '/settings/permissions/revoke',
            body: {
              workspace_agent_id: card.getAttribute('data-workspace-agent-id'),
              service_name: serviceSection.getAttribute('data-service-name'),
            },
          }
        );
      });
    });

    document.querySelectorAll('.remove-all-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var serviceSection = btn.closest('[data-service-name]');
        var serviceLabel = serviceSection.getAttribute('data-service-label');
        openRevokeDialog(
          'Remove all ' + serviceLabel + ' authorizations?',
          'This removes ' + serviceLabel + ' permissions from every workspace. Agents can request them again later.',
          {
            url: '/settings/permissions/revoke-all',
            body: { service_name: serviceSection.getAttribute('data-service-name') },
          }
        );
      });
    });

    // File-sharing revocation (own section, own endpoints; no service name).
    document.querySelectorAll('.revoke-fs-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var card = btn.closest('[data-workspace-agent-id]');
        var workspaceName = card.getAttribute('data-workspace-name');
        openRevokeDialog(
          'Revoke file sharing?',
          'This removes ' + workspaceName + "'s shared file access. The agent can request it again later.",
          {
            url: '/settings/permissions/file-sharing/revoke',
            body: { workspace_agent_id: card.getAttribute('data-workspace-agent-id') },
          }
        );
      });
    });

    document.querySelectorAll('.remove-all-fs-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        openRevokeDialog(
          'Remove all file sharing?',
          'This removes shared file access from every workspace. Agents can request it again later.',
          { url: '/settings/permissions/file-sharing/revoke-all', body: {} }
        );
      });
    });
  })();
</script>
{% endset %}
<Base title="Settings" scripts={{ _scripts }}>
  <div class="max-w-[960px] mx-auto px-6 py-12">
    <h1 class="type-heading text-primary mb-6">Settings</h1>
    <div class="flex gap-8 items-start">
      {# Left nav #}
      {# Both entries share identical base classes (notably no ``bg-transparent``,
         which would beat the toggled-on ``bg-fill-hover`` and leave the active
         entry un-highlighted); ``selectSection`` in the page script drives the
         active state on both by toggling ``bg-fill-hover`` / ``text-primary`` /
         ``text-secondary``. Permissions starts active. #}
      <nav class="w-48 shrink-0 flex flex-col gap-0.5" aria-label="Settings sections">
        <button type="button" data-settings-nav="permissions"
                class="flex items-center h-8 px-2 rounded-md cursor-pointer type-body text-left border-0 hover:text-primary hover:bg-fill-hover bg-fill-hover text-primary">
          Permissions
        </button>
        <button type="button" data-settings-nav="error-reporting"
                class="flex items-center h-8 px-2 rounded-md cursor-pointer type-body text-left border-0 hover:text-primary hover:bg-fill-hover text-secondary">
          Error reporting
        </button>
      </nav>

      {# Right content #}
      <div class="flex-1 min-w-0">
        {# -- Permissions panel -- #}
        <section data-settings-panel="permissions">
          <h2 class="type-heading text-primary mb-2">Permissions</h2>
          <p class="type-helper text-tertiary mb-6">
            Third-party service access your agents have been granted, across all workspaces.
            Revoking removes the permission; your saved sign-in is kept, and agents can ask again later.
          </p>

          {% if permissions_unavailable %}
            <Notice variant="warn">
              Permissions can't be loaded right now because the latchkey gateway is unavailable.
              Try again in a moment.
            </Notice>
          {% elif services_overview or file_sharing_grants %}
            <div class="flex flex-col gap-6">
              {% for service in services_overview %}
                {% set ws_count = service.workspace_grants | length %}
                <div class="border border-subtle rounded-lg overflow-hidden"
                     data-service-name="{{ service.service_name }}" data-service-label="{{ service.display_name }}">
                  <div class="flex items-center justify-between gap-3 px-4 py-3 bg-fill-subtle border-b border-subtle">
                    <h3 class="type-body font-semibold text-primary">
                      {{ service.display_name }}
                      <span class="type-helper text-tertiary font-normal">&middot; {{ ws_count }} workspace{{ '' if ws_count == 1 else 's' }}</span>
                    </h3>
                    <Button variant="ghost" size="md"
                            class="remove-all-btn !text-important !border-important/40 hover:!bg-[var(--c-important-surface)]">Remove all authorizations</Button>
                  </div>
                  <div class="p-4">
                    <div class="grid grid-cols-2 gap-3">
                      {% for grant in service.workspace_grants %}
                        <div class="minds-card p-4 flex flex-col gap-3"
                             data-workspace-agent-id="{{ grant.workspace_agent_id }}"
                             data-workspace-name="{{ grant.workspace_name }}">
                          <div class="flex items-center gap-2">
                            <span class="w-2.5 h-2.5 rounded-full shrink-0" style="background-color: {{ grant.color }}"></span>
                            <span class="type-body font-semibold text-primary truncate">{{ grant.workspace_name }}</span>
                          </div>
                          <div>
                            <p class="type-helper text-tertiary mb-1">Allowed</p>
                            <div class="flex flex-wrap gap-1">
                              {% for perm in grant.permissions %}
                                <code class="code-pill"{% if perm.description %} data-tooltip="{{ perm.description }}"{% endif %}>{{ perm.label }}</code>
                              {% endfor %}
                            </div>
                          </div>
                          <div class="mt-auto">
                            <Button variant="secondary" size="md" class="revoke-btn">Revoke</Button>
                          </div>
                        </div>
                      {% endfor %}
                    </div>
                  </div>
                </div>
              {% endfor %}

              {% if file_sharing_grants %}
                {% set fs_count = file_sharing_grants | length %}
                <div class="border border-subtle rounded-lg overflow-hidden" data-file-sharing="true">
                  <div class="flex items-center justify-between gap-3 px-4 py-3 bg-fill-subtle border-b border-subtle">
                    <h3 class="type-body font-semibold text-primary">
                      File sharing
                      <span class="type-helper text-tertiary font-normal">&middot; {{ fs_count }} workspace{{ '' if fs_count == 1 else 's' }}</span>
                    </h3>
                    <Button variant="ghost" size="md"
                            class="remove-all-fs-btn !text-important !border-important/40 hover:!bg-[var(--c-important-surface)]">Remove all authorizations</Button>
                  </div>
                  <div class="p-4">
                    <div class="grid grid-cols-2 gap-3">
                      {% for grant in file_sharing_grants %}
                        <div class="minds-card p-4 flex flex-col gap-3"
                             data-workspace-agent-id="{{ grant.workspace_agent_id }}"
                             data-workspace-name="{{ grant.workspace_name }}">
                          <div class="flex items-center gap-2">
                            <span class="w-2.5 h-2.5 rounded-full shrink-0" style="background-color: {{ grant.color }}"></span>
                            <span class="type-body font-semibold text-primary truncate">{{ grant.workspace_name }}</span>
                          </div>
                          <div>
                            <p class="type-helper text-tertiary mb-1">Allowed</p>
                            <div class="flex flex-wrap gap-1">
                              {% for perm in grant.permissions %}
                                <code class="code-pill"{% if perm.description %} data-tooltip="{{ perm.description }}"{% endif %}>{{ perm.label }}</code>
                              {% endfor %}
                            </div>
                          </div>
                          <div class="mt-auto">
                            <Button variant="secondary" size="md" class="revoke-fs-btn">Revoke</Button>
                          </div>
                        </div>
                      {% endfor %}
                    </div>
                  </div>
                </div>
              {% endif %}
            </div>
          {% else %}
            <Notice variant="info">
              No permissions have been granted yet.
            </Notice>
          {% endif %}
        </section>

        {# -- Error reporting panel -- #}
        <section data-settings-panel="error-reporting" class="hidden">
          <h2 class="type-heading text-primary mb-2">Error reporting</h2>
          <p class="type-helper text-tertiary mb-3">Applies to this device, regardless of which account is signed in.</p>
          <label class="flex items-start justify-between gap-3 py-3 border-b border-subtle cursor-pointer">
            <span>
              <span class="type-body text-primary font-semibold">Report unexpected errors</span>
              <span class="block type-helper text-tertiary">Send a report to Imbue when something goes wrong.</span>
            </span>
            <input type="checkbox" id="report-errors-toggle" class="mt-1 shrink-0"
                   {% if report_unexpected_errors %}checked{% endif %}>
          </label>
          <label id="include-logs-row"
                 class="flex items-start justify-between gap-3 py-3 border-b border-subtle cursor-pointer {% if not report_unexpected_errors %}hidden{% endif %}">
            <span>
              <span class="type-body text-primary font-semibold">Include logs</span>
              <span class="block type-helper text-tertiary">Attach recent log files to help diagnose the problem.</span>
            </span>
            <input type="checkbox" id="include-logs-toggle" class="mt-1 shrink-0"
                   {% if include_error_logs %}checked{% endif %}>
          </label>
        </section>
      </div>
    </div>

    <div class="mt-8"><Link href="/" extra="type-helper">&larr; Back to workspaces</Link></div>
  </div>

  <Modal id="revoke-dialog" card_extra="text-left">
    <h2 id="revoke-dialog-title" class="type-heading text-primary mb-3">Revoke access?</h2>
    <p id="revoke-dialog-body" class="type-body text-primary mb-4"></p>
    <p id="revoke-error" class="hidden type-body text-important mb-3" role="alert"></p>
    <div class="flex justify-end gap-3">
      <Button variant="secondary" id="revoke-cancel-btn">Cancel</Button>
      <Button variant="danger" id="revoke-confirm-btn">Revoke</Button>
    </div>
  </Modal>
</Base>
