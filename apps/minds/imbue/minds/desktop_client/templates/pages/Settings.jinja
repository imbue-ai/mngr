{#def boot_state #}
{#
  App-level ("Minds") settings as a full page: the browser-mode fallback for
  the centered settings modal (pages.SettingsModal). The whole body is the
  mithril settings surface (frontend/src/views/AppSettings.ts), mounted from
  the ``settings`` island slice: Connectors, Local files, Workspace
  delegation, Error reporting, and Master password -- all per-machine /
  app-level settings (the app, not any single workspace, owns permissions).
#}
{% set _scripts %}
<script>
  window.MindsUI.mountSettingsPage(document.getElementById('settings-root'));
</script>
{% endset %}
<ChromeShell title="Settings" page_label="Settings" :show_back="True" :boot_state="boot_state" scripts={{ _scripts }}>
  <PageContainer>
    <div id="settings-root"></div>
  </PageContainer>
</ChromeShell>
