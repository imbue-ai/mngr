{#def report_unexpected_errors=false, include_error_logs=false, has_saved_backup_password=false, dark_mode=false, region_options=[], region_selected="", app_version="" #}
{#
  App-level ("Minds") settings as a full page: the browser-mode fallback for
  the centered settings modal (pages.SettingsModal) the Electron shell shows.
  Both render the same shared sections (templates/SettingsSections.jinja):
  Appearance (dark mode), Error reporting, Account default region, Backup
  password, and About -- all per-machine device settings.

  Connector / permission management is per-workspace now and lives on each
  workspace's Connections view, not here.
#}
{% set _scripts %}
<script src="/_static/app_settings.js" defer></script>
{% endset %}
<Base title="Settings" scripts={{ _scripts }}>
  <PageContainer>
    <h1 class="type-heading-lg text-primary mb-6">Settings</h1>
    <SettingsSections
      :report_unexpected_errors="report_unexpected_errors"
      :include_error_logs="include_error_logs"
      :has_saved_backup_password="has_saved_backup_password"
      :dark_mode="dark_mode"
      :region_options="region_options"
      :region_selected="region_selected"
      :app_version="app_version" />
  </PageContainer>
</Base>
