{#def agent_id, request_id, ws_name, rationale, display_name, scope, permission_schemas, description_by_permission_name, checked_permissions, accent, will_open_browser, mngr_forward_origin #}
{#
  Latchkey predefined permission request dialog. Composes the
  Permissions* components; provides the per-permission simple/editor
  views and the auth-browser progress notice.

  The simple (default) view is a read-only summary of the permissions
  that will be granted on Approve. The editor view (hidden by default)
  is a checkbox per detent permission schema. Both views share the same
  underlying checkbox inputs (the editor div is merely hidden) so the
  generic submit handler can read the checked set in either view.
#}
{% set _extra_scripts %}
<script>
  // Reveal the checkbox editor and hide the simple summary. The Approve
  // button's enabled state is driven by the generic handler's
  // updateApproveState (it watches the checkbox inputs), so no extra
  // wiring is needed here.
  window.showPermissionEditor = function () {
    var simple = document.getElementById("permissions-simple-view");
    var editor = document.getElementById("permissions-editor-view");
    if (simple) simple.classList.add("hidden");
    if (editor) editor.classList.remove("hidden");
  };
</script>
{% endset %}
<PermissionsDialog :display_name="display_name" :accent="accent" extra_scripts={{ _extra_scripts }}>
  <PermissionsHeader :display_name="display_name" :ws_name="ws_name" :agent_id="agent_id" :rationale="rationale" />

  <PermissionsForm :request_id="request_id">
    {# Simple (default) view: a read-only summary of the permissions that
       will be granted on Approve, with no checkboxes. The full checkbox
       editor is hidden behind the "Adjust" link below. #}
    <div id="permissions-simple-view">
      {% if checked_permissions %}
        <p class="text-sm text-zinc-700 mb-3">
          Approving will grant {{ ws_name or agent_id }} and its sibling agents the following permissions:
        </p>
        <Card extra="space-y-3">
          {% for permission in permission_schemas %}
            {% if permission in checked_permissions %}
              <div>
                {# Checkmark and the permission name share one items-center
                   row so the icon is vertically centered on the name. Any
                   description sits below, indented to line up under the
                   name (icon width + gap = 26px). #}
                <div class="flex items-center gap-2.5">
                  <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"
                       class="w-4 h-4 shrink-0 text-emerald-600">
                    <path fill-rule="evenodd" clip-rule="evenodd"
                          d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 1 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" />
                  </svg>
                  <code class="text-sm font-mono text-zinc-900">{{ permission }}</code>
                </div>
                {% set permission_description = description_by_permission_name.get(permission) %}
                {% if permission_description %}
                  <span class="block text-sm text-zinc-700 mt-0.5 ml-[26px]">{{ permission_description }}</span>
                {% endif %}
              </div>
            {% endif %}
          {% endfor %}
          {# Right-aligned within the list card so it reads as a secondary
             affordance rather than another permission row. A faint top
             border separates it from the permission list above. #}
          <div class="flex justify-end border-t border-zinc-100 pt-2">
            <Button variant="ghost" id="permissions-adjust-link"
                    onclick="showPermissionEditor()"
                    extra="!p-0 !bg-transparent !text-xs !font-normal !text-blue-600 hover:!bg-transparent hover:underline hover:!text-blue-700">
              Adjust
            </Button>
          </div>
        </Card>
      {% else %}
        <Notice variant="warn">
          The agent did not request any specific permissions. Click
          <span class="font-medium">Adjust</span> below to choose what to grant.
        </Notice>
        <div class="flex justify-end mt-3">
          <Button variant="ghost" id="permissions-adjust-link"
                  onclick="showPermissionEditor()"
                  extra="!p-0 !bg-transparent !text-xs !font-normal !text-blue-600 hover:!bg-transparent hover:underline hover:!text-blue-700">
            Adjust
          </Button>
        </div>
      {% endif %}
    </div>

    {# Editor view: the full checkbox list, hidden until the user opts in
       via "Adjust". The inputs are present in the DOM either way so the
       generic submit handler can read the checked set. #}
    <div id="permissions-editor-view" class="hidden">
      <h2 class="text-sm font-medium text-zinc-700 mb-2">Permissions to grant:</h2>
      <Card extra="space-y-3">
        {% for permission in permission_schemas %}
          <label class="flex items-start gap-2.5 cursor-pointer">
            <input type="checkbox" name="permissions" value="{{ permission }}"
                   class="mt-1 shrink-0"
                   {% if permission in checked_permissions %}checked{% endif %}>
            <span class="min-w-0">
              <code class="text-sm font-mono text-zinc-900">{{ permission }}</code>
              {% set permission_description = description_by_permission_name.get(permission) %}
              {% if permission_description %}
                <span class="block text-sm text-zinc-700 mt-0.5">{{ permission_description }}</span>
              {% endif %}
            </span>
          </label>
        {% endfor %}
      </Card>
    </div>
  </PermissionsForm>

  {#
    The progress notice copy depends on whether ``latchkey auth browser``
    will actually run when the user clicks Approve. ``will_open_browser``
    is computed server-side from a fresh ``latchkey services info`` call,
    so when credentials are already valid (or the service requires manual
    credentials) we show a generic "Granting permission..." notice instead
    of falsely promising a browser pop-up.
  #}
  <div id="permissions-progress" class="hidden mt-4">
    <Notice variant="info">
      {% if will_open_browser %}
        <span class="font-medium">Authenticating...</span>
        Latchkey is opening a browser window for you to sign in to {{ display_name }}.
        This dialog will close automatically when the flow completes.
      {% else %}
        <span class="font-medium">Granting permission...</span>
      {% endif %}
    </Notice>
  </div>

  <PermissionsManualCredentials />
  <PermissionsError />
</PermissionsDialog>
