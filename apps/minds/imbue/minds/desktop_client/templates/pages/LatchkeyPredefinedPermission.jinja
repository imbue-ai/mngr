{#def agent_id, request_id, ws_name, rationale, display_name, scope, permission_schemas, description_by_permission_name, checked_permissions, accent, will_open_browser, mngr_forward_origin #}
{#
  Latchkey predefined permission request standalone page. Wraps the
  shared body component in the full PermissionsDialog chrome (Base
  plus backdrop plus submit/Escape JS) so the page can be loaded
  directly at /requests/{id}. The inbox modal embeds the body
  component directly.
#}
<PermissionsDialog :display_name="display_name" :accent="accent">
  <LatchkeyPredefinedPermissionBody
    :agent_id="agent_id"
    :request_id="request_id"
    :ws_name="ws_name"
    :rationale="rationale"
    :display_name="display_name"
    :scope="scope"
    :permission_schemas="permission_schemas"
    :description_by_permission_name="description_by_permission_name"
    :checked_permissions="checked_permissions"
    :will_open_browser="will_open_browser" />
</PermissionsDialog>
