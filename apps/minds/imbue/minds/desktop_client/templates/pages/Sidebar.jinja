{#def mngr_forward_origin #}
{#
  Standalone sidebar page served into the Electron sidebar WebContentsView.
  Same SSE subscription as the chrome-embedded sidebar but stripped down
  (no titlebar/iframe). All interactivity in /_static/sidebar.js.

  mngr_forward_origin is exposed via data-mngr-forward-origin so sidebar.js
  can build the cross-origin /goto/<agent>/ URL the plugin serves.
#}
{% set _body_attrs %}data-mngr-forward-origin="{{ mngr_forward_origin }}"{% endset %}
{% set _scripts %}
<script src="/_static/sidebar.js" defer></script>
{% endset %}
<Base title="Projects"
      body_class="bg-zinc-900 font-sans antialiased overflow-y-auto"
      body_attrs={{ _body_attrs }}
      scripts={{ _scripts }}>
  <h2 class="text-sm text-zinc-200 p-3 m-0 border-b border-white/10 font-medium">Projects</h2>
  <div id="sidebar-workspaces">
    <div class="px-4 py-6 text-sm text-zinc-400 text-center">No projects</div>
  </div>
</Base>
