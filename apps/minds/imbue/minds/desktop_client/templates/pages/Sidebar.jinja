{#def mngr_forward_origin #}
{#
  Standalone sidebar page served into the Electron sidebar WebContentsView.
  Acts as a modal: the WebContentsView covers the full content area, the
  body is the transparent backdrop, and the floating dark teal panel is
  pinned to the top-left. Clicks on the backdrop (anywhere outside the
  panel) and the Escape key close the sidebar via /_static/sidebar.js.
  The panel's height comes from its own flex content -- no JS measurement
  or Electron-side bounds math is needed.

  mngr_forward_origin is exposed via data-mngr-forward-origin so sidebar.js
  can build the cross-origin /goto/<agent>/ URL the plugin serves.
#}
{% set _body_attrs %}data-mngr-forward-origin="{{ mngr_forward_origin }}"{% endset %}
{% set _scripts %}
<script src="/_static/workspace_accent.js" defer></script>
<script src="/_static/sidebar_workspace_row.js" defer></script>
<script src="/_static/sidebar.js" defer></script>
{% endset %}
<Base title="Projects"
      body_class="font-sans antialiased bg-transparent"
      body_attrs={{ _body_attrs }}
      scripts={{ _scripts }}>
  <div id="sidebar-backdrop" class="fixed inset-0">
    <div id="sidebar-menu"
         class="absolute top-2 left-2 w-[244px] flex flex-col gap-px p-1.5 rounded-[10px] border border-white/10 bg-[#0b292b] shadow-[0_12px_32px_rgba(0,0,0,0.25)] overflow-hidden">
      <div id="sidebar-workspaces" class="flex flex-col gap-px">
        <div class="px-2 py-2 text-xs text-zinc-400 text-center">No projects</div>
      </div>
      <SidebarBottom />
    </div>
  </div>
</Base>
