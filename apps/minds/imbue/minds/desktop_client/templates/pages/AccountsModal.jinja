{#def boot_state #}
{#
  Centered "Manage Accounts" modal page, hosted in the desktop client's
  shared modal WebContentsView (or the browser ModalHost iframe). Opened
  from the home screen's bottom-left account launcher and the workspace
  switcher's account entry; the full page (GET /accounts) remains as the
  browser-mode fallback. The body is the mithril accounts surface
  (frontend/src/views/AccountsPage.ts, modal variant): actions POST the
  existing routes via fetch + reload (never following their redirect inside
  the modal iframe), and "Add account" / "Sign in again" swap the overlay to
  the sign-in modal through the host adapter.
#}
{% set _scripts %}
<script>
  window.MindsUI.mountAccountsModal(document.getElementById('accounts-modal-root'));
</script>
{% endset %}
<OverlaySurface title="Manage Accounts"
                body_style="-webkit-app-region: no-drag;"
                :boot_state="boot_state"
                scripts={{ _scripts }}>
  <div id="accounts-modal-root"></div>
</OverlaySurface>
