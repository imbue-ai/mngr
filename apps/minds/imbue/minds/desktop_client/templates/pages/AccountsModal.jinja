{#def accounts, default_account_id, enabled_by_user_id #}
{#
  Centered "Manage Accounts" modal page, hosted in the desktop client's
  shared modal WebContentsView. Opened from the home screen's bottom-left
  account launcher and the workspace switcher's account entry. The full-page
  twin (pages.Accounts) remains as the browser-mode fallback.

  Account actions reuse the existing POST routes (/accounts/set-default,
  /accounts/<id>/logout) via fetch + a reload of this page, so the redirect
  those routes answer with never navigates the modal iframe to the full page.
  "Add account" / "Sign in again" swap the overlay to the sign-in modal.

  ``enabled_by_user_id`` maps each account's user_id to whether its
  ``[providers.imbue_cloud_<slug>]`` block is enabled in settings.toml; a
  "Signed out" indicator surfaces when the session exists but the block was
  disabled via the providers panel.
#}
{% set _scripts %}
<script>
  (function () {
    window.dismissAccountsModal = function () {
      if (window.minds && window.minds.closeModal) window.minds.closeModal();
      else window.location.href = "/";
    };
    var backdrop = document.getElementById("accounts-modal-backdrop");
    if (backdrop) {
      backdrop.addEventListener("click", function (e) {
        if (e.target === backdrop) window.dismissAccountsModal();
      });
    }

    // Set-default / log-out POST via fetch, then re-render this modal page so
    // the list reflects the new state. The routes answer with a redirect to
    // the full accounts page; following it inside the modal iframe would
    // strand the full page in the overlay, so the response body is ignored.
    function postThenReload(url, body) {
      fetch(url, {
        method: "POST",
        credentials: "same-origin",
        headers: { "Content-Type": "application/x-www-form-urlencoded" },
        body: body || "",
      }).then(function () { window.location.reload(); }).catch(function () { window.location.reload(); });
    }
    document.querySelectorAll("[data-set-default]").forEach(function (btn) {
      btn.addEventListener("click", function () {
        postThenReload("/accounts/set-default", "user_id=" + encodeURIComponent(btn.getAttribute("data-set-default")));
      });
    });
    document.querySelectorAll("[data-logout]").forEach(function (btn) {
      btn.addEventListener("click", function () {
        postThenReload("/accounts/" + encodeURIComponent(btn.getAttribute("data-logout")) + "/logout");
      });
    });

    // Swap the overlay to the sign-in modal; after a successful sign-in it
    // lands the content view on home, where the account launcher reflects
    // the new account.
    window.openAddAccount = function () {
      if (window.minds && window.minds.openSigninModal) window.minds.openSigninModal("/");
      else window.location.href = "/auth/login";
    };
  })();
</script>
{% endset %}
<Base title="Manage Accounts"
      body_class="bg-transparent text-primary font-sans antialiased"
      body_style="-webkit-app-region: no-drag;"
      scripts={{ _scripts }}>
  <div id="accounts-modal-backdrop" class="fixed inset-0 flex items-center justify-center bg-surface-overlay p-4">
    <div class="relative bg-surface-primary rounded-lg shadow-overlay max-w-lg w-full p-8 max-h-[85vh] overflow-y-auto text-left">
      <DialogCloseButton onclick="dismissAccountsModal()" />
      <h1 class="type-heading-lg text-primary mb-6">Manage Accounts</h1>

      {% if accounts %}
        <div class="flex flex-col gap-2">
        {% for acct in accounts %}
          {% set acct_enabled = enabled_by_user_id.get(acct.user_id | string, True) %}
          <Card layout="row-spread">
            <div>
              <div class="font-semibold">
                {{ acct.email }}
                {% if not acct_enabled %}
                  <StatusBadge variant="warn" size="xs" extra="ml-2" title="Session was rejected by the server. Sign in again to re-enable.">Signed out</StatusBadge>
                {% endif %}
              </div>
              <div class="type-helper text-tertiary">
                {{ acct.workspace_ids | length }} workspace(s)
                {% if acct.user_id | string == default_account_id %} &middot; Default{% endif %}
              </div>
            </div>
            <div class="flex gap-2">
              {% if not acct_enabled %}
                <Button variant="primary" onclick="openAddAccount()">Sign in again</Button>
              {% endif %}
              {% if acct.user_id | string != default_account_id %}
                <Button variant="secondary" :data-set-default="acct.user_id">Set default</Button>
              {% else %}
                <span class="inline-flex items-center justify-center px-3 py-2 rounded-md type-label bg-fill-subtle text-primary border border-default opacity-60 cursor-default">Default</span>
              {% endif %}
              <Button variant="danger" :data-logout="acct.user_id">Log out</Button>
            </div>
          </Card>
        {% endfor %}
        </div>
      {% else %}
        <p class="text-secondary">No accounts logged in.</p>
      {% endif %}

      <div class="mt-4">
        <Button variant="primary" onclick="openAddAccount()">Add account</Button>
      </div>
    </div>
  </div>
</Base>
