{#def boot_state #}
{#
  Workspace creation form. The whole body is the mithril CreateFormPage
  component (frontend/src/views/CreateFormPage.ts), mounted from the
  ``create`` island slice: the two-preset simple view, the advanced
  provider/region/repository controls (always the submit source of truth),
  live host-name validation against /api/v1/desktop/host-name-available,
  the account-picker guard (sign-in modal through the host adapter for
  signed-out users), and the JS submission to POST /api/v1/workspaces with
  normalized API-error display.
#}
{% set _scripts %}
<script src="/_static/sync_status_banner.js" defer></script>
<script>
  window.MindsUI.mountCreateForm(document.getElementById('create-root'));
</script>
{% endset %}
<PageNarrowContainer title="Create a workspace" page_label="New workspace" padding="form" max_width="max-w-[720px]" scripts={{ _scripts }} :boot_state="boot_state">
  <div id="create-root"></div>
</PageNarrowContainer>
