{#def boot_state #}
{#
  Centered "Minds Settings" modal page, hosted in the desktop client's shared
  modal WebContentsView (or the browser ModalHost iframe) so it covers the
  whole window including the title bar. Opened from the home screen's
  bottom-left "Minds Settings" launcher and the workspace switcher's "Minds
  Settings" entry. The body is the mithril settings surface
  (frontend/src/views/AppSettings.ts, modal variant): same sections as the
  full /settings page, no "back to workspaces" link -- the X and a backdrop
  click dismiss through the host adapter; Escape is handled by the Electron
  main process for any modal-view page.
#}
{% set _scripts %}
<script>
  window.MindsUI.mountSettingsModal(document.getElementById('settings-modal-root'));
</script>
{% endset %}
<OverlaySurface title="Minds Settings"
                body_style="-webkit-app-region: no-drag;"
                :boot_state="boot_state"
                scripts={{ _scripts }}>
  <div id="settings-modal-root"></div>
</OverlaySurface>
