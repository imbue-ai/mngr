{#def boot_state, detail_html="", is_empty=False #}
{#
  Inbox modal page. Hosts:
    - Transparent body + dim backdrop (so the desktop client modal view
      reveals the workspace behind the inbox).
    - Master/detail layout: the left pane (#inbox-left-column) is the
      mithril InboxList component, mounted from the boot island and fed by
      the chrome ``requests`` payload's card summaries; the right detail
      pane (#inbox-detail) stays a server-rendered fragment swapped by the
      component's detail fetches.
    - The inline script that owns the server fragment's form logic:
      Approve gating, share-path pickers, grant/deny submission, and
      escape/backdrop dismissal.

  ``boot_state`` is the page's #minds-boot-state island dict: the chrome
  snapshot under ``chrome`` (its ``requests.cards`` is the initial list)
  plus the ``inbox`` extras (initially-selected id, keep-open semantics).
  ``detail_html`` is the pre-rendered right-pane HTML (a handler fragment,
  the "no longer available" fragment, or an empty placeholder). ``is_empty``
  is True when there are no pending requests; it sets the pre-mount
  collapsed layout (the component re-syncs the class after every render).
#}
{% set _head %}
  <style>
    .inbox-card {
      padding: 10px 12px;
      cursor: pointer;
      border-left: 3px solid transparent;
    }
    .inbox-card:hover { background: rgba(0, 0, 0, 0.04); }
    .inbox-card.is-selected {
      background: rgba(0, 0, 0, 0.06);
      border-left-color: var(--workspace-accent, #94a3b8);
    }
    /* While a deny POST is in flight (it's fire-and-forget so the user
       doesn't wait for the mngr message round trip) the card stays in
       the list until the server appends the response event and the
       chrome SSE pushes the new pending set. Visually mark it so the
       user doesn't think the dialog reappeared on its own, and disable
       hover / clicks so it can't be re-selected. */
    .inbox-card.is-denying {
      opacity: 0.6;
      pointer-events: none;
    }
    .inbox-card.is-denying .inbox-card-display::after {
      content: " (denying...)";
      color: #94a3b8;
      font-weight: normal;
      font-style: italic;
    }
    .inbox-card-kind {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: #64748b;
    }
    .inbox-card-display {
      font-size: 13px;
      color: #18181b;
      font-weight: 500;
      margin-top: 2px;
    }
    .inbox-empty-placeholder {
      padding: 32px 16px;
      text-align: center;
      color: #64748b;
      font-size: 13px;
    }
    /* Drawer in-animation: small slide from the left edge (-15px
       past the final position, slides right into place) plus a fade.
       Backdrop scrim fades in alongside it on the same timing. Runs
       once per inbox open (the modal view loads a fresh /inbox page
       each time, so the animation re-runs naturally). */
    @keyframes inbox-slide-in {
      from { transform: translateX(-15px); opacity: 0; }
      to   { transform: translateX(0);     opacity: 1; }
    }
    #inbox-dialog { animation: inbox-slide-in 180ms cubic-bezier(0, 0.55, 0.45, 1); }
    @keyframes inbox-backdrop-fade-in {
      from { background-color: rgba(0, 0, 0, 0); }
      to   { background-color: rgba(0, 0, 0, 0.2); }
    }
    #inbox-backdrop { animation: inbox-backdrop-fade-in 180ms cubic-bezier(0, 0.55, 0.45, 1); }
    /* When the body has no cards, the left column expands to fill the
       dialog and the right pane is hidden so the empty state reads as
       a single centered message rather than a half-empty split. The
       auto-open footer stays left-aligned in both states. */
    #inbox-body.is-empty #inbox-detail { display: none; }
    #inbox-body.is-empty #inbox-left-column {
      flex: 1 1 auto;
      width: auto;
      border-right: none;
    }
    #inbox-body.is-empty #inbox-list {
      display: flex;
      align-items: center;
      justify-content: center;
    }
  </style>
{% endset %}
{% set _scripts %}
<script type="application/json" id="minds-boot-state">{{ boot_state | tojson }}</script>
<script>
  (function () {
    var inboxDetail = document.getElementById("inbox-detail");

    // The Adjust toggle (predefined-permission "simple vs editor" view)
    // is the only per-handler script we used to inject; with no per-handler
    // scripts in the inbox shell, it lives here as a global so the
    // fragment's onclick=showPermissionEditor() still works after swap.
    window.showPermissionEditor = function () {
      var simple = document.getElementById("permissions-simple-view");
      var editor = document.getElementById("permissions-editor-view");
      if (simple) simple.classList.add("hidden");
      if (editor) editor.classList.remove("hidden");
    };

    // Approve becomes available as soon as any name="permissions" input
    // is checked. Re-run after every right-pane swap and on checkbox
    // change (via the delegated handler below).
    // Parse the WebDAV mount roots the file-sharing dialog embeds on its
    // path input (a JSON array of absolute paths). Returns [] when absent
    // or malformed.
    function sharePathRoots(input) {
      try {
        var parsed = JSON.parse(input.getAttribute("data-allowed-roots") || "[]");
        return Array.isArray(parsed) ? parsed : [];
      } catch (e) {
        return [];
      }
    }

    // Expand a leading ``~`` / ``~/`` to the home directory the
    // file-sharing dialog embeds on its path input, mirroring the
    // server-side ``_expand_home_prefix``. A bare ``~`` or ``~/...``
    // expands; ``~user`` (another user's home) is left unchanged so the
    // within-roots check rejects it, matching the server. Returns the
    // value unchanged when there is no home dir or no ``~`` prefix.
    function expandSharePathHome(value, input) {
      var home = String(input.getAttribute("data-home-dir") || "");
      if (!home) return value;
      if (value === "~" || value.indexOf("~/") === 0) {
        return home + value.slice(1);
      }
      return value;
    }

    // Whether ``value`` is at or beneath one of ``roots``. Case-insensitive
    // and purely lexical, mirroring the server-side check (and WsgiDAV's
    // share-prefix matching).
    function isSharePathWithinRoots(value, roots) {
      if (!value) return false;
      var lower = value.toLowerCase();
      return roots.some(function (root) {
        var r = String(root).replace(/\/+$/, "").toLowerCase() || "/";
        return lower === r || lower.indexOf(r + "/") === 0;
      });
    }

    // The predefined-permission dialog offers a catch-all permission
    // (stored as ``any``, shown to users as ``all``) alongside the
    // specific permissions. While ``all`` is ticked, the specific
    // checkboxes are disabled (they keep their own checked/unchecked
    // state) to communicate that the catch-all already covers them;
    // unticking ``all`` re-enables them. The browser omits disabled
    // inputs from the submission, so only the active side is granted.
    // The wildcard checkbox is tagged with ``data-wildcard`` in the
    // template; dialogs without one (e.g. file-sharing) are left
    // untouched.
    function syncPermissionWildcardExclusivity() {
      var form = document.getElementById("permissions-form");
      if (!form) return;
      var wildcard = form.querySelector('input[name="permissions"][data-wildcard]');
      if (!wildcard) return;
      form.querySelectorAll('input[name="permissions"]').forEach(function (box) {
        if (box !== wildcard) box.disabled = wildcard.checked;
      });
    }

    function updateApproveState() {
      var form = document.getElementById("permissions-form");
      if (!form) return;
      var approveBtn = document.getElementById("permissions-approve-btn");
      if (!approveBtn) return;
      syncPermissionWildcardExclusivity();
      var anyChecked = form.querySelector('input[name="permissions"]:checked') !== null;
      // The file-sharing dialog adds an editable path field. Its hidden
      // "permissions" checkbox is always checked, so gate Approve on the
      // path being both non-empty AND inside a shared root -- otherwise
      // the user could approve a blank or unshareable path. A hint is
      // shown next to the field for a non-empty out-of-root path so the
      // feedback is instant (matching the server-side rejection) instead
      // of only surfacing after submit.
      var pathInput = document.getElementById("file-sharing-path-input");
      var pathOk = true;
      if (pathInput) {
        var value = expandSharePathHome(pathInput.value.trim(), pathInput);
        var withinRoots = isSharePathWithinRoots(value, sharePathRoots(pathInput));
        pathOk = value.length > 0 && withinRoots;
        var hint = document.getElementById("file-sharing-path-hint");
        if (hint) hint.classList.toggle("hidden", !(value.length > 0 && !withinRoots));
      }
      approveBtn.disabled = !(anyChecked && pathOk);
    }
    window.updateApproveState = updateApproveState;

    // The file-sharing dialog ships its "Choose file…" / "Choose folder…"
    // buttons hidden; reveal them only when the Electron native-picker
    // bridge is available (in a plain browser the user pastes a path into
    // the input instead). Idempotent: safe to call after every
    // detail-pane render.
    function wireSharePathControls() {
      if (!(window.minds && window.minds.showFilePicker)) return;
      ["file-sharing-browse-file-btn", "file-sharing-browse-folder-btn"].forEach(function (id) {
        var btn = document.getElementById(id);
        if (btn) btn.classList.remove("hidden");
      });
    }

    // Open the OS picker for the requested ``mode`` ('file' or
    // 'directory') and write the chosen absolute path back into the
    // share-path input. Defaults the dialog to the path already in the
    // field. A cancel (or any bridge error) leaves the field untouched.
    window.browseForSharePath = async function (mode) {
      var input = document.getElementById("file-sharing-path-input");
      if (!input || !(window.minds && window.minds.showFilePicker)) return;
      try {
        var selected = await window.minds.showFilePicker({
          defaultPath: input.value.trim(),
          mode: mode === "directory" ? "directory" : "file",
        });
        if (typeof selected === "string" && selected.length > 0) {
          input.value = selected;
          updateApproveState();
        }
      } catch (e) {
        /* user cancelled or the bridge errored -- keep the current path */
      }
    };

    // Mount the left pane (cards + auto-open footer). The handle is the
    // page's glue to selection state and post-resolution advancement; the
    // component swaps the right pane on selection and calls back here so
    // the freshly-inserted fragment gets its form logic wired.
    var inboxList = window.MindsUI.mountInboxList(document.getElementById("inbox-left-column"), {
      onDetailSwapped: function () {
        updateApproveState();
        wireSharePathControls();
      },
    });

    function closeInbox() {
      inboxList.close();
    }
    window.closeInbox = closeInbox;

    function onBackdropClick(event) {
      if (event.target && event.target.id === "inbox-backdrop") closeInbox();
    }
    window.onBackdropClick = onBackdropClick;

    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape") closeInbox();
    });

    // -- Approve / Deny submission --

    // Bring a just-revealed notification (progress / error / manual
    // credentials box) into view at the bottom of the detail pane.
    // Required because the form sits at the top of the right pane and
    // the notice that's shown after Approve lives below it -- on a
    // tall request fragment the notice would otherwise be scrolled
    // off-screen. Scrolls all the way to the bottom of the detail
    // pane so the notice + its trailing padding are both visible.
    function scrollDetailIntoView(el) {
      if (!el) return;
      try {
        inboxDetail.scrollTo({ top: inboxDetail.scrollHeight, behavior: "smooth" });
      } catch (e) {
        // Older browsers without scrollTo({ behavior }).
        inboxDetail.scrollTop = inboxDetail.scrollHeight;
      }
    }

    // Toggle the "an approval is running in the background" state. While
    // busy, BOTH buttons are disabled and the Approve label is swapped for
    // a spinner + "Approving...", so the user always has a clear signal
    // that work is underway (a browser sign-in, a follow-up grant, or any
    // other step that runs until the approval succeeds or fails) and
    // cannot double-submit or deny mid-flight. When cleared, Deny is
    // re-enabled, the spinner hidden, the label restored, and Approve's
    // availability is recomputed from the checkbox state.
    function setApproveBusy(isBusy) {
      var approveBtn = document.getElementById("permissions-approve-btn");
      var denyBtn = document.getElementById("permissions-deny-btn");
      var spinner = document.getElementById("permissions-approve-spinner");
      var label = document.getElementById("permissions-approve-label");
      if (isBusy) {
        if (approveBtn) approveBtn.disabled = true;
        if (denyBtn) denyBtn.disabled = true;
        if (spinner) spinner.classList.remove("hidden");
        if (label) label.textContent = "Approving…";
      } else {
        if (denyBtn) denyBtn.disabled = false;
        if (spinner) spinner.classList.add("hidden");
        if (label) label.textContent = "Approve";
        updateApproveState();
      }
    }

    async function submitGrant(form, resolvedId) {
      var errorBox = document.getElementById("permissions-error");
      var errorMsg = document.getElementById("permissions-error-message");
      var manualBox = document.getElementById("permissions-manual-credentials");
      var progress = document.getElementById("permissions-progress");
      setApproveBusy(true);
      if (errorBox) errorBox.classList.add("hidden");
      if (manualBox) manualBox.classList.add("hidden");
      if (progress) {
        progress.classList.remove("hidden");
        scrollDetailIntoView(progress);
      }

      var formData = new FormData(form);
      try {
        var response = await fetch(form.action, {
          method: "POST",
          body: formData,
          credentials: "same-origin",
        });
        if (!response.ok) {
          var text = await response.text();
          throw new Error(text || ("HTTP " + response.status));
        }
        var data = await response.json();
        if (data.outcome === "GRANTED" || data.outcome === "DENIED") {
          await inboxList.advanceAfterResolution(resolvedId);
          return;
        }
        if (progress) progress.classList.add("hidden");
        if (data.outcome === "NEEDS_MANUAL_CREDENTIALS") {
          var cmdEl = document.getElementById("permissions-manual-credentials-command");
          var msgEl = document.getElementById("permissions-manual-credentials-message");
          if (cmdEl) cmdEl.textContent = data.set_credentials_example || "";
          if (msgEl) msgEl.textContent = data.message || "";
          if (manualBox) {
            manualBox.classList.remove("hidden");
            scrollDetailIntoView(manualBox);
          }
          setApproveBusy(false);
          return;
        }
        // FAILED: the approval did not complete (e.g. the browser sign-in
        // flow failed). The request stays pending server-side (it is not
        // resolved, so we do not advance the inbox); show the reason and
        // re-enable Approve so the user can retry -- this is a failure, not
        // a denial.
        if (data.outcome === "FAILED") {
          if (errorMsg) errorMsg.textContent = data.message || "Approval failed; please try again.";
          if (errorBox) {
            errorBox.classList.remove("hidden");
            scrollDetailIntoView(errorBox);
          }
          setApproveBusy(false);
          return;
        }
        if (errorMsg) errorMsg.textContent = data.message || "Authorization failed.";
        if (errorBox) {
          errorBox.classList.remove("hidden");
          scrollDetailIntoView(errorBox);
        }
        setApproveBusy(false);
      } catch (err) {
        if (progress) progress.classList.add("hidden");
        if (errorMsg) errorMsg.textContent = err && err.message ? err.message : String(err);
        if (errorBox) {
          errorBox.classList.remove("hidden");
          scrollDetailIntoView(errorBox);
        }
        setApproveBusy(false);
      }
    }

    window.submitPermissionDeny = function () {
      var form = document.getElementById("permissions-form");
      if (!form) return;
      var resolvedId = inboxList.getSelectedId();
      // Mark the card as denying immediately so any re-render before the
      // server has processed the deny shows it faded with a "(denying...)"
      // label rather than letting the user click it back into the dialog.
      if (resolvedId) inboxList.markDenying(resolvedId);
      // Disable both buttons so the resolving card can't be re-actioned
      // while the deny POST is in flight and the inbox advances.
      var approveBtn = document.getElementById("permissions-approve-btn");
      if (approveBtn) approveBtn.disabled = true;
      var denyBtn = document.getElementById("permissions-deny-btn");
      if (denyBtn) denyBtn.disabled = true;
      var denyUrl = form.action.replace(/\/grant\b/, "/deny");
      // Fire-and-forget so the user doesn't wait for mngr message round trips,
      // and so the next-item swap can start immediately. keepalive lets the
      // request finish even if the page transitions away unexpectedly.
      fetch(denyUrl, {
        method: "POST",
        credentials: "same-origin",
        keepalive: true,
      }).catch(function () {});
      inboxList.advanceAfterResolution(resolvedId);
    };

    // -- Event delegation --

    inboxDetail.addEventListener("submit", function (e) {
      var form = e.target;
      if (!form || form.id !== "permissions-form") return;
      e.preventDefault();
      submitGrant(form, inboxList.getSelectedId());
    });

    inboxDetail.addEventListener("change", function (e) {
      if (e.target && e.target.name === "permissions") updateApproveState();
    });

    // Initial state: set Approve-button availability for the server-rendered
    // detail and reveal the native pickers when the bridge offers them.
    updateApproveState();
    wireSharePathControls();
  })();
</script>
{% endset %}
<OverlaySurface title="Requests"
                body_style="-webkit-app-region: no-drag;"
                head={{ _head }}
                scripts={{ _scripts }}>
  {# Left-anchored slide-in drawer: full viewport height (including
     under the title bar -- the modal view bounds from y=0 in main.js),
     ~70% width capped at a max, dropping to ~90% on small viewports.
     The dialog is flush with the left/top/bottom edges and has no
     rounded corners so it reads as a top-level panel attached to the
     screen edge. The backdrop dims the workspace strip on the right. #}
  <div id="inbox-backdrop"
       class="fixed inset-0 bg-surface-overlay flex justify-start"
       onclick="onBackdropClick(event)">
    <div id="inbox-dialog"
         class="relative w-[90vw] lg:w-[75vw] max-w-[1100px] h-full flex flex-col bg-surface-primary border-r border-default shadow-overlay overflow-hidden">
      {# Header row. 3-column grid so the title sits in the visual
         center regardless of how wide the close button is. The fixed
         height matches the chrome titlebar (h-[38px] in Chrome.jinja)
         so the two headers line up visually when the drawer sits
         beside the workspace's titlebar strip.

         The header is opted INTO ``-webkit-app-region: drag`` so the
         user can grab it to drag the window (the chrome titlebar
         beneath is no-drag while the modal is open). The close button
         is opted back out via inline no-drag so its click is not
         eaten by the drag handler. #}
      <div class="grid grid-cols-3 items-center px-2 h-[38px] border-b border-default"
           style="-webkit-app-region: drag;">
        <div></div>
        <h1 class="type-section text-primary text-center">Requests</h1>
        <button type="button" aria-label="Close" data-tooltip="Close"
                id="inbox-close-btn"
                onclick="closeInbox()"
                style="-webkit-app-region: no-drag;"
                class="justify-self-end inline-flex items-center justify-center w-6 h-6 rounded-md text-tertiary hover:text-primary hover:bg-fill-hover cursor-pointer">
          <Icon16 name="close" />
        </button>
      </div>
      <div id="inbox-body" class="flex flex-1 min-h-0 {% if is_empty %}is-empty{% endif %}">
        {# Left column: the InboxList mount container. The component renders
           the scrollable card list (or empty placeholder) on top and the
           pinned auto-open footer at the bottom; the footer's horizontal
           alignment flips based on ``#inbox-body.is-empty`` (centered when
           empty, left-aligned otherwise). #}
        <div id="inbox-left-column" class="flex flex-col w-72 border-r border-default bg-fill-subtle"></div>
        <div id="inbox-detail" class="flex-1 overflow-y-auto p-6 sm:p-6">
          {{ detail_html|safe }}
        </div>
      </div>
    </div>
    {# Drag strip in the backdrop to the right of the drawer. ``flex-1
       h-[38px] self-start`` makes it sit at the top of the remaining
       flex row width and only 38px tall, matching the chrome titlebar
       height. With ``app-region: drag`` the OS uses this area as a
       window-drag handle. The OS swallows mousedown for dragging, so
       the backdrop's click-to-dismiss isn't triggered from here -- the
       rest of the backdrop below the strip remains click-to-dismiss. #}
    <div class="flex-1 h-[38px] self-start"
         style="-webkit-app-region: drag;"></div>
  </div>
</OverlaySurface>
