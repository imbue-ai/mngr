{#def agent_id, request_id, ws_name, rationale, display_name, verbs, checked_permissions, target_workspace_id, target_workspace_name, show_target_choice, mngr_forward_origin #}
{#
  Latchkey cross-workspace (``minds-workspaces``) permission request fragment.
  Rendered inside the inbox modal's right pane. The verbs split into two
  clearly-labeled groups: "general" (non-targeted) permissions that apply
  across all workspaces (list/read, create), and "workspace-specific"
  (targeted) permissions that act on a single workspace (destroy / lifecycle /
  backups-export / ssh / ...). Each group pre-checks the verbs the agent
  requested. Chrome and form submission JS live in the inbox shell and operate
  on the shared element ids (#permissions-form, #permissions-approve-btn, ...).

  The workspace-specific group is always shown. Its target radio depends on the
  request: when it named a target workspace the user chooses "Only this
  workspace" or "All workspaces"; when it named none, a caution notice explains
  the grant can only be broad and a single pre-selected "All workspaces" option
  is offered.

  The form submits ``permissions`` (the verb checkboxes) and ``target_scope``
  (``selected`` | ``all``). The targeted verbs honor ``target_scope``; the
  general verbs (read / create) ignore it.
#}
<div class="permissions-detail">
  <PermissionsHeader :display_name="display_name" :ws_name="ws_name" :agent_id="agent_id" :rationale="rationale" />

  <PermissionsForm :request_id="request_id">
    <p class="type-body text-primary mb-3">
      Approving will grant {{ ws_name or agent_id }} and its sibling agents the selected
      cross-workspace permissions below.
    </p>

    {# General (non-targeted) permissions: apply across all workspaces (current
       and future), so they carry no target and always appear. #}
    <h2 class="type-label text-primary mb-2">General permissions</h2>
    <p class="type-body text-primary mb-2">These apply across all workspaces (current and future).</p>
    <Card extra="space-y-3">
      {% for verb in verbs if not verb.is_targeted %}
        <label class="flex items-start gap-2 cursor-pointer">
          <input type="checkbox" name="permissions" value="{{ verb.permission }}"
                 class="mt-1 shrink-0"
                 {% if verb.permission in checked_permissions %}checked{% endif %}>
          <span class="min-w-0">
            <code class="type-body font-mono text-primary">{{ verb.display_name }}</code>
            {% if verb.description %}
              <span class="block type-body text-primary mt-0.5">{{ verb.description }}</span>
            {% endif %}
          </span>
        </label>
      {% endfor %}
    </Card>

    {# Workspace-specific (targeted) permissions and their target radio. These
       verbs are gated per-target, so they are always offered, but the scope
       choice below depends on whether the request named a target workspace:

       * with a named target, the user chooses "Only this workspace" (accumulate
         the named target into a per-workspace allowlist) or "All workspaces"
         (grant broadly);
       * without a named target there is no workspace to pin, so the only
         possible scope is broad -- we say so with a caution notice and offer a
         single, pre-selected "All workspaces" option. #}
    <h2 class="type-label text-primary mt-6 mb-2">Workspace-specific permissions</h2>
    {% if show_target_choice %}
      <p class="type-body text-primary mb-2">These act on a single workspace, chosen below.</p>
    {% else %}
      <p class="type-body text-primary mb-2">These act on individual workspaces.</p>
    {% endif %}
    <Card extra="space-y-3">
      {% for verb in verbs if verb.is_targeted %}
        <label class="flex items-start gap-2 cursor-pointer">
          <input type="checkbox" name="permissions" value="{{ verb.permission }}"
                 class="mt-1 shrink-0"
                 {% if verb.permission in checked_permissions %}checked{% endif %}>
          <span class="min-w-0">
            <code class="type-body font-mono text-primary">{{ verb.display_name }}</code>
            {% if verb.description %}
              <span class="block type-body text-primary mt-0.5">{{ verb.description }}</span>
            {% endif %}
          </span>
        </label>
      {% endfor %}
    </Card>

    <h2 class="type-label text-primary mt-6 mb-2">Apply workspace-specific permissions to:</h2>
    {% if show_target_choice %}
      <Card extra="space-y-2">
        <label class="flex items-start gap-2 cursor-pointer">
          <input type="radio" name="target_scope" value="selected" class="mt-1 shrink-0" checked>
          <span class="min-w-0">
            <span class="type-body text-primary">Only this workspace</span>
            <code class="block type-body font-mono text-primary mt-0.5">{{ target_workspace_name or target_workspace_id }}</code>
          </span>
        </label>
        <label class="flex items-start gap-2 cursor-pointer">
          <input type="radio" name="target_scope" value="all" class="mt-1 shrink-0">
          <span class="min-w-0">
            <span class="type-body text-primary">All workspaces</span>
            <span class="block type-body text-primary mt-0.5">
              Grant the selected actions for every workspace (current and future).
            </span>
          </span>
        </label>
      </Card>
    {% else %}
      {# No target workspace named: the only possible scope is broad. Warn
         clearly, then carry the choice through a single checked "All
         workspaces" radio (submitting ``target_scope=all``). #}
      <Notice variant="warn">
        This request did not name a specific workspace, so any
        workspace-specific permissions you grant will apply to
        <span class="font-semibold">all workspaces</span> (current and future).
        Grant them only if you intend that broad access.
      </Notice>
      <Card extra="space-y-2">
        <label class="flex items-start gap-2 cursor-pointer">
          <input type="radio" name="target_scope" value="all" class="mt-1 shrink-0" checked>
          <span class="min-w-0">
            <span class="type-body text-primary">All workspaces</span>
            <span class="block type-body text-primary mt-0.5">
              Grant the selected actions for every workspace (current and future).
            </span>
          </span>
        </label>
      </Card>
    {% endif %}
  </PermissionsForm>

  <div id="permissions-progress" class="hidden mt-4">
    <Notice variant="info">
      <span class="font-semibold">Granting permission...</span>
    </Notice>
  </div>

  <PermissionsManualCredentials />
  <PermissionsError />
</div>
