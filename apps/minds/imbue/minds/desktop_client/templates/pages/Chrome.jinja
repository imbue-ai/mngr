{#def is_mac, is_authenticated, mngr_forward_origin, initial_workspaces #}
{#
  Persistent chrome page (titlebar + sidebar + content iframe).

  is_mac controls macOS-specific styling (traffic-light padding, hidden window
  controls). In Electron mode, the iframe and embedded browser-mode sidebar are
  hidden via JS; the content and sidebar are separate WebContentsViews.

  mngr_forward_origin is exposed to page-level JS via a data attribute on the
  body so chrome.js can build workspace links that target the plugin's port
  directly.
#}
{% set _head %}
<style>
  /* Things that can't easily be expressed as Tailwind utilities. */
  html, body { height: 100%; overflow: hidden; }
  #minds-titlebar { -webkit-app-region: drag; box-shadow: var(--shadow-seam); }
  #minds-titlebar button { -webkit-app-region: no-drag; }
  .minds-user-area { -webkit-app-region: no-drag; }
</style>
{% endset %}
{% set _body_attrs %}data-is-mac="{{ 'true' if is_mac else 'false' }}" data-is-authenticated="{{ 'true' if is_authenticated else 'false' }}" data-mngr-forward-origin="{{ mngr_forward_origin }}"{% endset %}
{% set _scripts %}
<script src="/_static/workspace_accent.js" defer></script>
<script src="/_static/chrome.js" defer></script>
{% endset %}
<Base title="Minds"
      body_class="font-sans antialiased bg-zinc-900"
      head={{ _head }}
      body_attrs={{ _body_attrs }}
      scripts={{ _scripts }}>
  <div id="minds-titlebar"
       class="fixed top-0 left-0 right-0 h-[38px] bg-zinc-900 flex items-center select-none z-[100] border-b border-white/10 px-1 {% if is_mac %}pl-[72px]{% endif %}">
    <div class="flex gap-0.5">
      <TitlebarButton id="sidebar-toggle" title="Projects"><Icon24 name="sidebar" /></TitlebarButton>
      <TitlebarButton id="home-btn" title="Home"><Icon24 name="home" /></TitlebarButton>
      <TitlebarButton id="back-btn" title="Back"><Icon24 name="back" /></TitlebarButton>
      <TitlebarButton id="forward-btn" title="Forward"><Icon24 name="forward" /></TitlebarButton>
    </div>
    <div class="flex-1 flex items-center justify-center gap-2 px-2 min-w-0">
      <span id="title-swatch" class="accent-swatch hidden w-2.5 h-2.5 rounded-sm shrink-0"></span>
      <span id="page-title" class="text-zinc-200 text-xs whitespace-nowrap overflow-hidden text-ellipsis">Minds</span>
    </div>
    <div class="relative minds-user-area shrink-0">
      <button id="user-btn"
              class="!w-auto !h-auto !inline-block text-zinc-400 cursor-pointer px-2.5 py-1 rounded-md text-xs font-sans whitespace-nowrap hover:bg-white/5 hover:text-zinc-200"
              title="Account">Log in</button>
    </div>
    <TitlebarButton id="requests-toggle" title="Requests" extra="relative">
      <Icon24 name="messages" />
      <span id="requests-badge" class="hidden absolute top-0.5 right-0.5 w-2 h-2 rounded-full bg-red-500"></span>
    </TitlebarButton>
    <div class="flex {% if is_mac %}hidden{% endif %}">
      <TitlebarButton variant="control" id="min-btn" title="Minimize"><Icon12 name="minimize" /></TitlebarButton>
      <TitlebarButton variant="control" id="max-btn" title="Maximize"><Icon12 name="maximize" /></TitlebarButton>
      <TitlebarButton variant="control" tone="danger" id="close-btn" title="Close"><Icon12 name="close" /></TitlebarButton>
    </div>
  </div>

  {# Browser-mode sidebar: sits under the titlebar and slides in from the
     left when toggled. In Electron this is a separate WebContentsView and
     the JS hides this element. #}
  <div id="sidebar-panel"
       class="fixed left-0 top-[38px] w-[260px] h-[calc(100%-38px)] bg-zinc-900 z-50 shadow-[4px_0_12px_rgba(0,0,0,0.3)] -translate-x-full transition-transform duration-200 ease-in-out overflow-y-auto border-r border-white/10">
    <div id="sidebar-workspaces">
      <div class="px-4 py-6 text-sm text-zinc-400 text-center">No projects</div>
    </div>
  </div>

  <iframe id="content-frame"
          src="/"
          class="fixed left-[6px] top-[38px] border-0 rounded-xl bg-zinc-50"
          style="width: calc(100% - 12px); height: calc(100% - 44px); box-shadow: 0 1px 0 rgba(255,255,255,0.05) inset;"></iframe>
</Base>
