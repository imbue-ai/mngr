{#def is_mac, is_authenticated, mngr_forward_origin, initial_workspaces, workspace_presets #}
{#
  Persistent chrome page (titlebar + sidebar + content iframe).

  is_mac controls macOS-specific styling (traffic-light padding, hidden window
  controls). In Electron mode, the iframe and embedded browser-mode sidebar are
  hidden via JS; the content and sidebar are separate WebContentsViews.

  mngr_forward_origin is exposed to page-level JS via a data attribute on the
  body so chrome.js can build workspace links that target the plugin's port
  directly.

  workspace_presets is the list of (slug, hex) tuples for the titlebar
  workspace-color picker flyout.

  Chrome renders with the everywhere-default (confusion) workspace color;
  static/workspace_color.js applies the active workspace's color (read from
  the iframe URL on navigation) by swapping <html>'s data-theme +
  --workspace-bg in place.
#}
{% set _head %}
<style>
  /* Things that can't easily be expressed as Tailwind utilities. */
  html, body { height: 100%; overflow: hidden; }
  #minds-titlebar { -webkit-app-region: drag; box-shadow: var(--shadow-seam); }
  #minds-titlebar button { -webkit-app-region: no-drag; }
  .minds-user-area { -webkit-app-region: no-drag; }
  #minds-ws-color-flyout {
    -webkit-app-region: no-drag;
    background: var(--surface-overlay);
    border: 1px solid var(--surface-overlay-border);
  }
</style>
{% endset %}
{% set _body_attrs %}data-is-mac="{{ 'true' if is_mac else 'false' }}" data-is-authenticated="{{ 'true' if is_authenticated else 'false' }}" data-mngr-forward-origin="{{ mngr_forward_origin }}"{% endset %}
{% set _scripts %}
<script src="/_static/workspace_color.js" defer></script>
{# Legacy per-agent accent helper. chrome.js still calls
   `window.mindsAccent.get(...)` for the (currently hidden) `#title-swatch`
   element until Phase 3 migrates its callers to the new workspace_color.js
   pipeline; without this tag chrome.js throws on every Chrome page load. #}
<script src="/_static/workspace_accent.js" defer></script>
<script src="/_static/chrome.js" defer></script>
{% endset %}
<Base title="Minds"
      body_class="font-sans antialiased bg-token-workspace text-token-primary"
      head={{ _head }}
      body_attrs={{ _body_attrs }}
      scripts={{ _scripts }}>
  <div id="minds-titlebar"
       class="fixed top-0 left-0 right-0 h-[38px] bg-token-workspace flex items-center select-none z-[100] border-b border-token-subtle px-1 {% if is_mac %}pl-[72px]{% endif %}">
    <div class="flex gap-0.5">
      <button id="sidebar-toggle" title="Projects" class="titlebar-btn focus-ring-token">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="9" y1="3" x2="9" y2="21"/></svg>
      </button>
      <button id="home-btn" title="Home" class="titlebar-btn focus-ring-token">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12L12 3l9 9"/><path d="M5 10v10a1 1 0 0 0 1 1h4v-6h4v6h4a1 1 0 0 0 1-1V10"/></svg>
      </button>
      <button id="back-btn" title="Back" class="titlebar-btn focus-ring-token">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <button id="forward-btn" title="Forward" class="titlebar-btn focus-ring-token">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"/></svg>
      </button>
    </div>
    <div class="flex-1 flex items-center justify-center gap-2 px-2 min-w-0">
      <button id="ws-color-flyout-toggle"
              title="Change workspace color"
              class="hidden titlebar-btn focus-ring-token"
              style="width: 16px; height: 16px; padding: 0;">
        <span id="ws-color-flyout-swatch" class="ws-dot" style="width: 10px; height: 10px;"></span>
      </button>
      {# Legacy accent indicator. chrome.js still toggles its visibility +
         CSS variable until Phase 3 migrates that wiring; rendered hidden
         so it stays out of the way of the new flyout swatch above. #}
      <span id="title-swatch" class="accent-swatch hidden w-2.5 h-2.5 rounded-sm shrink-0"></span>
      <span id="page-title" class="type-helper-12 text-token-secondary whitespace-nowrap overflow-hidden text-ellipsis">Minds</span>
    </div>
    <div class="relative minds-user-area shrink-0">
      <button id="user-btn"
              class="!w-auto !h-auto !inline-block type-helper-12 text-token-tertiary cursor-pointer px-2.5 py-1 rounded-md whitespace-nowrap hover:bg-token-fill-hover focus-ring-token"
              title="Account">Log in</button>
    </div>
    <button id="requests-toggle" title="Requests" class="relative titlebar-btn focus-ring-token">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      <span id="requests-badge" class="hidden absolute top-0.5 right-0.5 w-2 h-2 rounded-full" style="background-color: var(--important);"></span>
    </button>
    <div class="flex {% if is_mac %}hidden{% endif %}">
      <button id="min-btn" title="Minimize" class="titlebar-btn focus-ring-token" style="width: 36px; height: 38px; border-radius: 0;">
        <svg viewBox="0 0 12 12" class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="2" y1="6" x2="10" y2="6"/></svg>
      </button>
      <button id="max-btn" title="Maximize" class="titlebar-btn focus-ring-token" style="width: 36px; height: 38px; border-radius: 0;">
        <svg viewBox="0 0 12 12" class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="8" height="8" rx="0.5"/></svg>
      </button>
      <button id="close-btn" title="Close" class="titlebar-btn focus-ring-token" style="width: 36px; height: 38px; border-radius: 0;">
        <svg viewBox="0 0 12 12" class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="2" y1="2" x2="10" y2="10"/><line x1="10" y1="2" x2="2" y2="10"/></svg>
      </button>
    </div>
  </div>

  {# Workspace-color quick-flip flyout. Anchored to the titlebar swatch
     button; opens via static/chrome.js. The 11 swatches are rendered
     server-side from workspace_presets; clicking one calls
     mindsWorkspaceColor.apply() and the chrome's <html> attributes
     update in place (no reload). #}
  <div id="minds-ws-color-flyout"
       class="hidden fixed top-[42px] left-1/2 -translate-x-1/2 z-[110] rounded-lg p-2"
       data-ws-color-flyout>
    <div class="flex flex-wrap gap-1.5 max-w-[180px]">
      {% for preset_slug, preset_hex in workspace_presets %}
        <button type="button"
                class="ws-swatch focus-ring-token"
                data-ws-color-preset="{{ preset_slug }}"
                title="{{ preset_slug }}"
                style="background: {{ preset_hex }}; width: 24px; height: 24px; border-radius: var(--radius-sm); border: 1px solid var(--border-default); cursor: pointer;"></button>
      {% endfor %}
    </div>
  </div>

  {# Browser-mode sidebar: sits under the titlebar and slides in from the
     left when toggled. In Electron this is a separate WebContentsView and
     the JS hides this element. #}
  <div id="sidebar-panel"
       class="fixed left-0 top-[38px] w-[260px] h-[calc(100%-38px)] bg-token-workspace z-50 -translate-x-full transition-transform duration-200 ease-in-out overflow-y-auto border-r border-token-subtle"
       style="box-shadow: 4px 0 12px rgba(0, 0, 0, 0.3);">
    <div id="sidebar-workspaces">
      <div class="px-4 py-6 type-helper-12 text-token-tertiary text-center">No projects</div>
    </div>
  </div>

  <iframe id="content-frame"
          src="/"
          class="fixed left-[6px] top-[38px] border-0 rounded-xl"
          style="width: calc(100% - 12px); height: calc(100% - 44px); background: #fafafa; box-shadow: 0 1px 0 rgba(255,255,255,0.05) inset;"></iframe>
</Base>
