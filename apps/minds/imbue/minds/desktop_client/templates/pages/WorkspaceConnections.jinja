{#def agent_id, ws_name, pending_requests=[], selected_id="", services_overview=[], file_sharing_grants=[], workspace_delegation_grants=[], permissions_unavailable=False #}
{#
  Per-workspace Connections view, opened from the titlebar's Connections
  icon-tab (and by permission-request OS notifications / deep links, which
  pass ``?selected=<request id>``). Layout matches the minds-options mockup.

  "Waiting on you" -- this workspace's pending permission requests as
  compact one-line cards (action title + rationale + Approve/Deny). Each
  card also holds its full latchkey detail fragment in a collapsed panel:
  the chevron (or a deep link, or an Approve that needs more input --
  e.g. a file-sharing path or an empty permission selection) expands it.
  Because several fragments can be on the page at once and they carry
  fixed element ids, all interactivity in
  /_static/workspace_connections.js is scoped per-card, and the
  fragments' inline handlers pass ``this`` so the shared globals can find
  their enclosing card.

  "Connected" -- one row per connection the workspace's host holds
  (connectors, shared local files, workspace delegation), mockup-style:
  icon + name + summary, a green "Connected" status, and a chevron that
  expands the row's detail (granted permission pills + revoke actions).
  Grants are stored per host and every agent on the host shares them;
  revoking removes the rule only, stored credentials stay put.
#}
{% set _head %}
<style>
  /* Deep-link highlight (?selected=<id>): an accent ring around the target
     request card, cleared by workspace_connections.js on first interaction. */
  .connections-request.is-selected { outline: 2px solid var(--c-accent); outline-offset: 2px; }
  /* A deny POST is fire-and-forget; the card stays until the SSE-driven
     reload drops it. Fade + freeze it so it can't be re-actioned meanwhile. */
  .connections-request.is-denying { opacity: 0.6; pointer-events: none; }
  /* Expanded rows rotate their chevron. */
  .connections-expand-icon { transition: transform 100ms ease-in-out; }
  .is-expanded > * .connections-expand-icon, .is-expanded .connections-expand-icon { transform: rotate(180deg); }
</style>
{% endset %}
{% set _scripts %}
<script src="/_static/workspace_connections.js" defer></script>
{% endset %}
{% set _body_attrs %}data-agent-id="{{ agent_id }}"{% endset %}
<Base title="Connections" head={{ _head }} body_attrs={{ _body_attrs }} scripts={{ _scripts }}>
  <div class="max-w-[860px] mx-auto px-8 py-12">
    <h1 class="type-heading-lg text-primary">Connections</h1>
    <p class="mt-2 max-w-[620px] type-body text-secondary">
      Bring your tools and data into <span class="font-semibold text-primary">{{ ws_name or agent_id }}</span>.
      The agent can read from and act on anything you connect &mdash; and it always asks before
      reaching something new.
    </p>

    {# -- Pending permission requests -- #}
    {% if pending_requests %}
      <section class="mt-8" data-connections-pending>
        <h2 class="type-section text-tertiary">Waiting on you</h2>
        <div class="mt-2 flex flex-col gap-2">
          {% for req in pending_requests %}
            <div class="connections-request rounded-md border border-subtle bg-fill-subtle {% if req.id == selected_id %}is-selected is-expanded{% endif %}"
                 id="request-{{ req.id }}"
                 data-request-id="{{ req.id }}">
              <div class="flex items-center gap-3 px-3 py-2">
                <div class="min-w-0 flex-1">
                  <div class="type-label text-primary truncate">{{ req.title or req.display_name }}</div>
                  {% if req.description %}
                    <p class="type-helper text-secondary truncate">{{ req.description }}</p>
                  {% endif %}
                </div>
                <div class="shrink-0 flex items-center gap-1.5">
                  <Button variant="primary" size="md" class="connections-approve-btn">Approve</Button>
                  <Button variant="secondary" size="md" class="connections-deny-btn">Deny</Button>
                  <Button variant="ghost" size="icon" class="connections-toggle-btn"
                          aria-label="Details" data-tooltip="Details">
                    <Icon16 name="chevron-down" extra="connections-expand-icon" />
                  </Button>
                </div>
              </div>
              <div class="connections-request-detail {% if req.id != selected_id %}hidden{% endif %} border-t border-subtle px-4 pb-4">
                {{ req.detail_html|safe }}
              </div>
            </div>
          {% endfor %}
        </div>
      </section>
    {% endif %}

    {# -- Everything the workspace's host currently holds -- #}
    <section class="mt-8">
      <h2 class="type-section text-tertiary">Connected</h2>
      {% if permissions_unavailable %}
        <div class="mt-2">
          <Notice variant="warn">
            Connections can't be loaded right now.
            Try again in a moment.
          </Notice>
        </div>
      {% elif services_overview or file_sharing_grants or workspace_delegation_grants %}
        <div class="mt-1 flex flex-col divide-y divide-subtle">
          {# Connectors: one row per (service, this-workspace grant). #}
          {% for service in services_overview %}
            {% for grant in service.workspace_grants %}
              <div class="connection-item"
                   data-service-name="{{ service.service_name }}" data-service-label="{{ service.display_name }}"
                   data-workspace-agent-id="{{ grant.workspace_agent_id }}"
                   data-workspace-name="{{ grant.workspace_name }}">
                <button type="button" class="connection-row flex w-full items-center gap-3 px-2 py-3 rounded-md text-left cursor-pointer transition-colors hover:bg-fill-subtle bg-transparent border-0">
                  <Icon16 name="cable" extra="shrink-0 text-secondary" />
                  <span class="min-w-0 flex-1">
                    <span class="block type-label text-primary">{{ service.display_name }}</span>
                    <span class="block type-helper text-secondary truncate">{% for perm in grant.permissions %}{{ perm.label }}{% if not loop.last %}, {% endif %}{% endfor %}</span>
                  </span>
                  <span class="shrink-0 inline-flex items-center gap-1 type-helper text-secondary">
                    <span class="w-1.5 h-1.5 rounded-full bg-success"></span>
                    Connected
                  </span>
                  <Icon16 name="chevron-down" extra="shrink-0 text-tertiary connections-expand-icon" />
                </button>
                <div class="connection-detail hidden px-2 pb-3">
                  <p class="type-helper text-tertiary mb-1">Allowed</p>
                  <div class="flex flex-wrap gap-1 mb-3">
                    {% for perm in grant.permissions %}
                      <code class="code-pill"{% if perm.description %} data-tooltip="{{ perm.description }}"{% endif %}>{{ perm.label }}</code>
                    {% endfor %}
                  </div>
                  <Button variant="secondary" size="md" class="revoke-btn">Revoke</Button>
                </div>
              </div>
            {% endfor %}
          {% endfor %}

          {# File sharing: one row per grant (all shared paths). #}
          {% for grant in file_sharing_grants %}
            <div class="connection-item"
                 data-workspace-agent-id="{{ grant.workspace_agent_id }}"
                 data-workspace-name="{{ grant.workspace_name }}">
              <button type="button" class="connection-row flex w-full items-center gap-3 px-2 py-3 rounded-md text-left cursor-pointer transition-colors hover:bg-fill-subtle bg-transparent border-0">
                <Icon16 name="home" extra="shrink-0 text-secondary" />
                <span class="min-w-0 flex-1">
                  <span class="block type-label text-primary">Local files</span>
                  <span class="block type-helper text-secondary truncate">{% for shared in grant.paths %}{{ shared.path }}{% if not loop.last %}, {% endif %}{% endfor %}</span>
                </span>
                <span class="shrink-0 inline-flex items-center gap-1 type-helper text-secondary">
                  <span class="w-1.5 h-1.5 rounded-full bg-success"></span>
                  Connected
                </span>
                <Icon16 name="chevron-down" extra="shrink-0 text-tertiary connections-expand-icon" />
              </button>
              <div class="connection-detail hidden px-2 pb-3">
                <p class="type-helper text-tertiary mb-1">Allowed</p>
                <div class="flex flex-col gap-1 mb-3">
                  {% for shared in grant.paths %}
                    <div class="flex items-center justify-between gap-3">
                      <code class="code-pill truncate min-w-0" data-tooltip="{{ shared.path }}">{{ shared.path }}</code>
                      <span class="type-helper text-secondary shrink-0">{{ shared.access_label }}</span>
                    </div>
                  {% endfor %}
                </div>
                <Button variant="secondary" size="md" class="revoke-fs-btn">Revoke</Button>
              </div>
            </div>
          {% endfor %}

          {# Workspace delegation: one row per granting workspace. #}
          {% for grant in workspace_delegation_grants %}
            <div class="connection-item"
                 data-workspace-agent-id="{{ grant.workspace_agent_id }}"
                 data-workspace-name="{{ grant.workspace_name }}">
              <button type="button" class="connection-row flex w-full items-center gap-3 px-2 py-3 rounded-md text-left cursor-pointer transition-colors hover:bg-fill-subtle bg-transparent border-0">
                <Icon16 name="panels-top-left" extra="shrink-0 text-secondary" />
                <span class="min-w-0 flex-1">
                  <span class="block type-label text-primary">Workspace delegation</span>
                  <span class="block type-helper text-secondary truncate">{% for verb in grant.verbs %}{{ verb.label }}{% if not loop.last %}, {% endif %}{% endfor %}</span>
                </span>
                <span class="shrink-0 inline-flex items-center gap-1 type-helper text-secondary">
                  <span class="w-1.5 h-1.5 rounded-full bg-success"></span>
                  Connected
                </span>
                <Icon16 name="chevron-down" extra="shrink-0 text-tertiary connections-expand-icon" />
              </button>
              <div class="connection-detail hidden px-2 pb-3">
                <p class="type-helper text-tertiary mb-1">Access this workspace's agents hold to manage other workspaces. Revoking removes it; agents can ask again later.</p>
                <div class="flex flex-col">
                  {% for verb in grant.verbs %}
                    <div class="flex items-center justify-between gap-3 py-1.5 border-b border-subtle"
                         data-verb-permission="{{ verb.verb_permission }}" data-verb-label="{{ verb.label }}">
                      <div class="flex items-center gap-2 min-w-0 flex-wrap">
                        <code class="code-pill" data-tooltip="{{ verb.description }}">{{ verb.label }}</code>
                        <span class="type-helper text-tertiary">on:</span>
                        <span class="type-body text-secondary truncate">{{ "All workspaces" if verb.is_all_workspaces else verb.target_names | join(", ") }}</span>
                      </div>
                      <Button variant="ghost" size="md" class="revoke-verb-btn shrink-0">Revoke</Button>
                    </div>
                  {% endfor %}
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      {% else %}
        <div class="mt-2">
          <Notice variant="info">No connectors have been added yet. To connect a new service, just ask the agent in this workspace to use it.</Notice>
        </div>
      {% endif %}
    </section>
  </div>

  <Modal id="revoke-dialog" card_extra="text-left">
    <h2 id="revoke-dialog-title" class="type-heading text-primary mb-3">Revoke access?</h2>
    <p id="revoke-dialog-body" class="type-body text-primary mb-4"></p>
    <p id="revoke-error" class="hidden type-body text-important mb-3" role="alert"></p>
    <div class="flex justify-end gap-3">
      <Button variant="secondary" id="revoke-cancel-btn">Cancel</Button>
      <Button variant="danger" id="revoke-confirm-btn">Revoke</Button>
    </div>
  </Modal>
</Base>
