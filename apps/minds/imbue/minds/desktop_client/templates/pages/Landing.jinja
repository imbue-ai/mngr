{#def agent_ids, agent_accents, mngr_forward_origin, telegram_enabled, telegram_status_by_agent_id, is_discovering, agent_names, destroying_status_by_agent_id, shutdown_capable_agent_ids, mind_liveness_by_agent_id, agent_providers={} #}
{#
  Landing page: list of accessible workspaces with per-row health, backup,
  and telegram status. Subscribes to the chrome SSE so the page reloads
  when a destroy completes (or any other workspace-list change lands).
#}
{% set _scripts %}
<script>
  (function () {
    var rendered = (document.querySelector('[data-landing-agent-ids]') || {}).dataset || {};
    var renderedIds = (rendered.landingAgentIds || '').split(',').filter(function (s) { return s.length > 0; });
    var renderedSet = new Set(renderedIds);

    var healthStatusByAgent = {};

    // Server-seeded mind container liveness. ``mindLivenessByAgent`` maps agent id
    // -> 'RUNNING' | 'STOPPED' | 'UNKNOWN'; only shutdown-capable minds (those on a
    // provider whose host minds can stop/start -- docker/lima today) appear, and
    // they are the only rows that get Start/Stop controls.
    var mindLivenessByAgent = {{ mind_liveness_by_agent_id | tojson }};
    // While a Start/Stop the user issued is in flight, the row shows an optimistic
    // transient ('STARTING'/'STOPPING'); this maps agent id -> the target state
    // ('RUNNING'/'STOPPED') so an interim ``workspaces`` push (still carrying the
    // pre-action liveness) does not clobber the transient back. Cleared once the
    // authoritative state reaches the target or the action fails.
    var pendingMindActionByAgent = {};
    var isElectronShell = navigator.userAgent.indexOf('Electron') !== -1;

    function getRow(agentId) {
      return document.querySelector('[data-agent-id="' + (window.CSS && CSS.escape ? CSS.escape(agentId) : agentId) + '"]');
    }

    function applyRowHealth(agentId, status) {
      var row = getRow(agentId);
      if (!row) return;
      // A stopped container has no server to be unhealthy; suppress the health
      // badge entirely so it doesn't compete with the "Stopped" state badge.
      if (mindLivenessByAgent[agentId] === 'STOPPED') {
        status = 'healthy';
      }
      var badge = row.querySelector('.landing-health-badge');
      if (!badge) return;
      if (status === 'stuck') {
        badge.textContent = 'Server not responding';
        badge.className = 'landing-health-badge inline-flex items-center px-2 py-0.5 rounded-md type-label bg-warning/15 text-warning';
      } else if (status === 'restarting') {
        badge.textContent = 'Restarting...';
        badge.className = 'landing-health-badge inline-flex items-center px-2 py-0.5 rounded-md type-label bg-warning/15 text-warning';
      } else if (status === 'restart_failed') {
        badge.textContent = 'Restart failed';
        badge.className = 'landing-health-badge inline-flex items-center px-2 py-0.5 rounded-md type-label bg-warning/15 text-warning';
      } else {
        badge.textContent = '';
        badge.className = 'landing-health-badge inline-flex items-center px-2 py-0.5 rounded-md type-label';
      }
      // Hide via inline display, not a `.hidden` class: the base class is
      // inline-flex, which beats `.hidden` in the cascade. The badge shows only
      // when it carries text (the empty "healthy" state is hidden).
      badge.style.display = badge.textContent ? '' : 'none';
    }

    window.landingRowClick = function (event, row) {
      var agentId = row.dataset.agentId;
      var status = healthStatusByAgent[agentId];
      var ret = row.dataset.defaultHref || '';
      if (status === 'stuck' || status === 'restarting' || status === 'restart_failed') {
        window.location = '/agents/' + encodeURIComponent(agentId) + '/recovery?return_to=' + encodeURIComponent(ret);
      } else if (mindLivenessByAgent[agentId] === 'STOPPED') {
        // The mind's container is stopped, so loading the workspace directly would
        // strand the user on the loader for the full HEALTHY->STUCK probe-failure
        // threshold before any restart is dispatched. We already know it's down, so
        // route straight to the recovery page, which confirms host_offline via its
        // probe and cold-boots the host immediately. ``intent=restart`` is required:
        // the health tracker has never probed this stopped mind so it still reports
        // HEALTHY, and without the intent the recovery handler would 302 us right
        // back to the loader instead of dispatching the restart.
        window.location = '/agents/' + encodeURIComponent(agentId)
          + '/recovery?return_to=' + encodeURIComponent(ret) + '&intent=restart';
      } else {
        window.location = ret;
      }
    };

    window.landingRestartClick = function (button) {
      var row = button.closest('[data-agent-id]');
      if (!row) return;
      var agentId = row.dataset.agentId;
      var ret = row.dataset.defaultHref || '';
      window.location = '/agents/' + encodeURIComponent(agentId)
        + '/recovery?return_to=' + encodeURIComponent(ret) + '&intent=restart';
    };

    window.landingOpenInNewWindow = function (button) {
      var row = button.closest('[data-agent-id]');
      if (!row) return;
      var agentId = row.dataset.agentId;
      if (isElectronShell) {
        // Route through the content relay -> main process, which opens (or
        // focuses) a dedicated window for this workspace. Same channel the
        // sidebar's open-in-new arrow uses.
        window.postMessage({ type: 'minds:open-workspace-in-new-window', agentId: agentId }, '*');
      } else {
        // Plain browser: no native windows, so open the workspace URL in a
        // new tab instead.
        window.open(row.dataset.defaultHref, '_blank', 'noopener');
      }
    };

    // -- Mind Start / Stop controls --

    // Apply a (possibly transient) liveness label to a shutdown-capable row: swap
    // which of the Start / Stop buttons is shown and set the status badge.
    // Transient 'STARTING' / 'STOPPING' are client-only optimistic labels set on
    // click; the authoritative 'RUNNING' / 'STOPPED' / 'UNKNOWN' arrive folded
    // into the ``workspaces`` SSE payload.
    function applyMindLiveness(agentId, state) {
      mindLivenessByAgent[agentId] = state;
      var row = getRow(agentId);
      if (!row) return;
      var startBtn = row.querySelector('.landing-start-btn');
      var stopBtn = row.querySelector('.landing-stop-btn');
      var badge = row.querySelector('.landing-mind-state-badge');
      var showStart = state === 'STOPPED';
      var showStop = state === 'RUNNING';
      // Toggle inline display rather than a ``.hidden`` class: the button base
      // class is ``inline-flex``, which beats ``.hidden`` on equal specificity,
      // so a class-based hide would leave both buttons visible.
      if (startBtn) startBtn.style.display = showStart ? '' : 'none';
      if (stopBtn) stopBtn.style.display = showStop ? '' : 'none';
      if (badge) {
        var text = '';
        var tone = 'bg-fill-subtle text-primary';
        if (state === 'STOPPED') { text = 'Stopped'; tone = 'bg-fill-subtle text-primary'; }
        else if (state === 'UNKNOWN') { text = 'Status unknown'; tone = 'bg-fill-subtle text-secondary'; }
        else if (state === 'STOPPING') { text = 'Stopping…'; tone = 'bg-warning/15 text-warning'; }
        else if (state === 'STARTING') { text = 'Starting…'; tone = 'bg-warning/15 text-warning'; }
        badge.textContent = text;
        badge.className = 'landing-mind-state-badge inline-flex items-center px-2 py-0.5 rounded-md type-label ' + tone;
        // Inline display again (the base class is inline-flex, so a .hidden
        // class wouldn't hide the empty RUNNING-state badge).
        badge.style.display = text ? '' : 'none';
      }
      // Re-evaluate the health badge: a freshly-stopped row must drop any
      // "Server not responding" badge it was showing.
      applyRowHealth(agentId, healthStatusByAgent[agentId] || 'healthy');
    }

    // Apply an authoritative liveness (from the ``workspaces`` SSE payload),
    // honouring any in-flight optimistic action: while a Start/Stop is pending,
    // an interim payload still carrying the pre-action state is ignored so it
    // doesn't flicker the transient back; once the payload reaches the target
    // state the pending guard clears and the real state shows.
    function applyAuthoritativeMindLiveness(agentId, state) {
      var pendingTarget = pendingMindActionByAgent[agentId];
      if (pendingTarget) {
        if (state !== pendingTarget) return;
        delete pendingMindActionByAgent[agentId];
      }
      applyMindLiveness(agentId, state);
    }

    window.landingStartClick = function (button) {
      var row = button.closest('[data-agent-id]');
      if (!row) return;
      var agentId = row.dataset.agentId;
      pendingMindActionByAgent[agentId] = 'RUNNING';
      applyMindLiveness(agentId, 'STARTING');
      // The endpoint is synchronous: it resolves only once the host has actually
      // started (or failed), so a non-ok response is a real failure to revert.
      fetch('/api/agents/' + encodeURIComponent(agentId) + '/start-host', { method: 'POST' })
        .then(function (response) {
          if (response.ok) {
            applyAuthoritativeMindLiveness(agentId, 'RUNNING');
          } else {
            console.error('Start for', agentId, 'returned HTTP', response.status);
            delete pendingMindActionByAgent[agentId];
            applyMindLiveness(agentId, 'STOPPED');
          }
        })
        .catch(function (err) {
          console.error('Start for', agentId, 'failed:', err);
          delete pendingMindActionByAgent[agentId];
          applyMindLiveness(agentId, 'STOPPED');
        });
    };

    window.landingStopClick = function (button) {
      var row = button.closest('[data-agent-id]');
      if (!row) return;
      var agentId = row.dataset.agentId;
      var name = row.dataset.mindName || agentId;
      // In the desktop shell, route through the relay so the main process can
      // show a native confirmation dialog and issue the stop itself (no in-page
      // optimistic flip -- the user may still cancel that dialog, and the result
      // arrives over the SSE). In a plain browser there is no shell, so confirm
      // in-page and stop via fetch with an optimistic transient.
      if (isElectronShell) {
        window.postMessage({ type: 'minds:confirm-stop-mind', agentId: agentId, name: name }, '*');
        return;
      }
      var ok = window.confirm('Stop "' + name + '"? Its agents will stop and its services become inaccessible. '
        + 'Data is preserved and you can start it again.');
      if (!ok) return;
      pendingMindActionByAgent[agentId] = 'STOPPED';
      applyMindLiveness(agentId, 'STOPPING');
      fetch('/api/agents/' + encodeURIComponent(agentId) + '/stop-host', { method: 'POST' })
        .then(function (response) {
          if (response.ok) {
            applyAuthoritativeMindLiveness(agentId, 'STOPPED');
          } else {
            console.error('Stop for', agentId, 'returned HTTP', response.status);
            delete pendingMindActionByAgent[agentId];
            applyMindLiveness(agentId, 'RUNNING');
          }
        })
        .catch(function (err) {
          console.error('Stop for', agentId, 'failed:', err);
          delete pendingMindActionByAgent[agentId];
          applyMindLiveness(agentId, 'RUNNING');
        });
    };

    var pendingToggleClickedAtByProvider = {};
    var lastEventAt = null;
    var lastFullSnapshotAt = null;
    var renderedProviders = null;

    function relativeAgo(iso) {
      if (!iso) return '—';
      var t = Date.parse(iso);
      if (isNaN(t)) return '—';
      var secs = Math.max(0, Math.round((Date.now() - t) / 1000));
      if (secs < 60) return secs + 's ago';
      if (secs < 3600) return Math.round(secs / 60) + 'm ago';
      if (secs < 86400) return Math.round(secs / 3600) + 'h ago';
      return Math.round(secs / 86400) + 'd ago';
    }

    function tickFreshness() {
      var el = document.querySelector('[data-providers-last-event]');
      if (el) el.textContent = relativeAgo(lastEventAt);
      var el2 = document.querySelector('[data-providers-last-snapshot]');
      if (el2) el2.textContent = relativeAgo(lastFullSnapshotAt);
    }
    setInterval(tickFreshness, 1000);

    function badgeClassForStatus(status) {
      if (status === 'ok') return 'bg-success/15 text-success';
      if (status === 'error') return 'bg-important/15 text-important';
      if (status === 'disabled') return 'bg-fill-subtle text-primary';
      return 'bg-fill-subtle text-primary';
    }

    function badgeLabelForStatus(status) {
      if (status === 'ok') return 'OK';
      if (status === 'error') return 'Error';
      if (status === 'disabled') return 'Disabled';
      return status;
    }

    function renderProvidersSummary(entries) {
      var summary = document.querySelector('[data-providers-summary]');
      if (!summary) return;
      var enabledCount = 0;
      var errorCount = 0;
      entries.forEach(function (entry) {
        if (entry.status !== 'disabled') enabledCount += 1;
        if (entry.status === 'error') errorCount += 1;
      });
      var providerWord = enabledCount === 1 ? 'provider' : 'providers';
      var text = enabledCount + ' ' + providerWord + ' enabled';
      if (errorCount > 0) {
        var errorWord = errorCount === 1 ? 'error' : 'errors';
        text += ' (' + errorCount + ' ' + errorWord + ')';
      }
      summary.textContent = text;
    }

    function renderProviders(payload) {
      var panel = document.querySelector('[data-providers-panel]');
      var list = document.querySelector('[data-providers-list]');
      if (!panel || !list) return;
      var entries = (payload && payload.providers) || [];
      if (entries.length === 0) {
        panel.hidden = true;
        list.innerHTML = '';
        return;
      }
      panel.hidden = false;
      renderProvidersSummary(entries);
      list.innerHTML = '';
      entries.forEach(function (entry) {
        var row = document.createElement('div');
        // Same surface as Card.jinja: ``.minds-card`` carries the
        // bg/border/rounded (no baseline shadow); the Tailwind utilities
        // handle the tight padding + flex layout. Keep this string in
        // sync with Card.jinja's class output when extending the
        // primitive.
        row.className = 'minds-card flex items-center gap-1.5 px-4 py-2';
        row.dataset.providerName = entry.name;

        var nameEl = document.createElement('span');
        nameEl.className = 'font-semibold text-primary';
        nameEl.textContent = entry.name;
        row.appendChild(nameEl);

        if (entry.backend) {
          var backendEl = document.createElement('span');
          backendEl.className = 'type-helper text-secondary';
          backendEl.textContent = entry.backend;
          row.appendChild(backendEl);
        }

        var badge = document.createElement('span');
        badge.className = 'inline-flex items-center px-2 py-0.5 rounded-md type-label ' + badgeClassForStatus(entry.status);
        badge.textContent = badgeLabelForStatus(entry.status);
        row.appendChild(badge);

        if (entry.status === 'error' && entry.error_message) {
          var err = document.createElement('span');
          err.className = 'flex-1 type-helper text-primary truncate';
          err.title = (entry.error_type || '') + ': ' + entry.error_message;
          err.textContent = (entry.error_type || '') + ': ' + entry.error_message;
          row.appendChild(err);
        } else {
          var spacer = document.createElement('span');
          spacer.className = 'flex-1';
          row.appendChild(spacer);
        }

        var pendingClickedAt = pendingToggleClickedAtByProvider[entry.name];
        var snapshotAt = lastFullSnapshotAt ? Date.parse(lastFullSnapshotAt) : 0;
        var isPending = pendingClickedAt && (!lastFullSnapshotAt || pendingClickedAt > snapshotAt);

        var btn = document.createElement('button');
        btn.className = 'px-2 py-1 type-helper rounded-md border border-default bg-surface-primary hover:bg-fill-hover text-primary';
        if (isPending) {
          btn.disabled = true;
          btn.textContent = 'Waiting…';
        } else if (entry.status === 'disabled') {
          btn.textContent = 'Enable';
          btn.onclick = function () { toggleProvider(entry.name, true); };
        } else {
          btn.textContent = 'Disable';
          btn.onclick = function () { toggleProvider(entry.name, false); };
        }
        row.appendChild(btn);

        list.appendChild(row);
      });
      renderedProviders = entries;
    }

    function toggleProvider(name, isEnabled) {
      pendingToggleClickedAtByProvider[name] = Date.now();
      renderProviders({ providers: renderedProviders || [] });
      fetch('/api/providers/' + encodeURIComponent(name) + '/toggle', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ is_enabled: isEnabled }),
      }).then(function (response) {
        if (!response.ok) {
          console.error('Provider toggle for', name, 'returned HTTP', response.status);
          delete pendingToggleClickedAtByProvider[name];
          renderProviders({ providers: renderedProviders || [] });
        }
      }).catch(function (err) {
        console.error('Provider toggle for', name, 'failed:', err);
        delete pendingToggleClickedAtByProvider[name];
        renderProviders({ providers: renderedProviders || [] });
      });
    }

    (function wireProvidersToggle() {
      var btn = document.querySelector('[data-providers-toggle]');
      var details = document.querySelector('[data-providers-details]');
      var chevron = document.querySelector('[data-providers-chevron]');
      if (!btn || !details || !chevron) return;
      btn.addEventListener('click', function () {
        var willShow = details.hidden;
        details.hidden = !willShow;
        chevron.textContent = willShow ? '▾' : '▸';
      });
    })();

    var BACKUP_BADGE_BASE = 'landing-backup-badge inline-flex items-center px-2 py-0.5 rounded-md type-label ';
    var BACKUP_RECENT_CREATE_MS = 75 * 60 * 1000;
    var BACKUP_CHECKING_TEXT = 'Checking backups…';

    function applyBackupBadge(agentId, status) {
      var row = getRow(agentId);
      if (!row) return;
      var badge = row.querySelector('.landing-backup-badge');
      if (!badge) return;
      var state = status && status.state;
      var text = '';
      var tone = 'bg-fill-subtle text-secondary';
      if (state === 'BACKING_UP') {
        text = 'Backing up…'; tone = 'bg-accent/15 text-accent';
      } else if (state === 'BACKED_UP') {
        text = 'Backed up ' + relativeAgo(status.last_success_at); tone = 'bg-success/15 text-success';
      } else if (state === 'NEVER') {
        text = 'Backup pending'; tone = 'bg-warning/15 text-warning';
      } else if (state === 'UNKNOWN') {
        text = 'Backup status unknown'; tone = 'bg-fill-subtle text-secondary';
      } else {
        var createdMs = status && status.created_at ? Date.parse(status.created_at) : NaN;
        if (!isNaN(createdMs) && (Date.now() - createdMs) < BACKUP_RECENT_CREATE_MS) {
          text = 'Created ' + relativeAgo(status.created_at); tone = 'bg-fill-subtle text-secondary';
        } else {
          text = 'No backups'; tone = 'bg-fill-subtle text-secondary';
        }
      }
      badge.textContent = text;
      badge.className = BACKUP_BADGE_BASE + tone;
      // Show via inline display, clearing any `display:none` a prior
      // clearBackupChecking set (a `.hidden` class can't hide this inline-flex
      // pill, so we drive visibility through style.display).
      badge.style.display = '';
      var download = row.querySelector('.landing-backup-download');
      if (download) {
        if (state === 'BACKED_UP') {
          download.textContent = 'download';
          download.classList.remove('hidden');
          download.onclick = function (ev) { return window.backupExport(ev, agentId); };
        } else {
          download.classList.add('hidden');
          download.onclick = null;
        }
      }
    }

    window.backupExport = function (ev, agentId) {
      ev.preventDefault();
      ev.stopPropagation();
      var link = ev.currentTarget;
      if (link.getAttribute('data-exporting') === '1') return false;
      link.setAttribute('data-exporting', '1');
      link.style.pointerEvents = 'none';
      var original = link.textContent;
      link.innerHTML = '<span class="spinner spinner-accent inline-block w-3 h-3 align-middle"></span> exporting…';
      function restore(text) {
        link.textContent = text;
        link.style.pointerEvents = '';
        link.removeAttribute('data-exporting');
      }
      fetch('/api/backup-export/' + encodeURIComponent(agentId)).then(function (resp) {
        if (!resp.ok) throw new Error('export failed: ' + resp.status);
        var disp = resp.headers.get('Content-Disposition') || '';
        var match = /filename="?([^"]+)"?/.exec(disp);
        var name = match ? match[1] : (agentId + '-backup.zip');
        return resp.blob().then(function (blob) { return { blob: blob, name: name }; });
      }).then(function (result) {
        var url = URL.createObjectURL(result.blob);
        var anchor = document.createElement('a');
        anchor.href = url;
        anchor.download = result.name;
        document.body.appendChild(anchor);
        anchor.click();
        document.body.removeChild(anchor);
        URL.revokeObjectURL(url);
        restore(original);
      }).catch(function (err) {
        console.error('Backup export failed:', err);
        link.textContent = 'export failed';
        setTimeout(function () { restore(original); }, 3000);
      });
      return false;
    };

    function showBackupChecking() {
      document.querySelectorAll('.landing-backup-badge').forEach(function (badge) {
        badge.textContent = BACKUP_CHECKING_TEXT;
        badge.className = BACKUP_BADGE_BASE + 'bg-fill-subtle text-secondary';
        badge.style.display = '';
      });
    }

    function clearBackupChecking() {
      document.querySelectorAll('.landing-backup-badge').forEach(function (badge) {
        if (badge.textContent === BACKUP_CHECKING_TEXT) {
          badge.textContent = '';
          badge.className = 'landing-backup-badge inline-flex items-center px-2 py-0.5 rounded-md type-label';
          // Hide via inline display, not a `.hidden` class (the base class is
          // inline-flex, which beats `.hidden` in the cascade).
          badge.style.display = 'none';
        }
      });
    }

    function loadBackupStatus() {
      showBackupChecking();
      fetch('/api/backup-status').then(function (response) {
        return response.ok ? response.json() : {};
      }).then(function (data) {
        Object.keys(data).forEach(function (agentId) { applyBackupBadge(agentId, data[agentId]); });
        clearBackupChecking();
      }).catch(function (err) {
        console.error('Backup status fetch failed:', err);
        clearBackupChecking();
      });
    }
    loadBackupStatus();

    var es = null;
    function connect() {
      if (es) es.close();
      es = new EventSource('/_chrome/events');
      es.onmessage = function (event) {
        var data;
        try { data = JSON.parse(event.data); } catch (e) { return; }
        if (data.type === 'system_interface_status') {
          var aid = data.agent_id;
          if (data.status === 'healthy') delete healthStatusByAgent[aid];
          else healthStatusByAgent[aid] = data.status;
          applyRowHealth(aid, data.status);
          return;
        }
        if (data.type === 'providers_state') {
          lastEventAt = data.last_event_at;
          lastFullSnapshotAt = data.last_full_snapshot_at;
          var snapshotAt = lastFullSnapshotAt ? Date.parse(lastFullSnapshotAt) : 0;
          Object.keys(pendingToggleClickedAtByProvider).forEach(function (name) {
            if (pendingToggleClickedAtByProvider[name] <= snapshotAt) {
              delete pendingToggleClickedAtByProvider[name];
            }
          });
          renderProviders(data);
          tickFreshness();
          return;
        }
        if (data.type !== 'workspaces' || !Array.isArray(data.workspaces)) return;
        var liveIds = data.workspaces.map(function (w) { return w.id; });
        var liveSet = new Set(liveIds);
        var differs = liveIds.length !== renderedSet.size
          || liveIds.some(function (id) { return !renderedSet.has(id); })
          || renderedIds.some(function (id) { return !liveSet.has(id); });
        if (differs) {
          es.close();
          location.reload();
          return;
        }
        // Same set of rows: apply each shutdown-capable mind's liveness in place
        // (it rides the workspace entry now, not a separate event).
        data.workspaces.forEach(function (w) {
          if (w.liveness) applyAuthoritativeMindLiveness(w.id, w.liveness);
        });
      };
      es.onerror = function () {
        if (!es) return;
        es.close();
        es = null;
        setTimeout(connect, 5000);
      };
    }
    // Reconcile each row with its server-seeded liveness before the SSE opens.
    Object.keys(mindLivenessByAgent).forEach(function (agentId) {
      applyMindLiveness(agentId, mindLivenessByAgent[agentId]);
    });
    connect();
  })();
</script>
{% endset %}
<Base title="Projects" scripts={{ _scripts }}>
  <PageContainer>
    {% if agent_ids %}
      <div class="flex items-center justify-between mb-4" data-landing-agent-ids="{{ agent_ids | map('string') | join(',') }}">
        <h1 class="type-heading text-primary">Projects</h1>
        <ButtonLink href="/create" variant="primary">Create</ButtonLink>
      </div>

      <div class="flex flex-col gap-1.5">
        {% for agent_id in agent_ids %}
          {% set destroying_status = destroying_status_by_agent_id.get(agent_id | string) %}
          {# Precompute row-local strings so the Card invocation stays readable.
             JinjaX component attributes are literal strings by default; the
             ':' prefix turns one into a Python expression. #}
          {% set accent_style = "--workspace-accent: " ~ agent_accents.get(agent_id | string, "#0b292b") ~ ";" %}
          {% set goto_href = mngr_forward_origin ~ "/goto/" ~ agent_id ~ "/" %}
          {% set destroying_href = "/destroying/" ~ agent_id %}
          {% set supports_shutdown = (agent_id | string) in shutdown_capable_agent_ids %}
          {% set mind_state = mind_liveness_by_agent_id.get(agent_id | string, "UNKNOWN") %}
          {# Inline display (not a ``.hidden`` class) controls which control shows:
             the button base class is ``inline-flex`` and would win over ``.hidden``.
             JinjaX evaluates ``:``-prefixed attrs as Python, so precompute here. #}
          {% set start_btn_style = "" if mind_state == "STOPPED" else "display:none" %}
          {% set stop_btn_style = "" if mind_state == "RUNNING" else "display:none" %}
          {% if destroying_status %}
            <Card tag="a" layout="row" interactive
                  extra="accent-spine relative overflow-hidden"
                  :href="destroying_href"
                  :style="accent_style">
              <span class="flex-1 font-semibold text-secondary pl-1">{{ agent_names.get(agent_id | string, agent_id) }}</span>
              {% if destroying_status == 'running' %}
                <StatusBadge extra="gap-2">
                  <Spinner size="sm" />
                  Destroying...
                </StatusBadge>
              {% else %}
                <StatusBadge variant="error">Destroy failed</StatusBadge>
              {% endif %}
            </Card>
          {% else %}
            <Card layout="row" interactive
                  extra="accent-spine relative overflow-hidden"
                  :style="accent_style"
                  :data-agent-id="agent_id"
                  :data-default-href="goto_href"
                  :data-mind-name="agent_names.get(agent_id | string, agent_id)"
                  onclick="window.landingRowClick(event, this)">
              <span class="flex-1 font-semibold text-primary pl-1">{{ agent_names.get(agent_id | string, agent_id) }}</span>
              {% set provider_label = agent_providers.get(agent_id | string, "") %}
              {% if provider_label %}
                <span class="landing-provider-badge inline-flex items-center px-2 py-0.5 rounded-md type-label bg-fill-subtle text-secondary">{{ provider_label }}</span>
              {% endif %}
              <span class="landing-backup-badge inline-flex items-center px-2 py-0.5 rounded-md type-label" style="display:none"></span>
              <Link href="#" class="landing-backup-download hidden cursor-pointer" extra="type-helper">download</Link>
              <span class="landing-mind-state-badge inline-flex items-center px-2 py-0.5 rounded-md type-label" style="display:none"></span>
              <span class="landing-health-badge inline-flex items-center px-2 py-0.5 rounded-md type-label" style="display:none"></span>
              {% if supports_shutdown %}
                {# Shutdown-capable (docker/lima) minds get container Start/Stop
                   instead of the recovery-only Restart button; JS toggles which is shown.
                   Visibility is driven by inline ``display`` (not a ``.hidden``
                   class) because the button base class is ``inline-flex``, which
                   would otherwise win and show both buttons. #}
                <Button variant="ghost" size="icon"
                        extra="landing-start-btn"
                        :style="start_btn_style"
                        onclick="event.stopPropagation(); window.landingStartClick(this)"
                        title="Start mind"
                        aria-label="Start mind">
                  <Icon16 name="play" />
                </Button>
                <Button variant="ghost" size="icon"
                        extra="landing-stop-btn"
                        :style="stop_btn_style"
                        onclick="event.stopPropagation(); window.landingStopClick(this)"
                        title="Stop mind"
                        aria-label="Stop mind">
                  <Icon16 name="pause" />
                </Button>
              {% else %}
                <Button variant="ghost" size="icon"
                        onclick="event.stopPropagation(); window.landingRestartClick(this)"
                        title="Restart workspace"
                        aria-label="Restart workspace">
                  <Icon16 name="restart" />
                </Button>
              {% endif %}
              <Button variant="ghost" size="icon"
                      onclick="event.stopPropagation(); window.landingOpenInNewWindow(this)"
                      title="Open in new window"
                      aria-label="Open workspace in new window">
                <Icon16 name="arrow-up-right" />
              </Button>
              <Button variant="ghost" size="icon"
                      onclick={{ "event.stopPropagation(); window.location='/workspace/" ~ agent_id ~ "/settings'" }}
                      title="Settings"
                      aria-label="Workspace settings">
                <Icon16 name="settings" />
              </Button>
            </Card>
          {% endif %}
        {% endfor %}
      </div>
    {% else %}
      {% if is_discovering %}
        <div class="flex items-center justify-center min-h-[80vh]">
          <p class="text-tertiary text-center">Discovering agents...</p>
        </div>
        <script>setTimeout(function() { location.reload(); }, 2000);</script>
      {% else %}
        <div class="text-center py-12">
          <p class="text-tertiary mb-6">No projects yet</p>
          <ButtonLink href="/create" variant="primary">Create</ButtonLink>
        </div>
      {% endif %}
    {% endif %}

    {# Providers panel: rendered empty server-side, populated by the SSE
       providers_state event. Collapsed by default to a one-line summary
       ("X providers enabled (N errors)" + chevron); user clicks the
       summary to expand into the full list + freshness counters. #}
    <section class="mt-8 pt-6 border-t border-default" data-providers-panel hidden>
      <button type="button" data-providers-toggle
              class="w-full flex items-center justify-between text-left type-body text-primary hover:text-primary bg-transparent border-0 cursor-pointer p-0">
        <span data-providers-summary>0 providers enabled</span>
        <span data-providers-chevron class="text-tertiary ml-2">&#9656;</span>
      </button>
      <div data-providers-details class="mt-3" hidden>
        <div class="flex items-center justify-end mb-3">
          <div class="type-helper text-secondary flex gap-4">
            <span>last event <span data-providers-last-event>&mdash;</span></span>
            <span>last snapshot <span data-providers-last-snapshot>&mdash;</span></span>
          </div>
        </div>
        <div class="flex flex-col gap-1.5" data-providers-list></div>
      </div>
    </section>
  </PageContainer>
</Base>
