{#def boot_state #}
{#
  Landing page shell: the workspace list, providers panel, unlock banner and
  bottom-left launchers are all rendered client-side by the mithril
  LandingPage component (frontend/src/views/LandingPage.ts), mounted
  synchronously from the ``#minds-boot-state`` island so the first paint is
  complete on arrival. ``boot_state`` carries the chrome snapshot (from
  build_chrome_boot_state()) under the ``chrome`` key plus the landing extras
  (launcher account, locked accounts, discovering flag, mngr-forward origin)
  under ``landing``.

  Row-set changes rerender from the store's SSE subscription -- there is no
  refetch-on-drift full-page path anymore. sync_status_banner.js still
  dispatches ``minds:refresh-local-page`` (an in-place swap re-render) when
  account sync status changes, which re-runs this shell with a fresh island.
#}
{% set _scripts %}
<script src="/_static/sync_status_banner.js" defer></script>
<script>
  window.MindsUI.mountLanding(document.getElementById('landing-root'));
</script>
{% endset %}
<ChromeShell title="Workspaces" :boot_state="boot_state" scripts={{ _scripts }}>
  <div id="landing-root"></div>
</ChromeShell>
