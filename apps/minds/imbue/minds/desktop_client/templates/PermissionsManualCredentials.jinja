{#def #}
{#
  Hidden manual-credentials info box. Rendered hidden by default; the
  PermissionsDialog JS unhides it and populates the message and command
  when the server returns outcome=NEEDS_MANUAL_CREDENTIALS.
#}
<div id="permissions-manual-credentials" class="hidden mt-4">
  <Notice variant="info">
    <p class="font-medium">Manual credential setup required</p>
    <p id="permissions-manual-credentials-message" class="mt-1"></p>
    <p class="mt-2 text-sm">Obtain credentials from the provider, replace any <code>&lt;placeholders&gt;</code> below with them, run the command in a terminal, then click Approve again:</p>
    <pre class="mt-2 bg-zinc-900 text-zinc-200 rounded-md p-3 text-xs overflow-x-auto"><code id="permissions-manual-credentials-command"></code></pre>
  </Notice>
</div>
