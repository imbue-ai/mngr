{#def onclick, id="" #}
{#
  Absolute-positioned X button at the top right of a modal dialog. The
  inline SVG is a stroke-2 X glyph at 20x20. Caller supplies the
  ``onclick`` handler.

  Currently exercised only by the DevStyleguide showcase page; the
  inbox modal inlines its own button so it can sit inside a grid header
  and carry the per-element ``-webkit-app-region: no-drag`` opt-out
  needed by the drawer's drag-region handling.
#}
<button type="button" aria-label="Close"
        {% if id %}id="{{ id }}"{% endif %}
        onclick="{{ onclick }}"
        class="absolute top-3 right-3 z-10 inline-flex items-center justify-center w-8 h-8 rounded-md text-tertiary hover:text-primary hover:bg-zinc-100 transition-colors cursor-pointer">
  <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="w-5 h-5">
    <path fill-rule="evenodd" clip-rule="evenodd"
          d="M4.22 4.22a.75.75 0 0 1 1.06 0L10 8.94l4.72-4.72a.75.75 0 1 1 1.06 1.06L11.06 10l4.72 4.72a.75.75 0 1 1-1.06 1.06L10 11.06l-4.72 4.72a.75.75 0 0 1-1.06-1.06L8.94 10 4.22 5.28a.75.75 0 0 1 0-1.06Z" />
  </svg>
</button>
