{#def id="", card_extra="" #}
{#
  Overlay-style modal: fixed dimming backdrop centering an inner card.
  The dialog is hidden by default (caller toggles ``hidden`` via JS to
  show/dismiss). Differs from PermissionsDialog -- that one is the
  permission-request-specific chrome with a close button and submission
  JS; this is the lighter pattern used for in-page confirmation
  dialogs.

  ``id`` -- attached to the outer wrapper so the page's JS can find it
  to toggle visibility.
  ``card_extra`` -- extra classes for the inner card (e.g. ``text-left``
  to override the inherited text alignment).
#}
<div {% if id %}id="{{ id }}"{% endif %} class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/30">
  <div class="bg-white rounded-xl shadow-lg border border-zinc-200 max-w-sm w-full mx-4 p-6 {{ card_extra }}">
    {{ content }}
  </div>
</div>
