{#def variant="primary", extra="", id="", form="", block=false #}
{#
  <button type="submit">. Use inside a <form> (or pass ``form="..."``) for
  form submission. Usage:
    <ButtonSubmit variant="primary" form="create-form">Save</ButtonSubmit>

  Pulls its base class string and variants map from the Catalog globals
  ``BTN_BASE`` / ``BTN_VARIANTS`` (defined in templates.py).
#}
<button type="submit"
        class="{{ BTN_BASE }} {{ BTN_VARIANTS[variant] }} {% if block %}w-full{% endif %} {{ extra }}"
        {% if id %}id="{{ id }}"{% endif %}
        {% if form %}form="{{ form }}"{% endif %}>{{ content }}</button>
