{#def variant="primary", extra="", id="", form="", block=false, disabled=false #}
{#
  <button type="submit">. Use inside a <form> (or pass ``form="..."``) for
  form submission. Usage:
    <ButtonSubmit variant="primary" form="create-form">Save</ButtonSubmit>

  Pulls its base class string and variants map from the Catalog globals
  ``BTN_BASE`` / ``BTN_VARIANTS`` (defined in templates.py).

  ``disabled`` toggles the initial ``disabled`` attribute (JS can flip it
  back on/off after first paint). The disabled-state utility classes are
  already part of ``BTN_BASE`` so no extra styling is needed.
#}
<button type="submit"
        class="{{ BTN_BASE }} {{ BTN_VARIANTS[variant] }} {% if block %}w-full{% endif %} {{ extra }}"
        {% if id %}id="{{ id }}"{% endif %}
        {% if form %}form="{{ form }}"{% endif %}
        {% if disabled %}disabled{% endif %}>{{ content }}</button>
