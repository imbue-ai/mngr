{#def agent_id, accounts=[], redirect_url="", has_account=True, boot_state=None #}
{#
  The sharing editor body, shared between the full /sharing page
  (pages.Sharing, the browser-mode fallback) and the centered sharing modal
  (pages.SharingModal, the Electron overlay surface).

  Shows the Associate prompt when the workspace has no account yet; otherwise
  a mount container + the page's boot island for the mithril SharingEditor
  component (frontend/src/views/SharingEditor.ts), which owns the heading
  takeover, the shared-URL section, the three-state access list, and the
  Update/Disable submission flow. The mount call itself lives in each
  wrapper page's scripts block -- it must run after the component bundle
  (and, in the modal, after dismissSharingModal is defined).

  ``boot_state`` is the island dict ({"sharing": SharingBootExtras}); it is
  required whenever ``has_account`` is true and must appear at most once per
  page (the island id is the one-per-document #minds-boot-state).
#}
{% if not has_account %}
  <Associate :agent_id="agent_id" :accounts="accounts" :redirect_url="redirect_url" />
{% else %}
  <div id="sharing-editor-root"></div>
  <script type="application/json" id="minds-boot-state">{{ boot_state | tojson }}</script>
{% endif %}
