# ToDesktop's CI runs `npx pnpm@latest install`. pnpm 11.x treats
# ERR_PNPM_IGNORED_BUILDS as fatal. ignore-scripts=true skips all
# install-time scripts (electron, protobufjs, etc.) so the install
# succeeds. The packaged app doesn't need those scripts to have run
# (electron postinstall caches the runtime in ~/.cache; we ship our
# own copy via @todesktop/runtime + Electron binary in resources/).
ignore-scripts=true
auto-install-peers=true
