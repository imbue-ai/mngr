# Per-user config for minds release tooling. Copy to apps/minds/.env (which is
# gitignored) and fill in. Read only by `just sync-vendor-mngr` -- nothing else
# loads it, and nothing personal is committed.

# Absolute path to your default-workspace-template checkout, used during a minds
# release (see apps/minds/docs/release.md, step 3).
DEFAULT_WORKSPACE_TEMPLATE_DIR=/abs/path/to/default-workspace-template
